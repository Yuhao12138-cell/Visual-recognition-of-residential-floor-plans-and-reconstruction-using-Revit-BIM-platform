    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# 加载PythonStandard 和 DesignScript 库\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\nimport Autodesk.DesignScript.Geometry as DS\r\nimport Revit\r\nfrom Revit.Elements import *\r\nimport System\r\nsys.path.append(\"C:/Users/Lenovo/anaconda3/envs/revitenv/Lib/site-packages\")\r\nclr.AddReference('RevitAPI')\r\nclr.AddReference('RevitAPIUI')\r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.UI import *\r\n\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\nclr.AddReference('RevitNodes')\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\n#\r\nimport re\r\nimport numpy as np\r\nimport torch\r\nimport cv2\r\nfrom ultralytics import YOLO\r\n\r\ndataEnteringNode = IN \r\ndect_Model = IN[0]\r\npixpath = IN[1]\r\nscale = IN[2]\r\n#params\r\norigin = XYZ(0, 0, 0)   \r\nwidthFt = scale\r\npixelWidth = 1600   \r\npixelHeight = 1200                          \r\n#                         \r\nyolo_dect = YOLO(dect_Model,task = \"detect\")\r\nnewpath = \"E:/yanjiu/revitss/tests/jjianzhu_dect.jpg\"\r\n\r\ndect_result = yolo_dect(source = pixpath,save = False,conf = 0.3,iou = 0.45,imgsz = 640)\r\ncv2.imwrite(newpath,dect_result[0].plot())\r\n#tempouts = []\r\n#tempouts.append(newpath)\r\n#tempouts.extend(dect_result)\r\nscaleX = widthFt / pixelWidth\r\nscaleY = widthFt * (pixelHeight / pixelWidth) / pixelHeight  \r\n\r\nresult = dect_result[0]        \r\nboxes = result.boxes\r\nxyxy = boxes.xyxy.cpu().numpy() \r\ncls_ids = boxes.cls.cpu().numpy().astype(int)  # 类别索引 (N,)\r\nnames = result.names  \r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\napp = doc.Application\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\ncreated_lines = []\r\ndyn_lines = []\r\ndyn_faces = [] \r\ncreated_shapes = []\r\n\r\ndef pix_to_revit(x, y):\r\n    revit_x = origin.X + x * scaleX\r\n    revit_y = origin.Y + (pixelHeight - y) * scaleY  # 翻转 Y 轴\r\n    return XYZ(revit_x, revit_y, origin.Z)\r\ndef sanitize_name(name):\r\n    # 如果名称为空，返回默认名称\r\n    if not name:\r\n        return \"Unknown\"\r\n    # 移除控制字符（ASCII 0-31，除了tab? 但最好全部移除）\r\n    # 允许常见字符：字母、数字、空格、下划线、连字符、中文等\r\n    # 保留所有打印字符，移除控制字符\r\n    cleaned = re.sub(r'[\\x00-\\x1f\\x7f]', '', name)\r\n    # 如果清理后为空，则返回默认名\r\n    if not cleaned.strip():\r\n        return \"Unnamed\"\r\n    return cleaned\r\n\r\nplane = Plane.CreateByNormalAndOrigin(XYZ.BasisZ, origin)\r\nsketch_plane = SketchPlane.Create(doc, plane)\r\n\r\nfor i, bbox in enumerate(xyxy):\r\n    x1, y1, x2, y2 = bbox  # 左上角 (x1,y1), 右下角 (x2,y2)\r\n    \r\n    # 计算四个角点的 Revit 坐标\r\n    pt1 = pix_to_revit(x1, y1)  # 左上\r\n    pt2 = pix_to_revit(x2, y1)  # 右上\r\n    pt3 = pix_to_revit(x2, y2)  # 右下\r\n    pt4 = pix_to_revit(x1, y2)  # 左下\r\n   \r\n    dyn_pt1 = pt1.ToPoint()\r\n    dyn_pt2 = pt2.ToPoint()\r\n    dyn_pt3 = pt3.ToPoint()\r\n    dyn_pt4 = pt4.ToPoint()\r\n    # 创建四条线\r\n    lines = [\r\n        Line.CreateBound(pt1, pt2),\r\n        Line.CreateBound(pt2, pt3),\r\n        Line.CreateBound(pt3, pt4),\r\n        Line.CreateBound(pt4, pt1)\r\n    ]\r\n    \r\n    # 创建模型线并添加到列表\r\n    for line in lines:\r\n        model_curve = doc.Create.NewModelCurve(line, sketch_plane)\r\n        created_lines.append(model_curve)\r\n        start_dyn = line.GetEndPoint(0).ToPoint()\r\n        end_dyn = line.GetEndPoint(1).ToPoint()\r\n        dyn_line = DS.Line.ByStartPointEndPoint(start_dyn, end_dyn)\r\n        dyn_lines.append(dyn_line)\r\n    points = [dyn_pt1, dyn_pt2, dyn_pt3, dyn_pt4]\r\n    poly = DS.PolyCurve.ByPoints(points, connectLastToFirst=True)\r\n    if poly.IsClosed:\r\n        surface = DS.Surface.ByPatch(poly)\r\n        dyn_faces.append(surface)\r\n    curve_loop = CurveLoop()\r\n    curve_loop.Append(Line.CreateBound(pt1, pt2))\r\n    curve_loop.Append(Line.CreateBound(pt2, pt3))\r\n    curve_loop.Append(Line.CreateBound(pt3, pt4))\r\n    curve_loop.Append(Line.CreateBound(pt4, pt1))\r\n    \r\n    thickness = 0.001  # 可根据需要调整\r\n    solid = GeometryCreationUtilities.CreateExtrusionGeometry(\r\n        [curve_loop], XYZ.BasisZ, thickness)\r\n    direct_shape = DirectShape.CreateElement(doc, ElementId(BuiltInCategory.OST_GenericModel))\r\n    direct_shape.SetShape([solid])\r\n    class_id = cls_ids[i]\r\n    class_name = names[class_id]\r\n    safe_name = sanitize_name(class_name)\r\n    direct_shape.Name = \"YOLO_\" + safe_name\r\n    created_shapes.append(direct_shape)    \r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\ndoc.Regenerate()\r\n# Outs\r\n#OUT = [created_lines, dyn_lines]\r\nOUT = newpath,created_shapes",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "a600793b85d44596a6909142ff5352ff",
      "NodeType": "PythonScriptNode",
      "Inputs": [

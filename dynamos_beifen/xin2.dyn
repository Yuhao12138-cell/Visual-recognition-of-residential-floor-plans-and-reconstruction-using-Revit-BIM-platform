    {
      "ConcreteType": "Dynamo.Graph.Nodes.ZeroTouch.DSFunction, DynamoCore",
      "Id": "8504d09dc5ce44a4bcf0b6c80f2b3b0b",
      "NodeType": "FunctionNode",
      "Inputs": [
        {
          "Id": "a1b46d3c481b423481ac07af7410b115",
          "Name": "file",
          "Description": "要加载其图像的文件对象\n\nvar",

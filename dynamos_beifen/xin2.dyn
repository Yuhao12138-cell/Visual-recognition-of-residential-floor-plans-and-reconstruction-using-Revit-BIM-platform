    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\nsymbols_info = []\r\n\r\ncollector = FilteredElementCollector(doc).OfClass(FamilySymbol)\r\n\r\nfor fs in collector:\r\n    try:\r\n        cat_name = fs.Category.Name if fs.Category else \"NoCategory\"\r\n        fam_name = fs.Family.Name if fs.Family else \"NoFamily\"\r\n        \r\n        type_name = \"\"\r\n        p = fs.get_Parameter(BuiltInParameter.SYMBOL_NAME_PARAM)\r\n        if p:\r\n            type_name = p.AsString()\r\n        else:\r\n            type_name = fs.Name\r\n\r\n        symbols_info.append((cat_name, fam_name, type_name, fs.Id.IntegerValue))\r\n    except Exception as e:\r\n        symbols_info.append((\"ERROR\", str(e)))\r\n\r\nOUT = symbols_info\r\n",
      "Engine": "CPython3",
      "VariableInputPorts": true,

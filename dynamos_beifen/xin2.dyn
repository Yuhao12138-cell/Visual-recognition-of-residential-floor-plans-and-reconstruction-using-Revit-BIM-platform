          "KeepListStructure": false
        },
        {
          "Id": "be4e2accb2cd4088b212006a88282a15",
          "Name": "IN[2]",
          "Description": "Input #2",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [

    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# -*- coding: utf-8 -*-\r\n#--------------\r\nimport sys\r\nimport clr\r\nimport math\r\nimport json\r\nimport numpy as np\r\nimport cv2\r\n\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\nclr.AddReference('RevitAPI')\r\nclr.AddReference('RevitAPIUI')\r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.DB.Structure import StructuralType\r\n\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\nclr.AddReference('RevitNodes')\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\n\r\nsys.path.append(\"C:/Users/Lenovo/anaconda3/envs/revitenv/Lib/site-packages\")\r\nfrom ultralytics import YOLO\r\n\r\n\r\n# ============================================================\r\n# 输入\r\n# ============================================================\r\npose_Model = IN[0]\r\npixpath = IN[1]\r\nscale = IN[2]\r\ntarget_family_name = IN[3] if len(IN) > 3 else \"Bed\"\r\ntarget_type_name = IN[4] if len(IN) > 4 else \"Only_Bed\"\r\nseg_meta_json_path = IN[5] if len(IN) > 5 else None\r\nclass_config_json_path = IN[6] if len(IN) > 6 else None\r\n\r\n\r\n# ============================================================\r\n# 全局参数\r\n# ============================================================\r\norigin = XYZ(0, 0, 0)\r\nwidthFt = scale\r\npixelWidth = 1600\r\npixelHeight = 1200\r\n\r\nbbox_min_x = None\r\nbbox_min_y = None\r\nbbox_width = None\r\nbbox_height = None\r\nscale_x_ft_per_px = None\r\nscale_y_ft_per_px = None\r\n\r\nlogs = []\r\n\r\n\r\n# ============================================================\r\n# 默认配置\r\n# ============================================================\r\nDEFAULT_CLASS_CONFIG = {\r\n    \"Bed\": {\r\n        \"family_name\": \"Bed\",\r\n        \"type_name\": \"Bed\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": True,\r\n        \"family_default_axis\": \"Y\",\r\n        \"placement_mode\": \"free\"\r\n    },\r\n    \"BedSingle\": {\r\n        \"family_name\": \"BedSingle\",\r\n        \"type_name\": \"BedSingle\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\",\r\n        \"placement_mode\": \"free\"\r\n    },\r\n    \"CookingCounter\": {\r\n        \"family_name\": \"CookingCounter\",\r\n        \"type_name\": \"CookingCounter\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\",\r\n        \"placement_mode\": \"free\"\r\n    },\r\n    \"Cabinet\": {\r\n        \"family_name\": \"Cabinet\",\r\n        \"type_name\": \"Cabinet\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\",\r\n        \"placement_mode\": \"free\"\r\n    },\r\n    \"DiningTable\": {\r\n        \"family_name\": \"DiningTable\",\r\n        \"type_name\": \"DiningTable\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\",\r\n        \"placement_mode\": \"free\"\r\n    },\r\n    \"DiningTables\": {\r\n        \"family_name\": \"DiningTables\",\r\n        \"type_name\": \"DiningTables\",\r\n        \"rotate\": False,\r\n        \"area_filter\": False,\r\n        \"placement_mode\": \"free\"\r\n    },\r\n    \"Sofa\": {\r\n        \"family_name\": \"Sofa\",\r\n        \"type_name\": \"Sofa\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\",\r\n        \"placement_mode\": \"free\"\r\n    },\r\n    \"TVStand\": {\r\n        \"family_name\": \"TVStand\",\r\n        \"type_name\": \"TVStand\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\",\r\n        \"placement_mode\": \"free\"\r\n    },\r\n    \"Toilet\": {\r\n        \"family_name\": \"Toilet\",\r\n        \"type_name\": \"Toilet\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\",\r\n        \"placement_mode\": \"free\"\r\n    },\r\n    \"LeftDoor\": {\r\n        \"family_name\": \"LeftDoor\",\r\n        \"type_name\": \"LeftDoor\",\r\n        \"rotate\": False,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"placement_mode\": \"door_hosted\",\r\n        \"door_insert_offset_along_ft\": 0.0,\r\n        \"door_insert_offset_normal_ft\": 0.0,\r\n        \"door_max_host_wall_dist_ft\": 3.0,\r\n        \"door_geometry_match\": True\r\n    },\r\n    \"RightDoor\": {\r\n        \"family_name\": \"RightDoor\",\r\n        \"type_name\": \"RightDoor\",\r\n        \"rotate\": False,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"placement_mode\": \"door_hosted\",\r\n        \"door_insert_offset_along_ft\": 0.0,\r\n        \"door_insert_offset_normal_ft\": 0.0,\r\n        \"door_max_host_wall_dist_ft\": 3.0,\r\n        \"door_geometry_match\": True\r\n    }\r\n}\r\n\r\n\r\n# ============================================================\r\n# 基础工具\r\n# ============================================================\r\ndef norm_str(s):\r\n    if s is None:\r\n        return \"\"\r\n    return str(s).strip().lower()\r\n\r\n\r\ndef load_json_file(json_path, logs, label):\r\n    if not json_path:\r\n        logs.append(\"{}为空\".format(label))\r\n        return None\r\n    try:\r\n        with open(json_path, \"r\", encoding=\"utf-8\") as f:\r\n            data = json.load(f)\r\n        logs.append(\"读取{}成功: {}\".format(label, json_path))\r\n        return data\r\n    except Exception as e:\r\n        logs.append(\"读取{}失败: {}\".format(label, str(e)))\r\n        return None\r\n\r\n\r\ndef load_class_config(class_config_json_path, logs):\r\n    data = load_json_file(class_config_json_path, logs, \"class_config_json_path\")\r\n    if isinstance(data, dict) and len(data) > 0:\r\n        logs.append(\"使用外部CLASS_CONFIG，共{}类\".format(len(data)))\r\n        return data\r\n    logs.append(\"使用内置DEFAULT_CLASS_CONFIG，共{}类\".format(len(DEFAULT_CLASS_CONFIG)))\r\n    return DEFAULT_CLASS_CONFIG\r\n\r\n\r\ndef load_seg_meta(seg_meta_json_path, logs):\r\n    return load_json_file(seg_meta_json_path, logs, \"seg_meta_json_path\")\r\n\r\n\r\ndef pix_to_revit(x, y):\r\n    global bbox_min_x, bbox_min_y, bbox_height\r\n    global scale_x_ft_per_px, scale_y_ft_per_px\r\n    global origin, widthFt, pixelWidth, pixelHeight\r\n\r\n    try:\r\n        if bbox_min_x is not None and bbox_min_y is not None and bbox_height is not None and \\\r\n           scale_x_ft_per_px is not None and scale_y_ft_per_px is not None:\r\n            local_x = x - bbox_min_x\r\n            local_y = y - bbox_min_y\r\n            revit_x = origin.X + local_x * scale_x_ft_per_px\r\n            revit_y = origin.Y + (bbox_height - local_y) * scale_y_ft_per_px\r\n            return XYZ(revit_x, revit_y, origin.Z)\r\n    except:\r\n        pass\r\n\r\n    scaleX = widthFt / pixelWidth if pixelWidth > 0 else 0.0\r\n    scaleY = widthFt * (float(pixelHeight) / float(pixelWidth)) / pixelHeight if pixelWidth > 0 and pixelHeight > 0 else 0.0\r\n    revit_x = origin.X + x * scaleX\r\n    revit_y = origin.Y + (pixelHeight - y) * scaleY\r\n    return XYZ(revit_x, revit_y, origin.Z)\r\n\r\n\r\ndef get_level(doc):\r\n    av = doc.ActiveView\r\n    try:\r\n        if hasattr(av, \"GenLevel\") and av.GenLevel:\r\n            return av.GenLevel\r\n    except:\r\n        pass\r\n\r\n    levels = FilteredElementCollector(doc).OfClass(Level).ToElements()\r\n    if levels and len(levels) > 0:\r\n        return levels[0]\r\n\r\n    return None\r\n\r\n\r\ndef build_symbol_lookup(doc):\r\n    lookup = {}\r\n    collector = FilteredElementCollector(doc).OfClass(FamilySymbol)\r\n\r\n    for fs in collector:\r\n        try:\r\n            fam_name = fs.Family.Name if fs.Family else \"\"\r\n            p = fs.get_Parameter(BuiltInParameter.SYMBOL_NAME_PARAM)\r\n            typ_name = p.AsString() if p else fs.Name\r\n            lookup[(norm_str(fam_name), norm_str(typ_name))] = fs\r\n        except:\r\n            pass\r\n\r\n    return lookup\r\n\r\n\r\ndef get_symbol_from_lookup(symbol_lookup, family_name, type_name):\r\n    key = (norm_str(family_name), norm_str(type_name))\r\n    return symbol_lookup.get(key, None)\r\n\r\n\r\ndef ensure_symbol_active(doc, symbol):\r\n    if symbol and not symbol.IsActive:\r\n        symbol.Activate()\r\n        doc.Regenerate()\r\n\r\n\r\ndef xyz_sub(a, b):\r\n    return XYZ(a.X - b.X, a.Y - b.Y, a.Z - b.Z)\r\n\r\n\r\ndef xyz_add(a, b):\r\n    return XYZ(a.X + b.X, a.Y + b.Y, a.Z + b.Z)\r\n\r\n\r\ndef xyz_mul(v, s):\r\n    return XYZ(v.X * s, v.Y * s, v.Z * s)\r\n\r\n\r\ndef xyz_len2d(v):\r\n    return math.sqrt(v.X * v.X + v.Y * v.Y)\r\n\r\n\r\ndef xyz_norm2d(v):\r\n    l = xyz_len2d(v)\r\n    if l < 1e-9:\r\n        return None\r\n    return XYZ(v.X / l, v.Y / l, 0)\r\n\r\n\r\ndef dot2d(a, b):\r\n    return a.X * b.X + a.Y * b.Y\r\n\r\n\r\ndef dist2d(a, b):\r\n    dx = a.X - b.X\r\n    dy = a.Y - b.Y\r\n    return math.sqrt(dx * dx + dy * dy)\r\n\r\n\r\ndef clamp(v, a, b):\r\n    return max(a, min(b, v))\r\n\r\n\r\ndef angle_of_vector_2d(v):\r\n    return math.atan2(v.Y, v.X)\r\n\r\n\r\ndef normalize_angle(angle):\r\n    while angle > math.pi:\r\n        angle -= 2.0 * math.pi\r\n    while angle < -math.pi:\r\n        angle += 2.0 * math.pi\r\n    return angle\r\n\r\n\r\ndef rotate_instance(doc, instance, center_pt, angle):\r\n    axis_end = XYZ(center_pt.X, center_pt.Y, center_pt.Z + 1.0)\r\n    axis = Line.CreateBound(center_pt, axis_end)\r\n    ElementTransformUtils.RotateElement(doc, instance.Id, axis, angle)\r\n\r\n\r\ndef create_family_instance(doc, center_pt, symbol, level):\r\n    try:\r\n        return doc.Create.NewFamilyInstance(\r\n            center_pt,\r\n            symbol,\r\n            level,\r\n            StructuralType.NonStructural\r\n        )\r\n    except:\r\n        return doc.Create.NewFamilyInstance(\r\n            center_pt,\r\n            symbol,\r\n            doc.ActiveView\r\n        )\r\n\r\n\r\ndef get_angle_from_keypoints(start_pt, end_pt, family_default_axis=\"Y\"):\r\n    vec = XYZ(start_pt.X - end_pt.X, start_pt.Y - end_pt.Y, 0)\r\n    if vec.GetLength() < 1e-6:\r\n        return None\r\n\r\n    angle = math.atan2(vec.Y, vec.X)\r\n\r\n    if family_default_axis == \"Y\":\r\n        angle -= math.pi / 2.0\r\n\r\n    return angle\r\n\r\n\r\ndef compute_class_area_threshold(boxes, cls_ids, names, class_name, scale_ratio=0.33):\r\n    areas = []\r\n\r\n    for i, bbox in enumerate(boxes):\r\n        cls_name = names[int(cls_ids[i])] if len(cls_ids) > i else \"\"\r\n        if cls_name != class_name:\r\n            continue\r\n\r\n        x1, y1, x2, y2 = bbox\r\n        areas.append(max(0, x2 - x1) * max(0, y2 - y1))\r\n\r\n    if len(areas) == 0:\r\n        return 0.0, 0.0\r\n\r\n    median_area = float(np.median(areas))\r\n    return median_area, median_area * scale_ratio\r\n\r\n\r\n# ============================================================\r\n# 墙相关\r\n# ============================================================\r\ndef get_wall_curve(wall):\r\n    try:\r\n        loc = wall.Location\r\n        if loc and hasattr(loc, \"Curve\"):\r\n            return loc.Curve\r\n    except:\r\n        pass\r\n    return None\r\n\r\n\r\ndef point_to_curve_distance_2d(pt, curve):\r\n    try:\r\n        proj = curve.Project(pt)\r\n        if proj:\r\n            q = proj.XYZPoint\r\n            dx = pt.X - q.X\r\n            dy = pt.Y - q.Y\r\n            return math.sqrt(dx * dx + dy * dy), q\r\n    except:\r\n        pass\r\n\r\n    return None, None\r\n\r\n\r\ndef get_nearest_wall(doc, pt, max_dist_ft=3.0):\r\n    nearest_wall = None\r\n    nearest_curve = None\r\n    nearest_proj_pt = None\r\n    best_dist = 1e18\r\n\r\n    walls = FilteredElementCollector(doc).OfClass(Wall).ToElements()\r\n\r\n    for wall in walls:\r\n        try:\r\n            curve = get_wall_curve(wall)\r\n            if curve is None:\r\n                continue\r\n\r\n            dist, proj_pt = point_to_curve_distance_2d(pt, curve)\r\n            if dist is None:\r\n                continue\r\n\r\n            if dist < best_dist and dist <= max_dist_ft:\r\n                best_dist = dist\r\n                nearest_wall = wall\r\n                nearest_curve = curve\r\n                nearest_proj_pt = proj_pt\r\n        except:\r\n            continue\r\n\r\n    return nearest_wall, nearest_curve, nearest_proj_pt, best_dist\r\n\r\n\r\ndef get_wall_direction_unit(curve):\r\n    p0 = curve.GetEndPoint(0)\r\n    p1 = curve.GetEndPoint(1)\r\n    return xyz_norm2d(xyz_sub(p1, p0))\r\n\r\n\r\ndef get_wall_normal_unit_2d(wall_dir):\r\n    if wall_dir is None:\r\n        return None\r\n    return XYZ(-wall_dir.Y, wall_dir.X, 0)\r\n\r\n\r\n# ============================================================\r\n# 门族宽度\r\n# ============================================================\r\ndef get_symbol_width_ft(symbol):\r\n    cand_names = [\"AI_Width\", \"Width\", \"宽度\"]\r\n\r\n    for n in cand_names:\r\n        try:\r\n            p = symbol.LookupParameter(n)\r\n            if p and p.StorageType == StorageType.Double:\r\n                val = p.AsDouble()\r\n                if val and val > 1e-6:\r\n                    return val\r\n        except:\r\n            pass\r\n\r\n    builtin_candidates = [\r\n        BuiltInParameter.DOOR_WIDTH,\r\n        BuiltInParameter.FAMILY_WIDTH_PARAM\r\n    ]\r\n\r\n    for bip in builtin_candidates:\r\n        try:\r\n            p = symbol.get_Parameter(bip)\r\n            if p:\r\n                val = p.AsDouble()\r\n                if val and val > 1e-6:\r\n                    return val\r\n        except:\r\n            pass\r\n\r\n    return None\r\n\r\n\r\ndef place_hosted_door_instance(doc, level, symbol, wall, insert_pt):\r\n    try:\r\n        return doc.Create.NewFamilyInstance(\r\n            insert_pt,\r\n            symbol,\r\n            wall,\r\n            level,\r\n            StructuralType.NonStructural\r\n        )\r\n    except:\r\n        return doc.Create.NewFamilyInstance(\r\n            insert_pt,\r\n            symbol,\r\n            wall,\r\n            StructuralType.NonStructural\r\n        )\r\n\r\n\r\n# ============================================================\r\n# flip 工具\r\n# ============================================================\r\ndef can_flip_hand(inst):\r\n    try:\r\n        return inst.CanFlipHand\r\n    except:\r\n        return False\r\n\r\n\r\ndef can_flip_facing(inst):\r\n    try:\r\n        return inst.CanFlipFacing\r\n    except:\r\n        return False\r\n\r\n\r\ndef get_flip_state(inst):\r\n    hand = False\r\n    facing = False\r\n\r\n    try:\r\n        hand = inst.HandFlipped\r\n    except:\r\n        pass\r\n\r\n    try:\r\n        facing = inst.FacingFlipped\r\n    except:\r\n        pass\r\n\r\n    return hand, facing\r\n\r\n\r\ndef set_flip_state(inst, target_hand, target_facing):\r\n    changed = []\r\n\r\n    try:\r\n        cur_hand = inst.HandFlipped\r\n    except:\r\n        cur_hand = False\r\n\r\n    try:\r\n        cur_facing = inst.FacingFlipped\r\n    except:\r\n        cur_facing = False\r\n\r\n    if cur_hand != target_hand:\r\n        if can_flip_hand(inst):\r\n            inst.flipHand()\r\n            changed.append(\"flipHand\")\r\n        else:\r\n            return False, changed\r\n\r\n    try:\r\n        cur_facing = inst.FacingFlipped\r\n    except:\r\n        cur_facing = False\r\n\r\n    if cur_facing != target_facing:\r\n        if can_flip_facing(inst):\r\n            inst.flipFacing()\r\n            changed.append(\"flipFacing\")\r\n        else:\r\n            return False, changed\r\n\r\n    return True, changed\r\n\r\n\r\ndef get_candidate_flip_states(inst):\r\n    cur_hand, cur_facing = get_flip_state(inst)\r\n\r\n    raw = [\r\n        (cur_hand, cur_facing),\r\n        (not cur_hand, cur_facing),\r\n        (cur_hand, not cur_facing),\r\n        (not cur_hand, not cur_facing)\r\n    ]\r\n\r\n    states = []\r\n    seen = set()\r\n\r\n    for h, f in raw:\r\n        if (h, f) in seen:\r\n            continue\r\n\r\n        if h != cur_hand and not can_flip_hand(inst):\r\n            continue\r\n\r\n        if f != cur_facing and not can_flip_facing(inst):\r\n            continue\r\n\r\n        states.append((h, f))\r\n        seen.add((h, f))\r\n\r\n    return states\r\n\r\n\r\n# ============================================================\r\n# 实例真实平面几何读取\r\n# ============================================================\r\ndef segment_midpoint_2d(p0, p1):\r\n    return XYZ((p0.X + p1.X) * 0.5, (p0.Y + p1.Y) * 0.5, 0)\r\n\r\n\r\ndef segment_dir_2d(p0, p1):\r\n    return xyz_norm2d(XYZ(p1.X - p0.X, p1.Y - p0.Y, 0))\r\n\r\n\r\ndef safe_transform_point(trf, p):\r\n    try:\r\n        return trf.OfPoint(p)\r\n    except:\r\n        return p\r\n\r\n\r\ndef extract_instance_plan_segments_recursive(geom_elem, trf, out_segments):\r\n    if geom_elem is None:\r\n        return\r\n\r\n    for g in geom_elem:\r\n        try:\r\n            if isinstance(g, GeometryInstance):\r\n                try:\r\n                    sym_trf = trf.Multiply(g.Transform)\r\n                    sym_geom = g.GetSymbolGeometry()\r\n                    extract_instance_plan_segments_recursive(sym_geom, sym_trf, out_segments)\r\n                except:\r\n                    pass\r\n\r\n                try:\r\n                    inst_geom = g.GetInstanceGeometry()\r\n                    extract_instance_plan_segments_recursive(inst_geom, trf, out_segments)\r\n                except:\r\n                    pass\r\n\r\n            elif isinstance(g, Line):\r\n                p0 = safe_transform_point(trf, g.GetEndPoint(0))\r\n                p1 = safe_transform_point(trf, g.GetEndPoint(1))\r\n                out_segments.append((XYZ(p0.X, p0.Y, 0), XYZ(p1.X, p1.Y, 0), \"Line\"))\r\n\r\n            elif isinstance(g, Arc):\r\n                p0 = safe_transform_point(trf, g.GetEndPoint(0))\r\n                p1 = safe_transform_point(trf, g.GetEndPoint(1))\r\n                out_segments.append((XYZ(p0.X, p0.Y, 0), XYZ(p1.X, p1.Y, 0), \"ArcChord\"))\r\n\r\n            elif isinstance(g, Curve):\r\n                try:\r\n                    p0 = safe_transform_point(trf, g.GetEndPoint(0))\r\n                    p1 = safe_transform_point(trf, g.GetEndPoint(1))\r\n                    out_segments.append((XYZ(p0.X, p0.Y, 0), XYZ(p1.X, p1.Y, 0), \"CurveChord\"))\r\n                except:\r\n                    pass\r\n\r\n            elif isinstance(g, Solid):\r\n                try:\r\n                    for edge in g.Edges:\r\n                        c = edge.AsCurve()\r\n                        p0 = safe_transform_point(trf, c.GetEndPoint(0))\r\n                        p1 = safe_transform_point(trf, c.GetEndPoint(1))\r\n                        out_segments.append((XYZ(p0.X, p0.Y, 0), XYZ(p1.X, p1.Y, 0), \"SolidEdge\"))\r\n                except:\r\n                    pass\r\n\r\n        except:\r\n            continue\r\n\r\n\r\ndef get_instance_plan_segments(doc, inst):\r\n    opts = Options()\r\n    opts.ComputeReferences = False\r\n    opts.IncludeNonVisibleObjects = True\r\n\r\n    try:\r\n        opts.DetailLevel = ViewDetailLevel.Fine\r\n    except:\r\n        pass\r\n\r\n    try:\r\n        opts.View = doc.ActiveView\r\n    except:\r\n        pass\r\n\r\n    segments = []\r\n\r\n    try:\r\n        geom = inst.get_Geometry(opts)\r\n        extract_instance_plan_segments_recursive(geom, Transform.Identity, segments)\r\n    except:\r\n        pass\r\n\r\n    return segments\r\n\r\n\r\ndef filter_door_leaf_candidate_segments(segments, insert_pt, wall_dir, leaf_dir, door_width_ft):\r\n    candidates = []\r\n\r\n    min_len = max(0.4, door_width_ft * 0.20)\r\n    max_len = max(door_width_ft * 1.80, 6.0)\r\n    max_mid_dist = max(door_width_ft * 2.00, 6.0)\r\n\r\n    for p0, p1, typ in segments:\r\n        length = dist2d(p0, p1)\r\n\r\n        if length < min_len or length > max_len:\r\n            continue\r\n\r\n        d = segment_dir_2d(p0, p1)\r\n        if d is None:\r\n            continue\r\n\r\n        mid = segment_midpoint_2d(p0, p1)\r\n        mid_dist = dist2d(mid, insert_pt)\r\n\r\n        if mid_dist > max_mid_dist:\r\n            continue\r\n\r\n        parallel_to_wall = abs(dot2d(d, wall_dir))\r\n        parallel_to_leaf = abs(dot2d(d, leaf_dir))\r\n\r\n        # 门板线更应接近 DoorS->DoorE，而不是墙轴。\r\n        # 允许 0.15 容差，避免族线条有误差。\r\n        if parallel_to_leaf + 0.15 < parallel_to_wall:\r\n            continue\r\n\r\n        candidates.append({\r\n            \"p0\": p0,\r\n            \"p1\": p1,\r\n            \"type\": typ,\r\n            \"length\": length,\r\n            \"mid_dist\": mid_dist,\r\n            \"parallel_to_wall\": parallel_to_wall,\r\n            \"parallel_to_leaf\": parallel_to_leaf\r\n        })\r\n\r\n    return candidates\r\n\r\n\r\ndef score_leaf_segment_against_keypoints(seg_info, hinge_pt, leaf_end_pt, leaf_dir, door_width_ft):\r\n    p0 = seg_info[\"p0\"]\r\n    p1 = seg_info[\"p1\"]\r\n\r\n    d0 = dist2d(p0, hinge_pt)\r\n    d1 = dist2d(p1, hinge_pt)\r\n\r\n    if d0 <= d1:\r\n        hinge_candidate = p0\r\n        end_candidate = p1\r\n        dir_vec = segment_dir_2d(p0, p1)\r\n        hinge_dist = d0\r\n    else:\r\n        hinge_candidate = p1\r\n        end_candidate = p0\r\n        dir_vec = segment_dir_2d(p1, p0)\r\n        hinge_dist = d1\r\n\r\n    if dir_vec is None:\r\n        return -1e9, None\r\n\r\n    dir_score = dot2d(dir_vec, leaf_dir)\r\n    end_dist = dist2d(end_candidate, leaf_end_pt)\r\n\r\n    norm = max(door_width_ft, 1.0)\r\n    hinge_score = 1.0 - clamp(hinge_dist / norm, 0.0, 2.0)\r\n    end_score = 1.0 - clamp(end_dist / norm, 0.0, 2.0)\r\n\r\n    total = dir_score * 10.0 + hinge_score * 3.0 + end_score * 1.5 + seg_info[\"parallel_to_leaf\"] * 1.0\r\n\r\n    dbg = {\r\n        \"segment_type\": seg_info[\"type\"],\r\n        \"segment_p0_xyz\": [p0.X, p0.Y, p0.Z],\r\n        \"segment_p1_xyz\": [p1.X, p1.Y, p1.Z],\r\n        \"segment_length\": seg_info[\"length\"],\r\n        \"segment_mid_dist\": seg_info[\"mid_dist\"],\r\n        \"parallel_to_wall\": seg_info[\"parallel_to_wall\"],\r\n        \"parallel_to_leaf\": seg_info[\"parallel_to_leaf\"],\r\n        \"hinge_candidate_xyz\": [hinge_candidate.X, hinge_candidate.Y, hinge_candidate.Z],\r\n        \"end_candidate_xyz\": [end_candidate.X, end_candidate.Y, end_candidate.Z],\r\n        \"hinge_dist\": hinge_dist,\r\n        \"end_dist\": end_dist,\r\n        \"dir_vec_xyz\": [dir_vec.X, dir_vec.Y, dir_vec.Z],\r\n        \"target_leaf_dir_xyz\": [leaf_dir.X, leaf_dir.Y, leaf_dir.Z],\r\n        \"dir_score_dot\": dir_score,\r\n        \"hinge_score\": hinge_score,\r\n        \"end_score\": end_score,\r\n        \"total_score\": total\r\n    }\r\n\r\n    return total, dbg\r\n\r\n\r\ndef evaluate_door_actual_geometry_state(doc, inst, insert_pt, wall_dir, hinge_pt, leaf_end_pt, leaf_dir, door_width_ft):\r\n    segments = get_instance_plan_segments(doc, inst)\r\n\r\n    candidates = filter_door_leaf_candidate_segments(\r\n        segments,\r\n        insert_pt,\r\n        wall_dir,\r\n        leaf_dir,\r\n        door_width_ft\r\n    )\r\n\r\n    best_score = -1e9\r\n    best_dbg = None\r\n\r\n    for c in candidates:\r\n        score, dbg = score_leaf_segment_against_keypoints(\r\n            c,\r\n            hinge_pt,\r\n            leaf_end_pt,\r\n            leaf_dir,\r\n            door_width_ft\r\n        )\r\n\r\n        if score > best_score:\r\n            best_score = score\r\n            best_dbg = dbg\r\n\r\n    if best_dbg is None:\r\n        best_dbg = {\r\n            \"reason\": \"no_leaf_segment_candidate\",\r\n            \"raw_segment_count\": len(segments),\r\n            \"candidate_count\": len(candidates),\r\n            \"total_score\": -1e9\r\n        }\r\n    else:\r\n        best_dbg[\"raw_segment_count\"] = len(segments)\r\n        best_dbg[\"candidate_count\"] = len(candidates)\r\n\r\n    return best_score, best_dbg\r\n\r\n\r\n# ============================================================\r\n# 门处理：真实几何匹配版\r\n# ============================================================\r\ndef process_door_instance(\r\n    doc,\r\n    level,\r\n    symbol,\r\n    cls_name,\r\n    bbox,\r\n    kp_start_pt,\r\n    kp_end_pt,\r\n    cfg,\r\n    logs,\r\n    debug_tag=\"door\"\r\n):\r\n    x1, y1, x2, y2 = bbox\r\n    cx = (x1 + x2) * 0.5\r\n    cy = (y1 + y2) * 0.5\r\n\r\n    bbox_center_pt = pix_to_revit(cx, cy)\r\n\r\n    max_wall_dist = float(cfg.get(\"door_max_host_wall_dist_ft\", 3.0))\r\n\r\n    host_wall, wall_curve, bbox_proj_pt, wall_dist = get_nearest_wall(\r\n        doc,\r\n        bbox_center_pt,\r\n        max_dist_ft=max_wall_dist\r\n    )\r\n\r\n    if host_wall is None or wall_curve is None or bbox_proj_pt is None:\r\n        raise Exception(\"未找到门宿主墙\")\r\n\r\n    if kp_start_pt is None or kp_end_pt is None:\r\n        raise Exception(\"门缺少关键点，无法放置\")\r\n\r\n    wall_dir = get_wall_direction_unit(wall_curve)\r\n    if wall_dir is None:\r\n        raise Exception(\"墙方向无效\")\r\n\r\n    wall_nrm = get_wall_normal_unit_2d(wall_dir)\r\n    if wall_nrm is None:\r\n        raise Exception(\"墙法向无效\")\r\n\r\n    # 默认：关键点0是铰链端 DoorS，关键点1是门板自由端 DoorE\r\n    hinge_pt = kp_start_pt\r\n    leaf_end_pt = kp_end_pt\r\n\r\n    leaf_dir = xyz_norm2d(xyz_sub(leaf_end_pt, hinge_pt))\r\n    if leaf_dir is None:\r\n        raise Exception(\"门关键点方向无效\")\r\n\r\n    offset_along_ft = float(cfg.get(\"door_insert_offset_along_ft\", 0.0))\r\n    offset_normal_ft = float(cfg.get(\"door_insert_offset_normal_ft\", 0.0))\r\n\r\n    insert_pt = xyz_add(\r\n        xyz_add(bbox_proj_pt, xyz_mul(wall_dir, offset_along_ft)),\r\n        xyz_mul(wall_nrm, offset_normal_ft)\r\n    )\r\n\r\n    door_width_ft = get_symbol_width_ft(symbol)\r\n\r\n    if door_width_ft is None or door_width_ft < 1e-6:\r\n        pt_x1 = pix_to_revit(x1, y1)\r\n        pt_x2 = pix_to_revit(x2, y1)\r\n        pt_y2 = pix_to_revit(x1, y2)\r\n\r\n        bbox_w_ft = abs(pt_x2.X - pt_x1.X)\r\n        bbox_h_ft = abs(pt_y2.Y - pt_x1.Y)\r\n\r\n        door_width_ft = min(max(min(bbox_w_ft, bbox_h_ft), 2.0), 4.0)\r\n        logs.append(\"{} 使用bbox估计门宽: {:.3f} ft\".format(debug_tag, door_width_ft))\r\n    else:\r\n        logs.append(\"{} 读取门族默认宽度: {:.3f} ft\".format(debug_tag, door_width_ft))\r\n\r\n    inst = place_hosted_door_instance(\r\n        doc,\r\n        level,\r\n        symbol,\r\n        host_wall,\r\n        insert_pt\r\n    )\r\n    doc.Regenerate()\r\n\r\n    flip_states = get_candidate_flip_states(inst)\r\n    if len(flip_states) == 0:\r\n        flip_states = [get_flip_state(inst)]\r\n\r\n    best_score = -1e9\r\n    best_state = get_flip_state(inst)\r\n    best_eval_dbg = None\r\n    state_evals = []\r\n\r\n    for target_hand, target_facing in flip_states:\r\n        ok, changed = set_flip_state(inst, target_hand, target_facing)\r\n        doc.Regenerate()\r\n\r\n        if not ok:\r\n            state_evals.append({\r\n                \"tested_state\": {\r\n                    \"target_hand_flipped\": target_hand,\r\n                    \"target_facing_flipped\": target_facing,\r\n                    \"changed_ops\": changed\r\n                },\r\n                \"reason\": \"set_flip_state_failed\"\r\n            })\r\n            continue\r\n\r\n        score, eval_dbg = evaluate_door_actual_geometry_state(\r\n            doc,\r\n            inst,\r\n            insert_pt,\r\n            wall_dir,\r\n            hinge_pt,\r\n            leaf_end_pt,\r\n            leaf_dir,\r\n            door_width_ft\r\n        )\r\n\r\n        eval_dbg[\"tested_state\"] = {\r\n            \"target_hand_flipped\": target_hand,\r\n            \"target_facing_flipped\": target_facing,\r\n            \"changed_ops\": changed\r\n        }\r\n\r\n        try:\r\n            eval_dbg[\"hand_orientation_xyz\"] = [\r\n                inst.HandOrientation.X,\r\n                inst.HandOrientation.Y,\r\n                inst.HandOrientation.Z\r\n            ]\r\n        except:\r\n            eval_dbg[\"hand_orientation_xyz\"] = None\r\n\r\n        try:\r\n            eval_dbg[\"facing_orientation_xyz\"] = [\r\n                inst.FacingOrientation.X,\r\n                inst.FacingOrientation.Y,\r\n                inst.FacingOrientation.Z\r\n            ]\r\n        except:\r\n            eval_dbg[\"facing_orientation_xyz\"] = None\r\n\r\n        try:\r\n            eval_dbg[\"hand_flipped\"] = inst.HandFlipped\r\n        except:\r\n            eval_dbg[\"hand_flipped\"] = None\r\n\r\n        try:\r\n            eval_dbg[\"facing_flipped\"] = inst.FacingFlipped\r\n        except:\r\n            eval_dbg[\"facing_flipped\"] = None\r\n\r\n        state_evals.append(eval_dbg)\r\n\r\n        if score > best_score:\r\n            best_score = score\r\n            best_state = (target_hand, target_facing)\r\n            best_eval_dbg = eval_dbg\r\n\r\n    final_ok, final_changed = set_flip_state(\r\n        inst,\r\n        best_state[0],\r\n        best_state[1]\r\n    )\r\n    doc.Regenerate()\r\n\r\n    return inst, {\r\n        \"host_wall_id\": host_wall.Id.IntegerValue,\r\n        \"wall_dist_ft\": wall_dist,\r\n        \"door_width_ft\": door_width_ft,\r\n        \"bbox_px\": [float(x1), float(y1), float(x2), float(y2)],\r\n        \"bbox_center_xyz\": [bbox_center_pt.X, bbox_center_pt.Y, bbox_center_pt.Z],\r\n        \"bbox_proj_xyz\": [bbox_proj_pt.X, bbox_proj_pt.Y, bbox_proj_pt.Z],\r\n        \"insert_xyz\": [insert_pt.X, insert_pt.Y, insert_pt.Z],\r\n        \"kp_start_xyz\": [kp_start_pt.X, kp_start_pt.Y, kp_start_pt.Z],\r\n        \"kp_end_xyz\": [kp_end_pt.X, kp_end_pt.Y, kp_end_pt.Z],\r\n        \"hinge_pt_xyz\": [hinge_pt.X, hinge_pt.Y, hinge_pt.Z],\r\n        \"leaf_end_pt_xyz\": [leaf_end_pt.X, leaf_end_pt.Y, leaf_end_pt.Z],\r\n        \"leaf_dir_xyz\": [leaf_dir.X, leaf_dir.Y, leaf_dir.Z],\r\n        \"wall_dir_xyz\": [wall_dir.X, wall_dir.Y, wall_dir.Z],\r\n        \"wall_normal_xyz\": [wall_nrm.X, wall_nrm.Y, wall_nrm.Z],\r\n        \"door_insert_offset_along_ft\": offset_along_ft,\r\n        \"door_insert_offset_normal_ft\": offset_normal_ft,\r\n        \"match_method\": \"actual_instance_plan_geometry\",\r\n        \"flip_candidates\": flip_states,\r\n        \"state_evals\": state_evals,\r\n        \"best_state\": {\r\n            \"hand_flipped\": best_state[0],\r\n            \"facing_flipped\": best_state[1],\r\n            \"apply_ok\": final_ok,\r\n            \"apply_changed\": final_changed,\r\n            \"best_score\": best_score\r\n        },\r\n        \"best_eval_debug\": best_eval_dbg\r\n    }\r\n\r\n\r\n# ============================================================\r\n# 读取配置\r\n# ============================================================\r\nCLASS_CONFIG = load_class_config(class_config_json_path, logs)\r\n\r\n\r\n# ============================================================\r\n# 读取 seg_meta\r\n# ============================================================\r\nseg_meta = load_seg_meta(seg_meta_json_path, logs)\r\n\r\nif seg_meta and seg_meta.get(\"ok\", False):\r\n    try:\r\n        bbox_info = seg_meta.get(\"wall_bbox_px\", None)\r\n        scale_info = seg_meta.get(\"scale\", {})\r\n        dbg = seg_meta.get(\"debug\", {})\r\n\r\n        if bbox_info:\r\n            bbox_min_x = bbox_info.get(\"min_x\", None)\r\n            bbox_min_y = bbox_info.get(\"min_y\", None)\r\n            bbox_width = bbox_info.get(\"width\", None)\r\n            bbox_height = bbox_info.get(\"height\", None)\r\n\r\n        scale_x_ft_per_px = scale_info.get(\"scale_x_ft_per_px\", None)\r\n        scale_y_ft_per_px = scale_info.get(\"scale_y_ft_per_px\", None)\r\n\r\n        if \"pixelWidth\" in dbg and \"pixelHeight\" in dbg:\r\n            pixelWidth = dbg.get(\"pixelWidth\", pixelWidth)\r\n            pixelHeight = dbg.get(\"pixelHeight\", pixelHeight)\r\n\r\n        logs.append(\"bbox_info={}\".format(str(bbox_info)))\r\n        logs.append(\"scale_x_ft_per_px={}\".format(str(scale_x_ft_per_px)))\r\n        logs.append(\"scale_y_ft_per_px={}\".format(str(scale_y_ft_per_px)))\r\n        logs.append(\"pixelWidth={}, pixelHeight={}\".format(pixelWidth, pixelHeight))\r\n\r\n    except Exception as e:\r\n        logs.append(\"解析seg_meta失败: {}\".format(str(e)))\r\nelse:\r\n    logs.append(\"seg_meta无效，使用fallback整图scale\")\r\n\r\n\r\n# ============================================================\r\n# YOLO Pose\r\n# ============================================================\r\nyolo_pose = YOLO(pose_Model, task=\"pose\")\r\nnewpath = \"E:/yanjiu/revitss/tests/jjianzhu_pose.jpg\"\r\n\r\npose_results = yolo_pose(\r\n    source=pixpath,\r\n    save=False,\r\n    conf=0.3,\r\n    iou=0.45,\r\n    imgsz=640\r\n)\r\n\r\ncv2.imwrite(newpath, pose_results[0].plot())\r\n\r\nresult = pose_results[0]\r\nboxes = result.boxes.xyxy.cpu().numpy() if result.boxes is not None else []\r\ncls_ids = result.boxes.cls.cpu().numpy().astype(int) if result.boxes is not None else []\r\nconfs = result.boxes.conf.cpu().numpy() if result.boxes is not None else []\r\nnames = result.names\r\n\r\nkps_xy = None\r\nif result.keypoints is not None and result.keypoints.xy is not None:\r\n    kps_xy = result.keypoints.xy.cpu().numpy()\r\n\r\n\r\n# ============================================================\r\n# Revit 文档\r\n# ============================================================\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\nlevel = get_level(doc)\r\nsymbol_lookup = build_symbol_lookup(doc)\r\n\r\nbed_median_area, bed_min_area = compute_class_area_threshold(\r\n    boxes,\r\n    cls_ids,\r\n    names,\r\n    \"Bed\",\r\n    0.33\r\n)\r\n\r\ncreated_instances = []\r\ndebug_info = []\r\nmissing_family_types = []\r\nskipped_unconfigured_classes = []\r\n\r\n\r\n# 预激活符号\r\nfor cls_name, cfg in CLASS_CONFIG.items():\r\n    symbol = get_symbol_from_lookup(\r\n        symbol_lookup,\r\n        cfg.get(\"family_name\"),\r\n        cfg.get(\"type_name\")\r\n    )\r\n    if symbol:\r\n        ensure_symbol_active(doc, symbol)\r\n\r\n\r\n# ============================================================\r\n# 主循环\r\n# ============================================================\r\nfor i, bbox in enumerate(boxes):\r\n    cls_name = names[int(cls_ids[i])] if len(cls_ids) > i else \"\"\r\n    conf = confs[i] if len(confs) > i else 0.0\r\n\r\n    if cls_name not in CLASS_CONFIG:\r\n        skipped_unconfigured_classes.append({\r\n            \"index\": i,\r\n            \"class\": cls_name,\r\n            \"reason\": \"class_not_configured\"\r\n        })\r\n        continue\r\n\r\n    cfg = CLASS_CONFIG[cls_name]\r\n\r\n    family_name = cfg.get(\"family_name\")\r\n    type_name = cfg.get(\"type_name\")\r\n    need_rotate = cfg.get(\"rotate\", False)\r\n    family_default_axis = cfg.get(\"family_default_axis\", \"Y\")\r\n    placement_mode = cfg.get(\"placement_mode\", \"free\")\r\n\r\n    symbol = get_symbol_from_lookup(symbol_lookup, family_name, type_name)\r\n\r\n    if symbol is None:\r\n        missing_family_types.append({\r\n            \"index\": i,\r\n            \"class\": cls_name,\r\n            \"family_name\": family_name,\r\n            \"type_name\": type_name,\r\n            \"reason\": \"family_symbol_not_found\"\r\n        })\r\n        continue\r\n\r\n    x1, y1, x2, y2 = bbox\r\n    cx = (x1 + x2) * 0.5\r\n    cy = (y1 + y2) * 0.5\r\n    center_pt = pix_to_revit(cx, cy)\r\n\r\n    area = max(0, x2 - x1) * max(0, y2 - y1)\r\n\r\n    if cfg.get(\"area_filter\", False):\r\n        if cls_name == \"Bed\" and bed_min_area > 0 and area < bed_min_area:\r\n            debug_info.append({\r\n                \"index\": i,\r\n                \"class\": cls_name,\r\n                \"reason\": \"filtered_small_area\",\r\n                \"area\": float(area),\r\n                \"threshold\": float(bed_min_area)\r\n            })\r\n            continue\r\n\r\n    start_pt = None\r\n    end_pt = None\r\n\r\n    if kps_xy is not None and i < len(kps_xy):\r\n        kp_start_idx = cfg.get(\"kp_start_idx\", None)\r\n        kp_end_idx = cfg.get(\"kp_end_idx\", None)\r\n\r\n        kp = kps_xy[i]\r\n\r\n        if kp_start_idx is not None and kp_end_idx is not None and len(kp) > max(kp_start_idx, kp_end_idx):\r\n            sx, sy = kp[kp_start_idx]\r\n            ex, ey = kp[kp_end_idx]\r\n            start_pt = pix_to_revit(sx, sy)\r\n            end_pt = pix_to_revit(ex, ey)\r\n\r\n    # ------------------------------\r\n    # 门：真实几何匹配\r\n    # ------------------------------\r\n    if placement_mode == \"door_hosted\":\r\n        try:\r\n            inst, door_dbg = process_door_instance(\r\n                doc,\r\n                level,\r\n                symbol,\r\n                cls_name,\r\n                bbox,\r\n                start_pt,\r\n                end_pt,\r\n                cfg,\r\n                logs,\r\n                debug_tag=\"door_{}_{}\".format(i, cls_name)\r\n            )\r\n\r\n            created_instances.append(inst.ToDSType(False))\r\n\r\n            debug_info.append({\r\n                \"index\": i,\r\n                \"class\": cls_name,\r\n                \"family_name\": family_name,\r\n                \"type_name\": type_name,\r\n                \"placement_mode\": \"door_hosted\",\r\n                \"bbox_px\": [float(x1), float(y1), float(x2), float(y2)],\r\n                \"area\": float(area),\r\n                \"conf\": float(conf),\r\n                \"door_debug\": door_dbg\r\n            })\r\n\r\n        except Exception as e:\r\n            debug_info.append({\r\n                \"index\": i,\r\n                \"class\": cls_name,\r\n                \"placement_mode\": \"door_hosted\",\r\n                \"reason\": \"door_place_failed\",\r\n                \"error\": str(e),\r\n                \"bbox_px\": [float(x1), float(y1), float(x2), float(y2)],\r\n                \"kp_start_xyz\": [start_pt.X, start_pt.Y, start_pt.Z] if start_pt else None,\r\n                \"kp_end_xyz\": [end_pt.X, end_pt.Y, end_pt.Z] if end_pt else None\r\n            })\r\n\r\n        continue\r\n\r\n    # ------------------------------\r\n    # 普通自由族\r\n    # ------------------------------\r\n    try:\r\n        instance = create_family_instance(doc, center_pt, symbol, level)\r\n    except Exception as e:\r\n        debug_info.append({\r\n            \"index\": i,\r\n            \"class\": cls_name,\r\n            \"reason\": \"create_instance_failed\",\r\n            \"error\": str(e)\r\n        })\r\n        continue\r\n\r\n    rotated = False\r\n    angle = None\r\n\r\n    if need_rotate:\r\n        if start_pt is not None and end_pt is not None:\r\n            angle = get_angle_from_keypoints(start_pt, end_pt, family_default_axis)\r\n\r\n            if angle is not None:\r\n                try:\r\n                    rotate_instance(doc, instance, center_pt, angle)\r\n                    rotated = True\r\n                except Exception as e:\r\n                    debug_info.append({\r\n                        \"index\": i,\r\n                        \"class\": cls_name,\r\n                        \"reason\": \"rotate_failed\",\r\n                        \"error\": str(e)\r\n                    })\r\n            else:\r\n                debug_info.append({\r\n                    \"index\": i,\r\n                    \"class\": cls_name,\r\n                    \"reason\": \"zero_direction_vector\"\r\n                })\r\n        else:\r\n            debug_info.append({\r\n                \"index\": i,\r\n                \"class\": cls_name,\r\n                \"reason\": \"no_keypoints_for_rotation\"\r\n            })\r\n\r\n    created_instances.append(instance.ToDSType(False))\r\n\r\n    debug_info.append({\r\n        \"index\": i,\r\n        \"class\": cls_name,\r\n        \"family_name\": family_name,\r\n        \"type_name\": type_name,\r\n        \"placement_mode\": \"free\",\r\n        \"center_xyz\": [center_pt.X, center_pt.Y, center_pt.Z],\r\n        \"bbox_px\": [float(x1), float(y1), float(x2), float(y2)],\r\n        \"area\": float(area),\r\n        \"rotated\": rotated,\r\n        \"angle_rad\": angle,\r\n        \"angle_deg\": angle * 180.0 / math.pi if angle is not None else None,\r\n        \"conf\": float(conf),\r\n        \"kp_start_xyz\": [start_pt.X, start_pt.Y, start_pt.Z] if start_pt else None,\r\n        \"kp_end_xyz\": [end_pt.X, end_pt.Y, end_pt.Z] if end_pt else None\r\n    })\r\n\r\n\r\n# ============================================================\r\n# 提交\r\n# ============================================================\r\nTransactionManager.Instance.TransactionTaskDone()\r\ndoc.Regenerate()\r\n\r\n\r\nOUT = {\r\n    \"preview_image\": newpath,\r\n    \"created_instances\": created_instances,\r\n    \"debug_info\": debug_info,\r\n    \"missing_family_types\": missing_family_types,\r\n    \"skipped_unconfigured_classes\": skipped_unconfigured_classes,\r\n    \"bed_area_threshold\": {\r\n        \"median_area\": bed_median_area,\r\n        \"min_area\": bed_min_area\r\n    },\r\n    \"seg_meta_json_path\": seg_meta_json_path,\r\n    \"class_config_json_path\": class_config_json_path,\r\n    \"logs\": logs\r\n}\r\n",
      "Engine": "CPython3",

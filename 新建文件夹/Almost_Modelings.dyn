    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# 加载 PythonStandard 和 DesignScript 库\r\n#-----------------------------\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\nimport Autodesk.DesignScript.Geometry as DS\r\nimport Revit\r\nfrom Revit.Elements import *\r\nimport System\r\nsys.path.append(\"C:/Users/Lenovo/anaconda3/envs/revitenv/Lib/site-packages\")\r\nclr.AddReference('RevitAPI')\r\nclr.AddReference('RevitAPIUI')\r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.UI import *\r\n\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\nclr.AddReference('RevitNodes')\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\n\r\nimport re\r\nimport json\r\nimport os\r\nimport numpy as np\r\nimport torch\r\nimport cv2\r\nfrom ultralytics import YOLO\r\n\r\ndataEnteringNode = IN \r\n\r\n# =========================\r\n# 输入\r\n# =========================\r\ndect_Model = IN[0]\r\npixpath = IN[1]\r\nscale = IN[2]              # fallback\r\nseg_meta_json_path = IN[3] # 读取分割得到的缩放与bbox信息\r\n\r\n# =========================\r\n# 参数\r\n# =========================\r\norigin = XYZ(0, 0, 0)   \r\nwidthFt = scale\r\npixelWidth = 1600   \r\npixelHeight = 1200\r\n\r\nnewpath = \"E:/yanjiu/revitss/tests/jjianzhu_dect.jpg\"\r\n\r\n# fallback比例\r\nscaleX = widthFt / pixelWidth if pixelWidth > 0 else 0.0\r\nscaleY = widthFt * (pixelHeight / pixelWidth) / pixelHeight if pixelWidth > 0 and pixelHeight > 0 else 0.0\r\n\r\n# seg_meta读取到的参数\r\nbbox_info = None\r\nbbox_min_x = None\r\nbbox_min_y = None\r\nbbox_width = None\r\nbbox_height = None\r\nscale_x_ft_per_px = None\r\nscale_y_ft_per_px = None\r\n\r\nlogs = []\r\n\r\n# =========================\r\n# 窗参数\r\n# =========================\r\nTARGET_WINDOW_FAMILY_NAME = \"Window_test\"   # 窗族名\r\nTARGET_WINDOW_CLASS_NAME = \"window\"         # 检测类别名，统一转小写判断\r\n\r\nDEFAULT_WINDOW_HEIGHT_MM = 1500.0           # 固定窗高\r\nDEFAULT_SILL_HEIGHT_MM = 900.0              # 底高度\r\nWINDOW_SHRINK_EACH_SIDE_MM = 120.0          # 每端向内收120mm\r\nMIN_WINDOW_WIDTH_MM = 300.0                 # 最小窗宽，避免过小\r\n\r\n# =========================\r\n# 双开门参数\r\n# =========================\r\nTARGET_DOOR_FAMILY_NAME = \"TwoSideDoor\"     # 双开门族名\r\nTARGET_DOOR_CLASS_NAME = \"twosidedoor\"      # 检测bbox类别名，代码里统一lower，所以这里写小写\r\n\r\nDOOR_SHRINK_EACH_SIDE_MM = 100.0            # 双开门两边各向内收100mm左右\r\nMIN_DOOR_WIDTH_MM = 500.0                   # 最小门宽，避免过小\r\n\r\nMM_TO_FT = 1.0 / 304.8\r\n\r\n# =========================\r\n# 工具函数\r\n# =========================\r\ndef sanitize_name(name):\r\n    if not name:\r\n        return \"Unknown\"\r\n    cleaned = re.sub(r'[\\x00-\\x1f\\x7f]', '', str(name))\r\n    if not cleaned.strip():\r\n        return \"Unnamed\"\r\n    return cleaned\r\n\r\ndef mm_to_ft(mm):\r\n    return float(mm) * MM_TO_FT\r\n\r\ndef load_seg_meta(seg_meta_json_path, logs):\r\n    if seg_meta_json_path is None:\r\n        logs.append(\"seg_meta_json_path为空\")\r\n        return None\r\n\r\n    try:\r\n        with open(seg_meta_json_path, \"r\", encoding=\"utf-8\") as f:\r\n            data = json.load(f)\r\n        logs.append(\"读取seg_meta_json成功: {}\".format(seg_meta_json_path))\r\n        return data\r\n    except Exception as e:\r\n        logs.append(\"读取seg_meta_json失败: {}\".format(str(e)))\r\n        return None\r\n\r\ndef pix_to_revit(x, y):\r\n    global bbox_min_x, bbox_min_y, bbox_width, bbox_height\r\n    global scale_x_ft_per_px, scale_y_ft_per_px\r\n    global origin, scaleX, scaleY, pixelHeight\r\n\r\n    try:\r\n        if bbox_min_x is not None and bbox_min_y is not None and bbox_height is not None \\\r\n           and scale_x_ft_per_px is not None and scale_y_ft_per_px is not None:\r\n\r\n            local_x = x - bbox_min_x\r\n            local_y = y - bbox_min_y\r\n\r\n            revit_x = origin.X + local_x * scale_x_ft_per_px\r\n            revit_y = origin.Y + (bbox_height - local_y) * scale_y_ft_per_px\r\n            return XYZ(revit_x, revit_y, origin.Z)\r\n    except:\r\n        pass\r\n\r\n    revit_x = origin.X + x * scaleX\r\n    revit_y = origin.Y + (pixelHeight - y) * scaleY\r\n    return XYZ(revit_x, revit_y, origin.Z)\r\n\r\ndef get_px_to_ft_x():\r\n    global scale_x_ft_per_px, scaleX\r\n    return scale_x_ft_per_px if scale_x_ft_per_px is not None else scaleX\r\n\r\ndef get_px_to_ft_y():\r\n    global scale_y_ft_per_px, scaleY\r\n    return scale_y_ft_per_px if scale_y_ft_per_px is not None else scaleY\r\n\r\ndef get_wall_curve(wall):\r\n    try:\r\n        loc = wall.Location\r\n        if loc and hasattr(loc, \"Curve\"):\r\n            return loc.Curve\r\n    except:\r\n        pass\r\n    return None\r\n\r\ndef point_to_curve_distance_2d(pt, curve):\r\n    try:\r\n        proj = curve.Project(pt)\r\n        if proj:\r\n            q = proj.XYZPoint\r\n            dx = pt.X - q.X\r\n            dy = pt.Y - q.Y\r\n            return (dx * dx + dy * dy) ** 0.5, q\r\n    except:\r\n        pass\r\n    return None, None\r\n\r\ndef get_wall_orientation(curve):\r\n    p0 = curve.GetEndPoint(0)\r\n    p1 = curve.GetEndPoint(1)\r\n    dx = abs(p1.X - p0.X)\r\n    dy = abs(p1.Y - p0.Y)\r\n    if dx >= dy:\r\n        return \"h\"\r\n    else:\r\n        return \"v\"\r\n\r\ndef get_nearest_wall(doc, pt, max_dist_ft=3.0):\r\n    nearest_wall = None\r\n    nearest_curve = None\r\n    nearest_proj_pt = None\r\n    best_dist = 1e18\r\n\r\n    walls = FilteredElementCollector(doc).OfClass(Wall).ToElements()\r\n    for wall in walls:\r\n        try:\r\n            curve = get_wall_curve(wall)\r\n            if curve is None:\r\n                continue\r\n\r\n            dist, proj_pt = point_to_curve_distance_2d(pt, curve)\r\n            if dist is None:\r\n                continue\r\n\r\n            if dist < best_dist and dist <= max_dist_ft:\r\n                best_dist = dist\r\n                nearest_wall = wall\r\n                nearest_curve = curve\r\n                nearest_proj_pt = proj_pt\r\n\r\n        except:\r\n            continue\r\n\r\n    return nearest_wall, nearest_curve, nearest_proj_pt, best_dist\r\n\r\ndef get_window_symbol(doc, family_name):\r\n    collector = FilteredElementCollector(doc).OfClass(FamilySymbol).OfCategory(BuiltInCategory.OST_Windows)\r\n    for sym in collector:\r\n        try:\r\n            fam = sym.Family\r\n            if fam and fam.Name == family_name:\r\n                return sym\r\n        except:\r\n            continue\r\n    return None\r\n\r\ndef get_door_symbol(doc, family_name):\r\n    collector = FilteredElementCollector(doc).OfClass(FamilySymbol).OfCategory(BuiltInCategory.OST_Doors)\r\n    for sym in collector:\r\n        try:\r\n            fam = sym.Family\r\n            if fam and fam.Name == family_name:\r\n                return sym\r\n        except:\r\n            continue\r\n    return None\r\n\r\ndef set_param_if_exists(elem, param_name, value, logs, label):\r\n    try:\r\n        p = elem.LookupParameter(param_name)\r\n        if p and (not p.IsReadOnly):\r\n            p.Set(value)\r\n            logs.append(\"{} 参数设置成功: {}={:.4f}\".format(label, param_name, value))\r\n            return True\r\n        else:\r\n            logs.append(\"{} 参数不存在或只读: {}\".format(label, param_name))\r\n    except Exception as e:\r\n        logs.append(\"{} 参数设置失败: {} -> {}\".format(label, param_name, str(e)))\r\n    return False\r\n\r\ndef create_debug_bbox(doc, sketch_plane, pt1, pt2, pt3, pt4):\r\n    lines = [\r\n        Line.CreateBound(pt1, pt2),\r\n        Line.CreateBound(pt2, pt3),\r\n        Line.CreateBound(pt3, pt4),\r\n        Line.CreateBound(pt4, pt1)\r\n    ]\r\n    created = []\r\n    for line in lines:\r\n        try:\r\n            mc = doc.Create.NewModelCurve(line, sketch_plane)\r\n            created.append(mc)\r\n        except:\r\n            pass\r\n    return created\r\n\r\ndef calc_bbox_length_along_wall_mm(x1, y1, x2, y2, wall_ori):\r\n    \"\"\"\r\n    根据墙方向计算检测框沿墙方向的真实长度，单位mm。\r\n    h墙：取bbox水平像素宽度\r\n    v墙：取bbox竖向像素高度\r\n    \"\"\"\r\n    bbox_w_px = abs(x2 - x1)\r\n    bbox_h_px = abs(y2 - y1)\r\n\r\n    if wall_ori == \"h\":\r\n        raw_width_ft = bbox_w_px * get_px_to_ft_x()\r\n    else:\r\n        raw_width_ft = bbox_h_px * get_px_to_ft_y()\r\n\r\n    return raw_width_ft * 304.8\r\n\r\n# =========================\r\n# 读取seg_meta\r\n# =========================\r\nseg_meta = load_seg_meta(seg_meta_json_path, logs)\r\n\r\nif seg_meta and seg_meta.get(\"ok\", False):\r\n    try:\r\n        bbox_info = seg_meta.get(\"wall_bbox_px\", None)\r\n        scale_info = seg_meta.get(\"scale\", {})\r\n\r\n        if bbox_info:\r\n            bbox_min_x = bbox_info.get(\"min_x\", None)\r\n            bbox_min_y = bbox_info.get(\"min_y\", None)\r\n            bbox_width = bbox_info.get(\"width\", None)\r\n            bbox_height = bbox_info.get(\"height\", None)\r\n\r\n        scale_x_ft_per_px = scale_info.get(\"scale_x_ft_per_px\", None)\r\n        scale_y_ft_per_px = scale_info.get(\"scale_y_ft_per_px\", None)\r\n\r\n        dbg = seg_meta.get(\"debug\", {})\r\n        if \"pixelWidth\" in dbg and \"pixelHeight\" in dbg:\r\n            pixelWidth = dbg.get(\"pixelWidth\", pixelWidth)\r\n            pixelHeight = dbg.get(\"pixelHeight\", pixelHeight)\r\n\r\n        logs.append(\"bbox_info={}\".format(str(bbox_info)))\r\n        logs.append(\"scale_x_ft_per_px={}\".format(str(scale_x_ft_per_px)))\r\n        logs.append(\"scale_y_ft_per_px={}\".format(str(scale_y_ft_per_px)))\r\n        logs.append(\"pixelWidth={}, pixelHeight={}\".format(pixelWidth, pixelHeight))\r\n    except Exception as e:\r\n        logs.append(\"解析seg_meta失败: {}\".format(str(e)))\r\nelse:\r\n    logs.append(\"seg_meta无效，使用fallback整图scale\")\r\n\r\n# =========================\r\n# 运行YOLO检测\r\n# =========================\r\nyolo_dect = YOLO(dect_Model, task=\"detect\")\r\ndect_result = yolo_dect(source=pixpath, save=False, conf=0.3, iou=0.45, imgsz=640)\r\ncv2.imwrite(newpath, dect_result[0].plot())\r\n\r\nresult = dect_result[0]\r\nboxes = result.boxes\r\nxyxy = boxes.xyxy.cpu().numpy() if boxes is not None else np.empty((0, 4))\r\ncls_ids = boxes.cls.cpu().numpy().astype(int) if boxes is not None else np.array([], dtype=int)\r\nnames = result.names\r\n\r\nlogs.append(\"检测框数量: {}\".format(len(xyxy)))\r\nlogs.append(\"类别映射: {}\".format(str(names)))\r\n\r\n# =========================\r\n# Revit文档对象\r\n# =========================\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\napp = doc.Application\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\ncreated_lines = []\r\ncreated_windows = []\r\ncreated_doors = []\r\n\r\nplane = Plane.CreateByNormalAndOrigin(XYZ.BasisZ, origin)\r\nsketch_plane = SketchPlane.Create(doc, plane)\r\n\r\n# =========================\r\n# 查找窗族类型\r\n# =========================\r\nwindow_symbol = get_window_symbol(doc, TARGET_WINDOW_FAMILY_NAME)\r\nif window_symbol is None:\r\n    logs.append(\"未找到窗族类型: {}\".format(TARGET_WINDOW_FAMILY_NAME))\r\nelse:\r\n    logs.append(\"找到窗族类型: {}\".format(TARGET_WINDOW_FAMILY_NAME))\r\n    try:\r\n        if not window_symbol.IsActive:\r\n            window_symbol.Activate()\r\n            doc.Regenerate()\r\n            logs.append(\"窗族类型已激活\")\r\n    except Exception as e:\r\n        logs.append(\"窗族类型激活失败: {}\".format(str(e)))\r\n\r\n# =========================\r\n# 查找双开门族类型\r\n# =========================\r\ndoor_symbol = get_door_symbol(doc, TARGET_DOOR_FAMILY_NAME)\r\nif door_symbol is None:\r\n    logs.append(\"未找到双开门族类型: {}\".format(TARGET_DOOR_FAMILY_NAME))\r\nelse:\r\n    logs.append(\"找到双开门族类型: {}\".format(TARGET_DOOR_FAMILY_NAME))\r\n    try:\r\n        if not door_symbol.IsActive:\r\n            door_symbol.Activate()\r\n            doc.Regenerate()\r\n            logs.append(\"双开门族类型已激活\")\r\n    except Exception as e:\r\n        logs.append(\"双开门族类型激活失败: {}\".format(str(e)))\r\n\r\n# 取一个Level，供创建窗/门实例使用\r\nlevel = FilteredElementCollector(doc).OfClass(Level).FirstElement()\r\nif level is None:\r\n    logs.append(\"未找到Level，无法创建窗或门实例\")\r\n\r\n# =========================\r\n# 遍历检测结果\r\n# =========================\r\nfor i, bbox in enumerate(xyxy):\r\n    try:\r\n        x1, y1, x2, y2 = bbox\r\n        class_id = cls_ids[i]\r\n        class_name = sanitize_name(names[class_id]).lower()\r\n\r\n        # 可选：先画debug框\r\n        pt1 = pix_to_revit(x1, y1)\r\n        pt2 = pix_to_revit(x2, y1)\r\n        pt3 = pix_to_revit(x2, y2)\r\n        pt4 = pix_to_revit(x1, y2)\r\n        dbg_lines = create_debug_bbox(doc, sketch_plane, pt1, pt2, pt3, pt4)\r\n        created_lines.extend(dbg_lines)\r\n\r\n        # 只处理 window 和 TwoSideDoor\r\n        if class_name != TARGET_WINDOW_CLASS_NAME and class_name != TARGET_DOOR_CLASS_NAME:\r\n            logs.append(\"检测项{}跳过: class={}\".format(i, class_name))\r\n            continue\r\n\r\n        if level is None:\r\n            logs.append(\"检测项{}跳过: 缺少Level\".format(i))\r\n            continue\r\n\r\n        # 中心点\r\n        cx = 0.5 * (x1 + x2)\r\n        cy = 0.5 * (y1 + y2)\r\n        center_pt = pix_to_revit(cx, cy)\r\n\r\n        # 找最近墙\r\n        host_wall, wall_curve, proj_pt, wall_dist = get_nearest_wall(doc, center_pt, max_dist_ft=3.0)\r\n        if host_wall is None or wall_curve is None or proj_pt is None:\r\n            logs.append(\"检测项{}失败: 未找到合适宿主墙\".format(i))\r\n            continue\r\n\r\n        wall_ori = get_wall_orientation(wall_curve)\r\n\r\n        # 插入点优先用投影点\r\n        insert_pt = XYZ(proj_pt.X, proj_pt.Y, proj_pt.Z)\r\n\r\n        # =========================\r\n        # 处理窗\r\n        # =========================\r\n        if class_name == TARGET_WINDOW_CLASS_NAME:\r\n\r\n            if window_symbol is None:\r\n                logs.append(\"检测项{}跳过: 缺少窗族类型\".format(i))\r\n                continue\r\n\r\n            raw_width_mm = calc_bbox_length_along_wall_mm(x1, y1, x2, y2, wall_ori)\r\n\r\n            # 两端向内收\r\n            final_width_mm = raw_width_mm - 2.0 * WINDOW_SHRINK_EACH_SIDE_MM\r\n            final_width_mm = max(final_width_mm, MIN_WINDOW_WIDTH_MM)\r\n\r\n            final_width_ft = mm_to_ft(final_width_mm)\r\n            final_height_ft = mm_to_ft(DEFAULT_WINDOW_HEIGHT_MM)\r\n            sill_height_ft = mm_to_ft(DEFAULT_SILL_HEIGHT_MM)\r\n\r\n            # 创建窗实例\r\n            try:\r\n                win = doc.Create.NewFamilyInstance(\r\n                    insert_pt,\r\n                    window_symbol,\r\n                    host_wall,\r\n                    level,\r\n                    StructuralType.NonStructural\r\n                )\r\n            except:\r\n                # 有些版本/族可能只接受不带level的重载\r\n                win = doc.Create.NewFamilyInstance(\r\n                    insert_pt,\r\n                    window_symbol,\r\n                    host_wall,\r\n                    StructuralType.NonStructural\r\n                )\r\n\r\n            doc.Regenerate()\r\n\r\n            # 设置窗参数\r\n            set_param_if_exists(win, \"AI_Width\", final_width_ft, logs, \"窗{}\".format(i))\r\n            set_param_if_exists(win, \"AI_Height\", final_height_ft, logs, \"窗{}\".format(i))\r\n            set_param_if_exists(win, \"底高度\", sill_height_ft, logs, \"窗{}\".format(i))\r\n\r\n            created_windows.append(win.ToDSType(True))\r\n\r\n            logs.append(\r\n                \"窗{}创建成功: class={}, wall_ori={}, raw_width_mm={:.1f}, final_width_mm={:.1f}, height_mm={:.1f}, sill_mm={:.1f}\".format(\r\n                    i,\r\n                    class_name,\r\n                    wall_ori,\r\n                    raw_width_mm,\r\n                    final_width_mm,\r\n                    DEFAULT_WINDOW_HEIGHT_MM,\r\n                    DEFAULT_SILL_HEIGHT_MM\r\n                )\r\n            )\r\n\r\n        # =========================\r\n        # 处理双开门 TwoSideDoor\r\n        # =========================\r\n        elif class_name == TARGET_DOOR_CLASS_NAME:\r\n\r\n            if door_symbol is None:\r\n                logs.append(\"检测项{}跳过: 缺少双开门族类型\".format(i))\r\n                continue\r\n\r\n            raw_width_mm = calc_bbox_length_along_wall_mm(x1, y1, x2, y2, wall_ori)\r\n\r\n            # 双开门宽度：bbox沿墙方向长度，两边各内收100mm左右\r\n            final_door_width_mm = raw_width_mm - 2.0 * DOOR_SHRINK_EACH_SIDE_MM\r\n            final_door_width_mm = max(final_door_width_mm, MIN_DOOR_WIDTH_MM)\r\n\r\n            final_door_width_ft = mm_to_ft(final_door_width_mm)\r\n\r\n            # 创建双开门实例\r\n            try:\r\n                door = doc.Create.NewFamilyInstance(\r\n                    insert_pt,\r\n                    door_symbol,\r\n                    host_wall,\r\n                    level,\r\n                    StructuralType.NonStructural\r\n                )\r\n            except:\r\n                door = doc.Create.NewFamilyInstance(\r\n                    insert_pt,\r\n                    door_symbol,\r\n                    host_wall,\r\n                    StructuralType.NonStructural\r\n                )\r\n\r\n            doc.Regenerate()\r\n\r\n            # 只设置AI_Width，AI_Height保持族默认值\r\n            set_param_if_exists(door, \"AI_Width\", final_door_width_ft, logs, \"双开门{}\".format(i))\r\n\r\n            created_doors.append(door.ToDSType(True))\r\n\r\n            logs.append(\r\n                \"双开门{}创建成功: class={}, wall_ori={}, raw_width_mm={:.1f}, final_width_mm={:.1f}, AI_Height保持默认\".format(\r\n                    i,\r\n                    class_name,\r\n                    wall_ori,\r\n                    raw_width_mm,\r\n                    final_door_width_mm\r\n                )\r\n            )\r\n\r\n    except Exception as e:\r\n        logs.append(\"检测项{}处理失败: {}\".format(i, str(e)))\r\n        continue\r\n\r\n# =========================\r\n# 提交事务\r\n# =========================\r\nTransactionManager.Instance.TransactionTaskDone()\r\ndoc.Regenerate()\r\n\r\n# =========================\r\n# 输出\r\n# =========================\r\nOUT = newpath, created_windows, created_doors, created_lines, logs\r\n",
      "Engine": "CPython3",

    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# -*- coding: utf-8 -*-\r\n\r\n# ============================================================\r\n# Revit + Dynamo Python Node\r\n#\r\n# 基于姿态估计结果绘制：\r\n#   1. 家具姿态方向图\r\n#   2. 单开门宿主墙候选筛选图（第九张）\r\n#   3. 单开门最终放置示意图（第十张）\r\n#\r\n# 输出：\r\n#   08_furniture_pose_direction.png\r\n#   09_singledoor_host_wall_selection.png\r\n#   10_singledoor_final_placement.png\r\n#\r\n# 输入：\r\n#   IN[0] = pose YOLO model path 或模型对象\r\n#   IN[1] = 原始图片路径\r\n#   IN[2] = 06_wall_thickness_semantic_bars.png 路径，可选\r\n#   IN[3] = seg_meta.json 路径，可选\r\n#   IN[4] = class_config.json 路径，可选\r\n#   IN[5] = fallback_scale，可选，默认 1.0\r\n#   IN[6] = conf，可选，默认 0.3\r\n#   IN[7] = iou，可选，默认 0.45\r\n#   IN[8] = imgsz，可选，默认 1280\r\n# ============================================================\r\n\r\nimport os\r\nimport json\r\nimport math\r\nimport traceback\r\n\r\nimport cv2\r\nimport numpy as np\r\n\r\ntry:\r\n    from ultralytics import YOLO\r\nexcept Exception:\r\n    YOLO = None\r\n\r\n\r\n# ============================================================\r\n# Revit / Dynamo\r\n# ============================================================\r\n\r\ntry:\r\n    import clr\r\n\r\n    clr.AddReference(\"RevitServices\")\r\n    from RevitServices.Persistence import DocumentManager\r\n\r\n    clr.AddReference(\"RevitAPI\")\r\n    from Autodesk.Revit.DB import FilteredElementCollector, Wall, XYZ\r\n\r\n    doc = DocumentManager.Instance.CurrentDBDocument\r\n\r\nexcept Exception:\r\n    doc = None\r\n\r\n\r\n# ============================================================\r\n# 日志\r\n# ============================================================\r\n\r\nlogs = []\r\nlogs.append(\"=== 当前运行的是姿态估计家具与单开门可视化节点 V2 ===\")\r\n\r\n\r\n# ============================================================\r\n# 输入\r\n# ============================================================\r\n\r\ntry:\r\n    pose_Model = IN[0]\r\nexcept:\r\n    pose_Model = None\r\n\r\ntry:\r\n    pixpath = str(IN[1]).strip()\r\nexcept:\r\n    pixpath = \"\"\r\n\r\ntry:\r\n    wall_mask_img_path = str(IN[2]).strip()\r\nexcept:\r\n    wall_mask_img_path = \"\"\r\n\r\ntry:\r\n    seg_meta_json_path = str(IN[3]).strip()\r\nexcept:\r\n    seg_meta_json_path = \"\"\r\n\r\ntry:\r\n    class_config_json_path = str(IN[4]).strip()\r\nexcept:\r\n    class_config_json_path = \"\"\r\n\r\ntry:\r\n    fallback_scale = float(IN[5])\r\nexcept:\r\n    fallback_scale = 1.0\r\n\r\ntry:\r\n    YOLO_CONF = float(IN[6])\r\nexcept:\r\n    YOLO_CONF = 0.3\r\n\r\ntry:\r\n    YOLO_IOU = float(IN[7])\r\nexcept:\r\n    YOLO_IOU = 0.45\r\n\r\ntry:\r\n    YOLO_IMGSZ = int(IN[8])\r\nexcept:\r\n    YOLO_IMGSZ = 1280\r\n\r\n\r\n# ============================================================\r\n# 默认配置\r\n# ============================================================\r\n\r\nOUTPUT_FOLDER_NAME = \"structure_mask_process\"\r\n\r\nDEFAULT_CLASS_CONFIG = {\r\n    \"Bed\": {\r\n        \"family_name\": \"Bed\",\r\n        \"type_name\": \"Bed\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": True,\r\n        \"family_default_axis\": \"Y\",\r\n        \"placement_mode\": \"free\"\r\n    },\r\n    \"BedSingle\": {\r\n        \"family_name\": \"BedSingle\",\r\n        \"type_name\": \"BedSingle\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\",\r\n        \"placement_mode\": \"free\"\r\n    },\r\n    \"CookingCounter\": {\r\n        \"family_name\": \"CookingCounter\",\r\n        \"type_name\": \"CookingCounter\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\",\r\n        \"placement_mode\": \"free\"\r\n    },\r\n    \"Cabinet\": {\r\n        \"family_name\": \"Cabinet\",\r\n        \"type_name\": \"Cabinet\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\",\r\n        \"placement_mode\": \"free\"\r\n    },\r\n    \"DiningTable\": {\r\n        \"family_name\": \"DiningTable\",\r\n        \"type_name\": \"DiningTable\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\",\r\n        \"placement_mode\": \"free\"\r\n    },\r\n    \"DiningTables\": {\r\n        \"family_name\": \"DiningTables\",\r\n        \"type_name\": \"DiningTables\",\r\n        \"rotate\": False,\r\n        \"area_filter\": False,\r\n        \"placement_mode\": \"free\"\r\n    },\r\n    \"Sofa\": {\r\n        \"family_name\": \"Sofa\",\r\n        \"type_name\": \"Sofa\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\",\r\n        \"placement_mode\": \"free\"\r\n    },\r\n    \"TVStand\": {\r\n        \"family_name\": \"TVStand\",\r\n        \"type_name\": \"TVStand\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\",\r\n        \"placement_mode\": \"free\"\r\n    },\r\n    \"Toilet\": {\r\n        \"family_name\": \"Toilet\",\r\n        \"type_name\": \"Toilet\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\",\r\n        \"placement_mode\": \"free\"\r\n    },\r\n    \"LeftDoor\": {\r\n        \"family_name\": \"LeftDoor\",\r\n        \"type_name\": \"LeftDoor\",\r\n        \"rotate\": False,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"placement_mode\": \"door_hosted\",\r\n        \"door_max_host_wall_dist_ft\": 4.0,\r\n        \"door_min_perp_score\": 0.35,\r\n        \"door_min_end_clearance_ft\": 0.45,\r\n        \"door_end_clearance_ratio\": 0.25,\r\n        \"door_insert_reference\": \"bbox_center\",\r\n        \"door_insert_offset_along_ft\": 0.0,\r\n        \"door_insert_offset_normal_ft\": 0.0,\r\n        \"door_try_candidate_count\": 8,\r\n        \"door_geometry_match\": True\r\n    },\r\n    \"RightDoor\": {\r\n        \"family_name\": \"RightDoor\",\r\n        \"type_name\": \"RightDoor\",\r\n        \"rotate\": False,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"placement_mode\": \"door_hosted\",\r\n        \"door_max_host_wall_dist_ft\": 4.0,\r\n        \"door_min_perp_score\": 0.35,\r\n        \"door_min_end_clearance_ft\": 0.45,\r\n        \"door_end_clearance_ratio\": 0.25,\r\n        \"door_insert_reference\": \"bbox_center\",\r\n        \"door_insert_offset_along_ft\": 0.0,\r\n        \"door_insert_offset_normal_ft\": 0.0,\r\n        \"door_try_candidate_count\": 8,\r\n        \"door_geometry_match\": True\r\n    }\r\n}\r\n\r\n\r\n# ============================================================\r\n# 绘图参数\r\n# ============================================================\r\n\r\nFURNITURE_POSE_ARROW_THICKNESS = 8\r\nFURNITURE_DEFAULT_ARROW_THICKNESS = 10\r\nFURNITURE_ARROW_TIP_LENGTH = 0.25\r\nFURNITURE_BBOX_THICKNESS = 2\r\n\r\nDOOR_BBOX_THICKNESS = 2\r\nDOOR_KP_RADIUS = 7\r\nDOOR_CENTER_RADIUS = 8\r\nDOOR_PROJECT_RADIUS = 13\r\nDOOR_PROJECT_RING_RADIUS = 18\r\n\r\n# 第九张：门扇姿态箭头略细\r\nDOOR_LEAF_ARROW_THICKNESS_HOST = 5\r\n\r\n# 第十张：最终放置门扇色条更粗\r\nDOOR_FINAL_FRAME_THICKNESS = 4\r\nDOOR_FINAL_LEAF_THICKNESS = 12\r\nDOOR_FINAL_INSERT_RADIUS = 11\r\n\r\nHOST_WALL_MARKER_RADIUS = 8\r\nHOST_WALL_MARKER_INTERVAL_PX = 34\r\nHOST_WALL_MARKER_ALPHA = 0.18\r\nHOST_WALL_MARKER_ALPHA_BEST = 0.30\r\n\r\nTEXT_SCALE = 0.65\r\nTEXT_THICKNESS = 2\r\n\r\nAREA_FILTER_RATIO = 0.33\r\n\r\nCOLOR_PALETTE = [\r\n    (0, 255, 0),\r\n    (255, 0, 255),\r\n    (0, 165, 255),\r\n    (255, 0, 0),\r\n    (128, 0, 255),\r\n    (0, 255, 255),\r\n    (255, 128, 0),\r\n    (80, 255, 120),\r\n    (180, 80, 255),\r\n    (255, 80, 80),\r\n    (60, 180, 255),\r\n    (200, 255, 80),\r\n]\r\n\r\n\r\n# ============================================================\r\n# 基础工具\r\n# ============================================================\r\n\r\ndef ensure_dir(folder):\r\n    if folder and not os.path.exists(folder):\r\n        os.makedirs(folder)\r\n\r\n\r\ndef save_image(path, img):\r\n    ensure_dir(os.path.dirname(path))\r\n    ok = cv2.imwrite(path, img)\r\n    if not ok:\r\n        raise Exception(\"cv2.imwrite 保存失败: {}\".format(path))\r\n    logs.append(\"已保存图像: {}\".format(path))\r\n\r\n\r\ndef norm_str(s):\r\n    if s is None:\r\n        return \"\"\r\n    return str(s).strip().lower()\r\n\r\n\r\ndef load_json_multi_encoding(path, label):\r\n    if not path:\r\n        logs.append(\"{}为空\".format(label))\r\n        return None\r\n\r\n    if not os.path.exists(path):\r\n        logs.append(\"{}不存在: {}\".format(label, path))\r\n        return None\r\n\r\n    encodings = [\"utf-8\", \"utf-8-sig\", \"gbk\"]\r\n    last_err = None\r\n\r\n    for enc in encodings:\r\n        try:\r\n            with open(path, \"r\", encoding=enc) as f:\r\n                data = json.load(f)\r\n            logs.append(\"读取{}成功: {} encoding={}\".format(label, path, enc))\r\n            return data\r\n        except Exception as e:\r\n            last_err = e\r\n\r\n    logs.append(\"读取{}失败: {}\".format(label, str(last_err)))\r\n    return None\r\n\r\n\r\ndef load_class_config(path):\r\n    data = load_json_multi_encoding(path, \"class_config_json_path\")\r\n\r\n    if isinstance(data, dict) and len(data) > 0:\r\n        logs.append(\"使用外部 CLASS_CONFIG，共{}类\".format(len(data)))\r\n        return data\r\n\r\n    logs.append(\"使用内置 DEFAULT_CLASS_CONFIG，共{}类\".format(len(DEFAULT_CLASS_CONFIG)))\r\n    return DEFAULT_CLASS_CONFIG\r\n\r\n\r\ndef get_model(model_input):\r\n    if model_input is None:\r\n        raise Exception(\"IN[0]为空，请输入姿态估计模型对象或模型路径。\")\r\n\r\n    if not isinstance(model_input, str):\r\n        if hasattr(model_input, \"predict\") or hasattr(model_input, \"__call__\"):\r\n            logs.append(\"检测到 IN[0] 为已加载模型对象，直接使用。\")\r\n            return model_input\r\n\r\n    model_path = str(model_input).strip()\r\n\r\n    if not model_path:\r\n        raise Exception(\"模型路径为空。\")\r\n\r\n    if not os.path.exists(model_path):\r\n        raise Exception(\"模型路径不存在: {}\".format(model_path))\r\n\r\n    if YOLO is None:\r\n        raise Exception(\"无法导入 ultralytics.YOLO，请检查 Python 环境。\")\r\n\r\n    logs.append(\"开始加载 YOLO 姿态模型: {}\".format(model_path))\r\n    model = YOLO(model_path)\r\n    logs.append(\"YOLO 姿态模型加载完成。\")\r\n\r\n    return model\r\n\r\n\r\ndef safe_get_class_name(names, cls_id):\r\n    try:\r\n        if isinstance(names, dict):\r\n            return names.get(int(cls_id), str(cls_id))\r\n        return names[int(cls_id)]\r\n    except:\r\n        return str(cls_id)\r\n\r\n\r\ndef clip_point(pt, w, h):\r\n    x, y = pt\r\n    x = int(round(x))\r\n    y = int(round(y))\r\n    x = max(0, min(w - 1, x))\r\n    y = max(0, min(h - 1, y))\r\n    return (x, y)\r\n\r\n\r\ndef darker_color(color, factor=0.55):\r\n    b, g, r = color\r\n    return (\r\n        int(max(0, min(255, b * factor))),\r\n        int(max(0, min(255, g * factor))),\r\n        int(max(0, min(255, r * factor)))\r\n    )\r\n\r\n\r\ndef draw_text_with_outline(img, text, pos, color, scale=0.65):\r\n    x, y = pos\r\n\r\n    cv2.putText(\r\n        img,\r\n        text,\r\n        (int(x), int(y)),\r\n        cv2.FONT_HERSHEY_SIMPLEX,\r\n        scale,\r\n        (0, 0, 0),\r\n        TEXT_THICKNESS + 2,\r\n        cv2.LINE_AA\r\n    )\r\n\r\n    cv2.putText(\r\n        img,\r\n        text,\r\n        (int(x), int(y)),\r\n        cv2.FONT_HERSHEY_SIMPLEX,\r\n        scale,\r\n        color,\r\n        TEXT_THICKNESS,\r\n        cv2.LINE_AA\r\n    )\r\n\r\n\r\ndef draw_transparent_arrow(img, p1, p2, color, thickness=8, alpha=0.35, tip_length=0.25):\r\n    overlay = img.copy()\r\n\r\n    cv2.arrowedLine(\r\n        overlay,\r\n        p1,\r\n        p2,\r\n        color,\r\n        thickness=thickness,\r\n        line_type=cv2.LINE_AA,\r\n        tipLength=tip_length\r\n    )\r\n\r\n    out = cv2.addWeighted(overlay, alpha, img, 1.0 - alpha, 0)\r\n    img[:, :, :] = out[:, :, :]\r\n\r\n\r\ndef draw_transparent_wall_markers(img, p1, p2, color, alpha=0.25, radius=8):\r\n    h, w = img.shape[:2]\r\n\r\n    p1 = clip_point(p1, w, h)\r\n    p2 = clip_point(p2, w, h)\r\n\r\n    x1, y1 = p1\r\n    x2, y2 = p2\r\n    dx = x2 - x1\r\n    dy = y2 - y1\r\n\r\n    length = math.sqrt(dx * dx + dy * dy)\r\n    if length < 1:\r\n        return img\r\n\r\n    count = max(2, int(length / float(HOST_WALL_MARKER_INTERVAL_PX)))\r\n    overlay = img.copy()\r\n\r\n    for i in range(count + 1):\r\n        t = i / float(count)\r\n        x = int(round(x1 + dx * t))\r\n        y = int(round(y1 + dy * t))\r\n        cv2.circle(overlay, (x, y), radius, color, -1, cv2.LINE_AA)\r\n\r\n    out = cv2.addWeighted(overlay, alpha, img, 1.0 - alpha, 0)\r\n    return out\r\n\r\n\r\n# ============================================================\r\n# 坐标映射\r\n# ============================================================\r\n\r\nclass PixelRevitMapper(object):\r\n    def __init__(self, image_width, image_height, fallback_width_ft, seg_meta):\r\n        self.image_width = int(image_width)\r\n        self.image_height = int(image_height)\r\n\r\n        self.origin_x = 0.0\r\n        self.origin_y = 0.0\r\n        self.origin_z = 0.0\r\n\r\n        self.bbox_min_x = None\r\n        self.bbox_min_y = None\r\n        self.bbox_width = None\r\n        self.bbox_height = None\r\n\r\n        self.scale_x_ft_per_px = None\r\n        self.scale_y_ft_per_px = None\r\n\r\n        self.use_bbox_mapping = False\r\n\r\n        if self.image_width > 0:\r\n            self.fallback_scale_x = float(fallback_width_ft) / float(self.image_width)\r\n        else:\r\n            self.fallback_scale_x = 1.0\r\n\r\n        self.fallback_scale_y = self.fallback_scale_x\r\n\r\n        if isinstance(seg_meta, dict):\r\n            self.load_from_seg_meta(seg_meta)\r\n\r\n        if self.scale_x_ft_per_px is None:\r\n            self.scale_x_ft_per_px = self.fallback_scale_x\r\n\r\n        if self.scale_y_ft_per_px is None:\r\n            self.scale_y_ft_per_px = self.fallback_scale_y\r\n\r\n        logs.append(\"坐标映射 use_bbox_mapping={}\".format(self.use_bbox_mapping))\r\n        logs.append(\"bbox_min_x={}, bbox_min_y={}, bbox_width={}, bbox_height={}\".format(\r\n            self.bbox_min_x,\r\n            self.bbox_min_y,\r\n            self.bbox_width,\r\n            self.bbox_height\r\n        ))\r\n        logs.append(\"scale_x_ft_per_px={}, scale_y_ft_per_px={}\".format(\r\n            self.scale_x_ft_per_px,\r\n            self.scale_y_ft_per_px\r\n        ))\r\n\r\n    def load_from_seg_meta(self, meta):\r\n        try:\r\n            bbox = meta.get(\"wall_bbox_px\", None)\r\n            if bbox is None:\r\n                bbox = meta.get(\"bbox\", None)\r\n\r\n            if isinstance(bbox, dict):\r\n                min_x = bbox.get(\"min_x\", bbox.get(\"x_min\", None))\r\n                min_y = bbox.get(\"min_y\", bbox.get(\"y_min\", None))\r\n                width = bbox.get(\"width\", None)\r\n                height = bbox.get(\"height\", None)\r\n\r\n                if width is None:\r\n                    max_x = bbox.get(\"max_x\", bbox.get(\"x_max\", None))\r\n                    if max_x is not None and min_x is not None:\r\n                        width = float(max_x) - float(min_x)\r\n\r\n                if height is None:\r\n                    max_y = bbox.get(\"max_y\", bbox.get(\"y_max\", None))\r\n                    if max_y is not None and min_y is not None:\r\n                        height = float(max_y) - float(min_y)\r\n\r\n                if min_x is not None and min_y is not None and width is not None and height is not None:\r\n                    self.bbox_min_x = float(min_x)\r\n                    self.bbox_min_y = float(min_y)\r\n                    self.bbox_width = float(width)\r\n                    self.bbox_height = float(height)\r\n                    self.use_bbox_mapping = True\r\n\r\n            scale_info = meta.get(\"scale\", {})\r\n            sx = scale_info.get(\"scale_x_ft_per_px\", None)\r\n            sy = scale_info.get(\"scale_y_ft_per_px\", None)\r\n\r\n            if sx is None:\r\n                sx = meta.get(\"scale_x_ft_per_px\", None)\r\n            if sy is None:\r\n                sy = meta.get(\"scale_y_ft_per_px\", None)\r\n\r\n            if sx is not None:\r\n                self.scale_x_ft_per_px = float(sx)\r\n            if sy is not None:\r\n                self.scale_y_ft_per_px = float(sy)\r\n\r\n            dbg = meta.get(\"debug\", {})\r\n            if \"pixelWidth\" in dbg:\r\n                self.image_width = int(dbg.get(\"pixelWidth\"))\r\n            if \"pixelHeight\" in dbg:\r\n                self.image_height = int(dbg.get(\"pixelHeight\"))\r\n\r\n        except Exception as e:\r\n            logs.append(\"解析 seg_meta 失败，将使用 fallback 映射: {}\".format(str(e)))\r\n\r\n    def pix_to_revit(self, x, y):\r\n        x = float(x)\r\n        y = float(y)\r\n\r\n        if self.use_bbox_mapping and self.bbox_min_x is not None and self.bbox_min_y is not None and self.bbox_height is not None:\r\n            local_x = x - self.bbox_min_x\r\n            local_y = y - self.bbox_min_y\r\n\r\n            revit_x = self.origin_x + local_x * self.scale_x_ft_per_px\r\n            revit_y = self.origin_y + (self.bbox_height - local_y) * self.scale_y_ft_per_px\r\n            return XYZ(revit_x, revit_y, self.origin_z)\r\n\r\n        revit_x = self.origin_x + x * self.scale_x_ft_per_px\r\n        revit_y = self.origin_y + (self.image_height - y) * self.scale_y_ft_per_px\r\n        return XYZ(revit_x, revit_y, self.origin_z)\r\n\r\n    def revit_to_pix(self, pt):\r\n        if self.use_bbox_mapping and self.bbox_min_x is not None and self.bbox_min_y is not None and self.bbox_height is not None:\r\n            local_x = (pt.X - self.origin_x) / self.scale_x_ft_per_px\r\n            local_y_from_bottom = (pt.Y - self.origin_y) / self.scale_y_ft_per_px\r\n            local_y = self.bbox_height - local_y_from_bottom\r\n\r\n            x = self.bbox_min_x + local_x\r\n            y = self.bbox_min_y + local_y\r\n            return (float(x), float(y))\r\n\r\n        x = (pt.X - self.origin_x) / self.scale_x_ft_per_px\r\n        y = self.image_height - (pt.Y - self.origin_y) / self.scale_y_ft_per_px\r\n        return (float(x), float(y))\r\n\r\n\r\n# ============================================================\r\n# Revit 墙体几何工具\r\n# ============================================================\r\n\r\ndef xyz_sub(a, b):\r\n    return XYZ(a.X - b.X, a.Y - b.Y, a.Z - b.Z)\r\n\r\n\r\ndef xyz_add(a, b):\r\n    return XYZ(a.X + b.X, a.Y + b.Y, a.Z + b.Z)\r\n\r\n\r\ndef xyz_mul(v, s):\r\n    return XYZ(v.X * s, v.Y * s, v.Z * s)\r\n\r\n\r\ndef xyz_len2d(v):\r\n    return math.sqrt(v.X * v.X + v.Y * v.Y)\r\n\r\n\r\ndef xyz_norm2d(v):\r\n    l = xyz_len2d(v)\r\n    if l < 1e-9:\r\n        return None\r\n    return XYZ(v.X / l, v.Y / l, 0)\r\n\r\n\r\ndef dot2d(a, b):\r\n    return a.X * b.X + a.Y * b.Y\r\n\r\n\r\ndef dist2d(a, b):\r\n    dx = a.X - b.X\r\n    dy = a.Y - b.Y\r\n    return math.sqrt(dx * dx + dy * dy)\r\n\r\n\r\ndef clamp(v, a, b):\r\n    return max(a, min(b, v))\r\n\r\n\r\ndef get_wall_curve(wall):\r\n    try:\r\n        loc = wall.Location\r\n        if loc and hasattr(loc, \"Curve\"):\r\n            return loc.Curve\r\n    except:\r\n        pass\r\n    return None\r\n\r\n\r\ndef get_wall_direction_unit(curve):\r\n    try:\r\n        p0 = curve.GetEndPoint(0)\r\n        p1 = curve.GetEndPoint(1)\r\n        return xyz_norm2d(xyz_sub(p1, p0))\r\n    except:\r\n        return None\r\n\r\n\r\ndef get_wall_normal_unit_2d(wall_dir):\r\n    if wall_dir is None:\r\n        return None\r\n    return XYZ(-wall_dir.Y, wall_dir.X, 0)\r\n\r\n\r\ndef point_to_line_segment_projection_2d(pt, p0, p1):\r\n    vx = p1.X - p0.X\r\n    vy = p1.Y - p0.Y\r\n    wx = pt.X - p0.X\r\n    wy = pt.Y - p0.Y\r\n\r\n    vv = vx * vx + vy * vy\r\n    if vv < 1e-12:\r\n        return {\r\n            \"proj\": XYZ(p0.X, p0.Y, pt.Z),\r\n            \"dist\": dist2d(pt, p0),\r\n            \"t_raw\": 0.0,\r\n            \"t\": 0.0,\r\n            \"inside\": False,\r\n            \"length\": 0.0,\r\n            \"end_clearance\": 0.0\r\n        }\r\n\r\n    t_raw = (wx * vx + wy * vy) / vv\r\n    t = clamp(t_raw, 0.0, 1.0)\r\n    proj = XYZ(p0.X + t * vx, p0.Y + t * vy, pt.Z)\r\n\r\n    length = math.sqrt(vv)\r\n    inside = t_raw >= -0.02 and t_raw <= 1.02\r\n\r\n    if inside:\r\n        end_clearance = min(t * length, (1.0 - t) * length)\r\n    else:\r\n        end_clearance = -min(abs(t_raw), abs(t_raw - 1.0)) * length\r\n\r\n    return {\r\n        \"proj\": proj,\r\n        \"dist\": dist2d(pt, proj),\r\n        \"t_raw\": t_raw,\r\n        \"t\": t,\r\n        \"inside\": inside,\r\n        \"length\": length,\r\n        \"end_clearance\": end_clearance\r\n    }\r\n\r\n\r\ndef get_all_walls(doc):\r\n    if doc is None:\r\n        return []\r\n    try:\r\n        return list(FilteredElementCollector(doc).OfClass(Wall).ToElements())\r\n    except Exception:\r\n        return []\r\n\r\n\r\n# ============================================================\r\n# 姿态结果解析\r\n# ============================================================\r\n\r\ndef get_pose_keypoints_xy(result):\r\n    try:\r\n        if result.keypoints is None:\r\n            return None\r\n\r\n        if hasattr(result.keypoints, \"xy\") and result.keypoints.xy is not None:\r\n            return result.keypoints.xy.cpu().numpy()\r\n\r\n        if hasattr(result.keypoints, \"data\") and result.keypoints.data is not None:\r\n            data = result.keypoints.data.cpu().numpy()\r\n            return data[:, :, :2]\r\n    except:\r\n        return None\r\n\r\n    return None\r\n\r\n\r\ndef run_pose_inference(model, image_path):\r\n    logs.append(\"开始 YOLO Pose 推理...\")\r\n    logs.append(\"YOLO_IMGSZ={}, YOLO_CONF={}, YOLO_IOU={}\".format(\r\n        YOLO_IMGSZ, YOLO_CONF, YOLO_IOU\r\n    ))\r\n\r\n    results = model(\r\n        source=image_path,\r\n        save=False,\r\n        conf=YOLO_CONF,\r\n        iou=YOLO_IOU,\r\n        imgsz=YOLO_IMGSZ,\r\n        verbose=False\r\n    )\r\n\r\n    if results is None or len(results) == 0:\r\n        raise Exception(\"姿态估计模型没有返回结果。\")\r\n\r\n    result = results[0]\r\n\r\n    if result.boxes is None:\r\n        return [], {}\r\n\r\n    boxes = result.boxes\r\n    xyxy = boxes.xyxy.cpu().numpy() if boxes.xyxy is not None else np.empty((0, 4))\r\n    cls_ids = boxes.cls.cpu().numpy().astype(int) if boxes.cls is not None else np.array([], dtype=int)\r\n    confs = boxes.conf.cpu().numpy() if boxes.conf is not None else np.ones((len(xyxy),), dtype=np.float32)\r\n\r\n    names = result.names\r\n    kps_xy = get_pose_keypoints_xy(result)\r\n\r\n    instances = []\r\n\r\n    for i, bbox in enumerate(xyxy):\r\n        try:\r\n            cls_id = int(cls_ids[i])\r\n            class_name = safe_get_class_name(names, cls_id)\r\n\r\n            x1, y1, x2, y2 = bbox.tolist()\r\n            cx = 0.5 * (x1 + x2)\r\n            cy = 0.5 * (y1 + y2)\r\n\r\n            if kps_xy is not None and i < len(kps_xy):\r\n                keypoints = kps_xy[i]\r\n            else:\r\n                keypoints = np.empty((0, 2), dtype=np.float32)\r\n\r\n            instances.append({\r\n                \"index\": i,\r\n                \"class_name\": str(class_name),\r\n                \"conf\": float(confs[i]),\r\n                \"bbox\": [float(x1), float(y1), float(x2), float(y2)],\r\n                \"center_pix\": [float(cx), float(cy)],\r\n                \"keypoints\": keypoints\r\n            })\r\n        except Exception as e:\r\n            logs.append(\"解析姿态实例失败 idx={}: {}\".format(i, str(e)))\r\n\r\n    logs.append(\"姿态估计实例数量: {}\".format(len(instances)))\r\n    logs.append(\"类别映射: {}\".format(str(names)))\r\n\r\n    return instances, names\r\n\r\n\r\ndef get_kp_pair(instance, cfg):\r\n    kps = instance.get(\"keypoints\", None)\r\n\r\n    if kps is None or len(kps) == 0:\r\n        return None, None\r\n\r\n    ks = int(cfg.get(\"kp_start_idx\", 0))\r\n    ke = int(cfg.get(\"kp_end_idx\", 1))\r\n\r\n    if ks < 0 or ke < 0 or ks >= len(kps) or ke >= len(kps):\r\n        return None, None\r\n\r\n    p1 = kps[ks]\r\n    p2 = kps[ke]\r\n\r\n    if p1 is None or p2 is None:\r\n        return None, None\r\n\r\n    x1, y1 = float(p1[0]), float(p1[1])\r\n    x2, y2 = float(p2[0]), float(p2[1])\r\n\r\n    if abs(x1) < 1e-6 and abs(y1) < 1e-6:\r\n        return None, None\r\n    if abs(x2) < 1e-6 and abs(y2) < 1e-6:\r\n        return None, None\r\n    if math.hypot(x2 - x1, y2 - y1) < 2.0:\r\n        return None, None\r\n\r\n    return (x1, y1), (x2, y2)\r\n\r\n\r\ndef compute_class_area_threshold(instances, class_name):\r\n    areas = []\r\n\r\n    for ins in instances:\r\n        if ins.get(\"class_name\", \"\") != class_name:\r\n            continue\r\n\r\n        x1, y1, x2, y2 = ins[\"bbox\"]\r\n        area = max(0.0, x2 - x1) * max(0.0, y2 - y1)\r\n\r\n        if area > 0:\r\n            areas.append(area)\r\n\r\n    if not areas:\r\n        return 0.0, 0.0\r\n\r\n    median_area = float(np.median(np.array(areas, dtype=np.float32)))\r\n    threshold = median_area * AREA_FILTER_RATIO\r\n    return median_area, threshold\r\n\r\n\r\n# ============================================================\r\n# 单开门宿主墙评分\r\n# ============================================================\r\n\r\ndef remap_dist_score(dist, max_dist):\r\n    if max_dist <= 1e-9:\r\n        return 0.0\r\n    return clamp(1.0 - dist / max_dist, 0.0, 1.0)\r\n\r\n\r\ndef build_door_candidates(instance, cfg, mapper, walls):\r\n    kp_start, kp_end = get_kp_pair(instance, cfg)\r\n    if kp_start is None or kp_end is None:\r\n        return []\r\n\r\n    sx, sy = kp_start\r\n    ex, ey = kp_end\r\n\r\n    cx, cy = instance[\"center_pix\"]\r\n\r\n    Qs = mapper.pix_to_revit(sx, sy)\r\n    Qe = mapper.pix_to_revit(ex, ey)\r\n    Qb = mapper.pix_to_revit(cx, cy)\r\n\r\n    leaf_vec = xyz_sub(Qe, Qs)\r\n    leaf_dir = xyz_norm2d(leaf_vec)\r\n    if leaf_dir is None:\r\n        return []\r\n\r\n    max_dist = float(cfg.get(\"door_max_host_wall_dist_ft\", 4.0))\r\n    min_perp_score = float(cfg.get(\"door_min_perp_score\", 0.35))\r\n    min_end_clearance = float(cfg.get(\"door_min_end_clearance_ft\", 0.45))\r\n    end_clearance_ratio = float(cfg.get(\"door_end_clearance_ratio\", 0.25))\r\n\r\n    insert_ref = str(cfg.get(\"door_insert_reference\", \"bbox_center\")).strip().lower()\r\n    offset_along = float(cfg.get(\"door_insert_offset_along_ft\", 0.0))\r\n    offset_normal = float(cfg.get(\"door_insert_offset_normal_ft\", 0.0))\r\n\r\n    if insert_ref in [\"kp_start\", \"start\", \"hinge\", \"s\"]:\r\n        Qref = Qs\r\n    elif insert_ref in [\"leaf_mid\", \"kp_mid\", \"mid\"]:\r\n        Qref = XYZ((Qs.X + Qe.X) * 0.5, (Qs.Y + Qe.Y) * 0.5, Qs.Z)\r\n    else:\r\n        Qref = Qb\r\n\r\n    candidates = []\r\n\r\n    for wall in walls:\r\n        try:\r\n            curve = get_wall_curve(wall)\r\n            if curve is None:\r\n                continue\r\n\r\n            p0 = curve.GetEndPoint(0)\r\n            p1 = curve.GetEndPoint(1)\r\n\r\n            wall_dir = get_wall_direction_unit(curve)\r\n            if wall_dir is None:\r\n                continue\r\n\r\n            wall_normal = get_wall_normal_unit_2d(wall_dir)\r\n\r\n            proj_ref = point_to_line_segment_projection_2d(Qref, p0, p1)\r\n            proj_s = point_to_line_segment_projection_2d(Qs, p0, p1)\r\n            proj_b = point_to_line_segment_projection_2d(Qb, p0, p1)\r\n\r\n            if not proj_ref[\"inside\"]:\r\n                continue\r\n\r\n            wall_len = proj_ref[\"length\"]\r\n            if wall_len < 1e-6:\r\n                continue\r\n\r\n            required_clearance = max(min_end_clearance, wall_len * end_clearance_ratio * 0.05)\r\n            if proj_ref[\"end_clearance\"] < required_clearance:\r\n                continue\r\n\r\n            dist_ref = proj_ref[\"dist\"]\r\n            dist_s = proj_s[\"dist\"]\r\n            dist_b = proj_b[\"dist\"]\r\n\r\n            if min(dist_ref, dist_s, dist_b) > max_dist:\r\n                continue\r\n\r\n            perp_score = 1.0 - abs(dot2d(wall_dir, leaf_dir))\r\n            if perp_score < min_perp_score:\r\n                continue\r\n\r\n            d_s_score = remap_dist_score(dist_s, max_dist)\r\n            d_b_score = remap_dist_score(dist_b, max_dist)\r\n            d_ref_score = remap_dist_score(dist_ref, max_dist)\r\n            end_score = clamp(proj_ref[\"end_clearance\"] / max(min_end_clearance, 1e-6), 0.0, 1.0)\r\n\r\n            score = (\r\n                0.30 * d_s_score +\r\n                0.20 * d_b_score +\r\n                0.20 * d_ref_score +\r\n                0.25 * perp_score +\r\n                0.05 * end_score\r\n            )\r\n\r\n            insert_pt = proj_ref[\"proj\"]\r\n\r\n            if offset_along != 0.0:\r\n                insert_pt = xyz_add(insert_pt, xyz_mul(wall_dir, offset_along))\r\n\r\n            if offset_normal != 0.0 and wall_normal is not None:\r\n                insert_pt = xyz_add(insert_pt, xyz_mul(wall_normal, offset_normal))\r\n\r\n            candidates.append({\r\n                \"wall\": wall,\r\n                \"curve\": curve,\r\n                \"insert_pt\": insert_pt,\r\n                \"proj_ref\": proj_ref,\r\n                \"proj_s\": proj_s,\r\n                \"proj_b\": proj_b,\r\n                \"wall_dir\": wall_dir,\r\n                \"wall_normal\": wall_normal,\r\n                \"leaf_dir\": leaf_dir,\r\n                \"score\": score,\r\n                \"dist_ref\": dist_ref,\r\n                \"dist_s\": dist_s,\r\n                \"dist_b\": dist_b,\r\n                \"perp_score\": perp_score,\r\n                \"end_score\": end_score,\r\n                \"t\": proj_ref[\"t\"],\r\n                \"wall_len\": wall_len\r\n            })\r\n        except Exception:\r\n            continue\r\n\r\n    candidates.sort(key=lambda c: c[\"score\"], reverse=True)\r\n    try_count = int(cfg.get(\"door_try_candidate_count\", 8))\r\n    candidates = candidates[:max(1, try_count)]\r\n\r\n    return candidates\r\n\r\n\r\n# ============================================================\r\n# 绘制家具图\r\n# ============================================================\r\n\r\ndef draw_furniture_direction_image(base_img, furniture_items):\r\n    img = base_img.copy()\r\n    h, w = img.shape[:2]\r\n\r\n    for idx, item in enumerate(furniture_items):\r\n        color = COLOR_PALETTE[idx % len(COLOR_PALETTE)]\r\n        muted = darker_color(color, 0.55)\r\n\r\n        x1, y1, x2, y2 = item[\"bbox\"]\r\n        p_box1 = clip_point((x1, y1), w, h)\r\n        p_box2 = clip_point((x2, y2), w, h)\r\n\r\n        cv2.rectangle(img, p_box1, p_box2, color, FURNITURE_BBOX_THICKNESS, cv2.LINE_AA)\r\n\r\n        bx = 0.5 * (x1 + x2)\r\n        by_bottom = y2 - 0.18 * (y2 - y1)\r\n        by_top = y1 + 0.18 * (y2 - y1)\r\n\r\n        p_default_start = clip_point((bx, by_bottom), w, h)\r\n        p_default_end = clip_point((bx, by_top), w, h)\r\n\r\n        draw_transparent_arrow(\r\n            img,\r\n            p_default_start,\r\n            p_default_end,\r\n            muted,\r\n            thickness=FURNITURE_DEFAULT_ARROW_THICKNESS,\r\n            alpha=0.32,\r\n            tip_length=0.22\r\n        )\r\n\r\n        kp_start = item[\"kp_start\"]\r\n        kp_end = item[\"kp_end\"]\r\n\r\n        p_pose_start = clip_point(kp_start, w, h)\r\n        p_pose_end = clip_point(kp_end, w, h)\r\n\r\n        cv2.circle(img, p_pose_start, 7, color, -1, cv2.LINE_AA)\r\n        cv2.circle(img, p_pose_end, 7, (255, 255, 255), -1, cv2.LINE_AA)\r\n        cv2.circle(img, p_pose_end, 4, color, -1, cv2.LINE_AA)\r\n\r\n        cv2.arrowedLine(\r\n            img,\r\n            p_pose_start,\r\n            p_pose_end,\r\n            color,\r\n            thickness=FURNITURE_POSE_ARROW_THICKNESS,\r\n            line_type=cv2.LINE_AA,\r\n            tipLength=FURNITURE_ARROW_TIP_LENGTH\r\n        )\r\n\r\n        label = \"{}{}\".format(item[\"class_name\"], idx + 1)\r\n        tx = max(5, min(w - 200, int(x1)))\r\n        ty = max(22, min(h - 5, int(y1) - 8))\r\n        draw_text_with_outline(img, label, (tx, ty), color, scale=0.55)\r\n\r\n    return img\r\n\r\n\r\n# ============================================================\r\n# 绘制单开门宿主墙候选筛选图（第九张）\r\n# ============================================================\r\n\r\ndef draw_door_host_selection_image(base_img, door_items):\r\n    img = base_img.copy()\r\n    h, w = img.shape[:2]\r\n\r\n    # 先画候选宿主墙集合：同一个门实例使用同一种颜色\r\n    # 所有 candidates 都画成同色半透明点串；best 额外更明显一些\r\n    for idx, item in enumerate(door_items):\r\n        color = COLOR_PALETTE[idx % len(COLOR_PALETTE)]\r\n\r\n        candidate_walls = item.get(\"candidate_walls_pix\", [])\r\n        best_wall = item.get(\"best_wall_pix\", None)\r\n\r\n        for cw in candidate_walls:\r\n            img = draw_transparent_wall_markers(\r\n                img,\r\n                cw[\"p0\"],\r\n                cw[\"p1\"],\r\n                color,\r\n                alpha=HOST_WALL_MARKER_ALPHA,\r\n                radius=HOST_WALL_MARKER_RADIUS\r\n            )\r\n\r\n        if best_wall is not None:\r\n            img = draw_transparent_wall_markers(\r\n                img,\r\n                best_wall[\"p0\"],\r\n                best_wall[\"p1\"],\r\n                color,\r\n                alpha=HOST_WALL_MARKER_ALPHA_BEST,\r\n                radius=HOST_WALL_MARKER_RADIUS + 1\r\n            )\r\n\r\n    # 再画门本体信息\r\n    for idx, item in enumerate(door_items):\r\n        color = COLOR_PALETTE[idx % len(COLOR_PALETTE)]\r\n\r\n        x1, y1, x2, y2 = item[\"bbox\"]\r\n        p1 = clip_point((x1, y1), w, h)\r\n        p2 = clip_point((x2, y2), w, h)\r\n\r\n        cv2.rectangle(img, p1, p2, color, DOOR_BBOX_THICKNESS, cv2.LINE_AA)\r\n\r\n        center = clip_point(item[\"center_pix\"], w, h)\r\n        kp_s = clip_point(item[\"kp_start\"], w, h)\r\n        kp_e = clip_point(item[\"kp_end\"], w, h)\r\n        proj = clip_point(item[\"insert_pix\"], w, h)\r\n\r\n        cv2.circle(img, center, DOOR_CENTER_RADIUS + 3, (255, 255, 255), -1, cv2.LINE_AA)\r\n        cv2.circle(img, center, DOOR_CENTER_RADIUS, color, -1, cv2.LINE_AA)\r\n\r\n        cv2.circle(img, kp_s, DOOR_KP_RADIUS + 3, (0, 0, 0), -1, cv2.LINE_AA)\r\n        cv2.circle(img, kp_s, DOOR_KP_RADIUS, color, -1, cv2.LINE_AA)\r\n\r\n        cv2.circle(img, kp_e, DOOR_KP_RADIUS + 3, (255, 255, 255), -1, cv2.LINE_AA)\r\n        cv2.circle(img, kp_e, DOOR_KP_RADIUS, color, -1, cv2.LINE_AA)\r\n\r\n        # 第九张：更细一些的姿态箭头\r\n        cv2.arrowedLine(\r\n            img,\r\n            kp_s,\r\n            kp_e,\r\n            color,\r\n            thickness=DOOR_LEAF_ARROW_THICKNESS_HOST,\r\n            line_type=cv2.LINE_AA,\r\n            tipLength=0.23\r\n        )\r\n\r\n        cv2.line(img, center, proj, color, thickness=3, lineType=cv2.LINE_AA)\r\n\r\n        cv2.circle(img, proj, DOOR_PROJECT_RING_RADIUS, color, 4, cv2.LINE_AA)\r\n        cv2.circle(img, proj, DOOR_PROJECT_RADIUS, color, -1, cv2.LINE_AA)\r\n        cv2.circle(img, proj, 5, (255, 255, 255), -1, cv2.LINE_AA)\r\n\r\n        label = \"{}{}  cand={}  best={:.2f}\".format(\r\n            \"LD\" if item[\"class_name\"] == \"LeftDoor\" else \"RD\",\r\n            idx + 1,\r\n            len(item.get(\"candidate_walls_pix\", [])),\r\n            item.get(\"host_score\", 0.0)\r\n        )\r\n\r\n        tx = max(5, min(w - 260, proj[0] + 12))\r\n        ty = max(22, min(h - 5, proj[1] - 12))\r\n        draw_text_with_outline(img, label, (tx, ty), color, scale=0.58)\r\n\r\n    return img\r\n\r\n\r\n# ============================================================\r\n# 绘制单开门最终放置示意图（第十张）\r\n# 不再保留候选宿主墙半透明点\r\n# ============================================================\r\n\r\ndef draw_door_final_placement_image(base_img, door_items):\r\n    img = base_img.copy()\r\n    h, w = img.shape[:2]\r\n\r\n    for idx, item in enumerate(door_items):\r\n        color = COLOR_PALETTE[idx % len(COLOR_PALETTE)]\r\n\r\n        x1, y1, x2, y2 = item[\"bbox\"]\r\n        p_box1 = clip_point((x1, y1), w, h)\r\n        p_box2 = clip_point((x2, y2), w, h)\r\n\r\n        cv2.rectangle(img, p_box1, p_box2, color, DOOR_FINAL_FRAME_THICKNESS, cv2.LINE_AA)\r\n\r\n        insert_pt = clip_point(item[\"insert_pix\"], w, h)\r\n\r\n        cv2.circle(img, insert_pt, DOOR_FINAL_INSERT_RADIUS + 4, (255, 255, 255), -1, cv2.LINE_AA)\r\n        cv2.circle(img, insert_pt, DOOR_FINAL_INSERT_RADIUS, color, -1, cv2.LINE_AA)\r\n\r\n        sx, sy = item[\"kp_start\"]\r\n        ex, ey = item[\"kp_end\"]\r\n\r\n        vx = ex - sx\r\n        vy = ey - sy\r\n        length = math.sqrt(vx * vx + vy * vy)\r\n\r\n        if length < 1.0:\r\n            continue\r\n\r\n        ux = vx / length\r\n        uy = vy / length\r\n\r\n        box_w = abs(x2 - x1)\r\n        box_h = abs(y2 - y1)\r\n        leaf_len = min(max(length, min(box_w, box_h) * 0.55), max(box_w, box_h) * 1.05)\r\n\r\n        start_x = insert_pt[0]\r\n        start_y = insert_pt[1]\r\n        end_x = start_x + ux * leaf_len\r\n        end_y = start_y + uy * leaf_len\r\n\r\n        p_leaf_start = clip_point((start_x, start_y), w, h)\r\n        p_leaf_end = clip_point((end_x, end_y), w, h)\r\n\r\n        cv2.arrowedLine(\r\n            img,\r\n            p_leaf_start,\r\n            p_leaf_end,\r\n            color,\r\n            thickness=DOOR_FINAL_LEAF_THICKNESS,\r\n            line_type=cv2.LINE_AA,\r\n            tipLength=0.24\r\n        )\r\n\r\n        label = \"{}{} placed\".format(\r\n            \"LeftDoor\" if item[\"class_name\"] == \"LeftDoor\" else \"RightDoor\",\r\n            idx + 1\r\n        )\r\n\r\n        tx = max(5, min(w - 260, int(x1)))\r\n        ty = max(22, min(h - 5, int(y2) + 22))\r\n        draw_text_with_outline(img, label, (tx, ty), color, scale=0.6)\r\n\r\n    return img\r\n\r\n\r\n# ============================================================\r\n# 图例\r\n# ============================================================\r\n\r\ndef make_legend_image():\r\n    img = np.zeros((250, 1180, 3), dtype=np.uint8)\r\n\r\n    c1 = COLOR_PALETTE[0]\r\n    c2 = COLOR_PALETTE[1]\r\n\r\n    cv2.arrowedLine(img, (45, 42), (180, 42), c1, 8, cv2.LINE_AA, tipLength=0.25)\r\n    cv2.putText(\r\n        img,\r\n        \"Furniture pose arrow: keypoint start -> keypoint end\",\r\n        (220, 50),\r\n        cv2.FONT_HERSHEY_SIMPLEX,\r\n        0.72,\r\n        (255, 255, 255),\r\n        2,\r\n        cv2.LINE_AA\r\n    )\r\n\r\n    overlay = img.copy()\r\n    cv2.arrowedLine(overlay, (45, 92), (180, 92), darker_color(c1, 0.55), 10, cv2.LINE_AA, tipLength=0.22)\r\n    img = cv2.addWeighted(overlay, 0.35, img, 0.65, 0)\r\n    cv2.putText(\r\n        img,\r\n        \"Furniture default direction: bottom -> top inside bbox, same color but darker and transparent\",\r\n        (220, 100),\r\n        cv2.FONT_HERSHEY_SIMPLEX,\r\n        0.72,\r\n        (255, 255, 255),\r\n        2,\r\n        cv2.LINE_AA\r\n    )\r\n\r\n    # 第九张图例：候选墙集合\r\n    overlay2 = img.copy()\r\n    for xx in range(45, 180, 22):\r\n        cv2.circle(overlay2, (xx, 150), 8, c2, -1, cv2.LINE_AA)\r\n    img = cv2.addWeighted(overlay2, 0.25, img, 0.75, 0)\r\n    cv2.circle(img, (112, 150), 15, c2, -1, cv2.LINE_AA)\r\n    cv2.circle(img, (112, 150), 20, c2, 4, cv2.LINE_AA)\r\n    cv2.putText(\r\n        img,\r\n        \"09: same-color transparent dotted walls = candidate host-wall set; solid large point = best projected insertion point\",\r\n        (220, 158),\r\n        cv2.FONT_HERSHEY_SIMPLEX,\r\n        0.72,\r\n        (255, 255, 255),\r\n        2,\r\n        cv2.LINE_AA\r\n    )\r\n\r\n    cv2.arrowedLine(img, (45, 208), (180, 208), c2, 12, cv2.LINE_AA, tipLength=0.24)\r\n    cv2.putText(\r\n        img,\r\n        \"10: final single-door placement, no candidate host-wall dots retained\",\r\n        (220, 216),\r\n        cv2.FONT_HERSHEY_SIMPLEX,\r\n        0.72,\r\n        (255, 255, 255),\r\n        2,\r\n        cv2.LINE_AA\r\n    )\r\n\r\n    return img\r\n\r\n\r\n# ============================================================\r\n# 主流程\r\n# ============================================================\r\n\r\ntry:\r\n    if doc is None:\r\n        raise Exception(\"当前 Revit doc 为空，请确认在 Revit + Dynamo 环境中运行。\")\r\n\r\n    if not pixpath or not os.path.exists(pixpath):\r\n        raise Exception(\"输入原始图片路径无效或不存在: {}\".format(pixpath))\r\n\r\n    pix_img = cv2.imread(pixpath, cv2.IMREAD_COLOR)\r\n    if pix_img is None:\r\n        raise Exception(\"cv2.imread 读取原图失败: {}\".format(pixpath))\r\n\r\n    img_h, img_w = pix_img.shape[:2]\r\n\r\n    logs.append(\"输入原始图像: {}\".format(pixpath))\r\n    logs.append(\"图像尺寸: width={}, height={}\".format(img_w, img_h))\r\n\r\n    image_dir = os.path.dirname(os.path.abspath(pixpath))\r\n    output_dir = os.path.join(image_dir, OUTPUT_FOLDER_NAME)\r\n    ensure_dir(output_dir)\r\n    logs.append(\"输出目录: {}\".format(output_dir))\r\n\r\n    if not wall_mask_img_path or not os.path.exists(wall_mask_img_path):\r\n        auto_path = os.path.join(output_dir, \"06_wall_thickness_semantic_bars.png\")\r\n        if os.path.exists(auto_path):\r\n            wall_mask_img_path = auto_path\r\n            logs.append(\"自动找到墙体遮罩图: {}\".format(wall_mask_img_path))\r\n\r\n    if wall_mask_img_path and os.path.exists(wall_mask_img_path):\r\n        base_img = cv2.imread(wall_mask_img_path, cv2.IMREAD_COLOR)\r\n        if base_img is None:\r\n            logs.append(\"读取墙体遮罩图失败，使用原图作为底图。\")\r\n            base_img = pix_img.copy()\r\n        else:\r\n            logs.append(\"读取墙体遮罩图成功: {}\".format(wall_mask_img_path))\r\n    else:\r\n        logs.append(\"未提供墙体遮罩图，使用原图作为底图。\")\r\n        base_img = pix_img.copy()\r\n\r\n    if base_img.shape[1] != img_w or base_img.shape[0] != img_h:\r\n        base_img = cv2.resize(base_img, (img_w, img_h), interpolation=cv2.INTER_LINEAR)\r\n        logs.append(\"底图尺寸与原图不同，已 resize 到原图尺寸。\")\r\n\r\n    class_config = load_class_config(class_config_json_path)\r\n    seg_meta = load_json_multi_encoding(seg_meta_json_path, \"seg_meta_json_path\")\r\n\r\n    mapper = PixelRevitMapper(img_w, img_h, fallback_scale, seg_meta)\r\n\r\n    walls = get_all_walls(doc)\r\n    logs.append(\"当前 Revit 文档墙体数量: {}\".format(len(walls)))\r\n\r\n    model = get_model(pose_Model)\r\n    instances, names = run_pose_inference(model, pixpath)\r\n\r\n    area_threshold_by_class = {}\r\n    for cname, cfg in class_config.items():\r\n        if bool(cfg.get(\"area_filter\", False)):\r\n            med, th = compute_class_area_threshold(instances, cname)\r\n            area_threshold_by_class[cname] = {\"median\": med, \"threshold\": th}\r\n            logs.append(\"类别{}面积过滤: median={}, threshold={}\".format(cname, med, th))\r\n\r\n    furniture_items = []\r\n    door_items_raw = []\r\n    skipped = []\r\n\r\n    for ins in instances:\r\n        cname = ins[\"class_name\"]\r\n\r\n        if cname not in class_config:\r\n            skipped.append({\"class_name\": cname, \"reason\": \"class_not_in_config\"})\r\n            continue\r\n\r\n        cfg = class_config[cname]\r\n        mode = str(cfg.get(\"placement_mode\", \"free\")).strip().lower()\r\n\r\n        x1, y1, x2, y2 = ins[\"bbox\"]\r\n        area = max(0.0, x2 - x1) * max(0.0, y2 - y1)\r\n\r\n        if bool(cfg.get(\"area_filter\", False)):\r\n            th = area_threshold_by_class.get(cname, {}).get(\"threshold\", 0.0)\r\n            if th > 0 and area < th:\r\n                skipped.append({\r\n                    \"class_name\": cname,\r\n                    \"reason\": \"area_filter\",\r\n                    \"area\": area,\r\n                    \"threshold\": th\r\n                })\r\n                continue\r\n\r\n        kp_start, kp_end = get_kp_pair(ins, cfg)\r\n\r\n        if mode == \"free\":\r\n            if kp_start is None or kp_end is None:\r\n                skipped.append({\"class_name\": cname, \"reason\": \"no_valid_keypoints_for_furniture\"})\r\n                continue\r\n\r\n            furniture_items.append({\r\n                \"class_name\": cname,\r\n                \"conf\": ins[\"conf\"],\r\n                \"bbox\": ins[\"bbox\"],\r\n                \"center_pix\": ins[\"center_pix\"],\r\n                \"kp_start\": kp_start,\r\n                \"kp_end\": kp_end\r\n            })\r\n\r\n        elif mode == \"door_hosted\":\r\n            if cname not in [\"LeftDoor\", \"RightDoor\"]:\r\n                skipped.append({\"class_name\": cname, \"reason\": \"door_hosted_but_not_single_door\"})\r\n                continue\r\n\r\n            if kp_start is None or kp_end is None:\r\n                skipped.append({\"class_name\": cname, \"reason\": \"no_valid_keypoints_for_door\"})\r\n                continue\r\n\r\n            door_items_raw.append({\r\n                \"instance\": ins,\r\n                \"config\": cfg,\r\n                \"kp_start\": kp_start,\r\n                \"kp_end\": kp_end\r\n            })\r\n\r\n    logs.append(\"家具可视化实例数量: {}\".format(len(furniture_items)))\r\n    logs.append(\"单开门候选实例数量: {}\".format(len(door_items_raw)))\r\n\r\n    door_items = []\r\n\r\n    for idx, d in enumerate(door_items_raw):\r\n        ins = d[\"instance\"]\r\n        cfg = d[\"config\"]\r\n\r\n        candidates = build_door_candidates(ins, cfg, mapper, walls)\r\n\r\n        if not candidates:\r\n            logs.append(\"单开门 idx={} class={} 未找到有效宿主墙候选。\".format(\r\n                idx, ins[\"class_name\"]\r\n            ))\r\n            continue\r\n\r\n        best = candidates[0]\r\n\r\n        # 候选墙集合像素化\r\n        candidate_walls_pix = []\r\n        for cand in candidates:\r\n            curve = cand[\"curve\"]\r\n            p0 = curve.GetEndPoint(0)\r\n            p1 = curve.GetEndPoint(1)\r\n\r\n            candidate_walls_pix.append({\r\n                \"wall_id\": cand[\"wall\"].Id.IntegerValue,\r\n                \"p0\": mapper.revit_to_pix(p0),\r\n                \"p1\": mapper.revit_to_pix(p1),\r\n                \"score\": float(cand[\"score\"])\r\n            })\r\n\r\n        best_curve = best[\"curve\"]\r\n        best_p0 = best_curve.GetEndPoint(0)\r\n        best_p1 = best_curve.GetEndPoint(1)\r\n\r\n        item = {\r\n            \"index\": idx,\r\n            \"class_name\": ins[\"class_name\"],\r\n            \"conf\": ins[\"conf\"],\r\n            \"bbox\": ins[\"bbox\"],\r\n            \"center_pix\": tuple(ins[\"center_pix\"]),\r\n            \"kp_start\": d[\"kp_start\"],\r\n            \"kp_end\": d[\"kp_end\"],\r\n            \"insert_pix\": mapper.revit_to_pix(best[\"insert_pt\"]),\r\n            \"host_wall_id\": best[\"wall\"].Id.IntegerValue,\r\n            \"host_score\": float(best[\"score\"]),\r\n            \"host_dist_ref\": float(best[\"dist_ref\"]),\r\n            \"host_dist_s\": float(best[\"dist_s\"]),\r\n            \"host_dist_b\": float(best[\"dist_b\"]),\r\n            \"perp_score\": float(best[\"perp_score\"]),\r\n            \"host_t\": float(best[\"t\"]),\r\n            \"candidate_count\": len(candidates),\r\n\r\n            # 第九张：候选墙集合\r\n            \"candidate_walls_pix\": candidate_walls_pix,\r\n\r\n            # 第九张：最佳墙单独标识\r\n            \"best_wall_pix\": {\r\n                \"p0\": mapper.revit_to_pix(best_p0),\r\n                \"p1\": mapper.revit_to_pix(best_p1),\r\n                \"wall_id\": best[\"wall\"].Id.IntegerValue\r\n            }\r\n        }\r\n\r\n        door_items.append(item)\r\n\r\n        logs.append(\r\n            \"单开门 idx={} class={} best_wall={} score={:.3f} candidates={}\".format(\r\n                idx,\r\n                ins[\"class_name\"],\r\n                item[\"host_wall_id\"],\r\n                item[\"host_score\"],\r\n                item[\"candidate_count\"]\r\n            )\r\n        )\r\n\r\n    logs.append(\"成功完成宿主墙筛选的单开门数量: {}\".format(len(door_items)))\r\n\r\n    # 08\r\n    furniture_img = draw_furniture_direction_image(base_img, furniture_items)\r\n    furniture_path = os.path.join(output_dir, \"08_furniture_pose_direction.png\")\r\n    save_image(furniture_path, furniture_img)\r\n\r\n    # 09\r\n    door_host_img = draw_door_host_selection_image(base_img, door_items)\r\n    door_host_path = os.path.join(output_dir, \"09_singledoor_host_wall_selection.png\")\r\n    save_image(door_host_path, door_host_img)\r\n\r\n    # 10：注意这里用 base_img 重新绘制，不保留第九张的候选墙点\r\n    door_final_img = draw_door_final_placement_image(base_img, door_items)\r\n    door_final_path = os.path.join(output_dir, \"10_singledoor_final_placement.png\")\r\n    save_image(door_final_path, door_final_img)\r\n\r\n    legend_img = make_legend_image()\r\n    legend_path = os.path.join(output_dir, \"08_09_10_pose_visualization_legend.png\")\r\n    save_image(legend_path, legend_img)\r\n\r\n    def jsonable_item(item):\r\n        out = {}\r\n        for k, v in item.items():\r\n            if isinstance(v, tuple):\r\n                out[k] = [float(x) for x in v]\r\n            elif isinstance(v, list):\r\n                out[k] = v\r\n            elif isinstance(v, np.ndarray):\r\n                out[k] = v.tolist()\r\n            elif isinstance(v, (int, float, str, bool)) or v is None:\r\n                out[k] = v\r\n            else:\r\n                try:\r\n                    out[k] = float(v)\r\n                except:\r\n                    out[k] = str(v)\r\n        return out\r\n\r\n    info = {\r\n        \"source_image\": pixpath,\r\n        \"base_wall_mask\": wall_mask_img_path,\r\n        \"seg_meta_json_path\": seg_meta_json_path,\r\n        \"class_config_json_path\": class_config_json_path,\r\n        \"furniture_count\": len(furniture_items),\r\n        \"single_door_count\": len(door_items),\r\n        \"furniture_items\": [jsonable_item(x) for x in furniture_items],\r\n        \"door_items\": [jsonable_item(x) for x in door_items],\r\n        \"skipped\": skipped\r\n    }\r\n\r\n    info_path = os.path.join(output_dir, \"08_09_10_pose_visualization_info.json\")\r\n    with open(info_path, \"w\", encoding=\"utf-8\") as f:\r\n        json.dump(info, f, ensure_ascii=False, indent=2)\r\n\r\n    logs.append(\"已保存可视化信息 JSON: {}\".format(info_path))\r\n\r\n    OUT = {\r\n        \"success\": True,\r\n        \"output_dir\": output_dir,\r\n        \"furniture_pose_direction\": furniture_path,\r\n        \"single_door_host_wall_selection\": door_host_path,\r\n        \"single_door_final_placement\": door_final_path,\r\n        \"legend\": legend_path,\r\n        \"info_json\": info_path,\r\n        \"furniture_count\": int(len(furniture_items)),\r\n        \"single_door_count\": int(len(door_items)),\r\n        \"skipped_count\": int(len(skipped)),\r\n        \"logs\": logs\r\n    }\r\n\r\nexcept Exception as e:\r\n    logs.append(\"执行失败: {}\".format(str(e)))\r\n    logs.append(traceback.format_exc())\r\n\r\n    OUT = {\r\n        \"success\": False,\r\n        \"error\": str(e),\r\n        \"logs\": logs\r\n    }\r\n",
      "Engine": "CPython3",

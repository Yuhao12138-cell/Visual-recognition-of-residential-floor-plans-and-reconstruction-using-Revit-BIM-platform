    {
      "ConcreteType": "CoreNodeModels.Watch, CoreNodeModels",
      "WatchWidth": 420.0,
      "WatchHeight": 38.4,
      "Id": "558c7c81b0b7400aa6aa56d5e738b188",
      "NodeType": "ExtensionNode",
      "Inputs": [

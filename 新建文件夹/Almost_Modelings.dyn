    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# -*- coding: utf-8 -*-\r\n\r\nimport os\r\nimport traceback\r\nimport random\r\nimport cv2\r\nimport numpy as np\r\n\r\ntry:\r\n    from ultralytics import YOLO\r\nexcept Exception:\r\n    YOLO = None\r\n\r\nlogs = []\r\n\r\n# ============================================================\r\n# 输入\r\n# ============================================================\r\n\r\ntry:\r\n    dect_Model = IN[0]\r\nexcept:\r\n    dect_Model = None\r\n\r\ntry:\r\n    pixpath = IN[1]\r\nexcept:\r\n    pixpath = \"\"\r\n\r\n# 可选参数\r\ntry:\r\n    YOLO_IMGSZ = int(IN[2])\r\nexcept:\r\n    YOLO_IMGSZ = 1280\r\n\r\ntry:\r\n    YOLO_CONF = float(IN[3])\r\nexcept:\r\n    YOLO_CONF = 0.7\r\n\r\ntry:\r\n    YOLO_IOU = float(IN[4])\r\nexcept:\r\n    YOLO_IOU = 0.45\r\n\r\n# 这里即使给了 IN[5]，也只是子文件夹名字，不允许变成完整路径\r\ntry:\r\n    output_folder_name = str(IN[5]).strip()\r\n    if not output_folder_name:\r\n        output_folder_name = \"structure_mask_process\"\r\nexcept:\r\n    output_folder_name = \"structure_mask_process\"\r\n\r\n# 防止有人把 json 路径传进来\r\noutput_folder_name = os.path.basename(output_folder_name)\r\noutput_folder_name = output_folder_name.replace(\".json\", \"\")\r\noutput_folder_name = output_folder_name.replace(\".txt\", \"\")\r\noutput_folder_name = output_folder_name.replace(\".png\", \"\")\r\noutput_folder_name = output_folder_name.replace(\".jpg\", \"\")\r\nif output_folder_name == \"\":\r\n    output_folder_name = \"structure_mask_process\"\r\n\r\n\r\n# ============================================================\r\n# 参数\r\n# ============================================================\r\n\r\nCLASS_COLORS = {\r\n    \"wall\":   (255, 255, 255),  # 白\r\n    \"door\":   (0, 255, 255),    # 黄\r\n    \"window\": (255, 0, 0),      # 蓝\r\n    \"tdoor\":  (255, 0, 255)     # 紫\r\n}\r\n\r\nUSE_RANDOM_COLORS = False\r\n\r\nOPENING_DILATE_KERNEL = 9\r\nOPENING_DILATE_ITER = 1\r\n\r\nBRIDGE_KERNEL = 5\r\nBRIDGE_ITER = 1\r\n\r\nCLOSE_KERNEL = 7\r\nCLOSE_ITER = 1\r\n\r\nOPEN_KERNEL = 3\r\nOPEN_ITER = 1\r\n\r\nERODE_BACK_KERNEL = 3\r\nERODE_BACK_ITER = 1\r\n\r\nMIN_COMPONENT_AREA = 80\r\n\r\n\r\n# ============================================================\r\n# 工具函数\r\n# ============================================================\r\n\r\ndef ensure_dir(folder):\r\n    if not folder:\r\n        raise Exception(\"输出文件夹为空，无法创建。\")\r\n    if not os.path.exists(folder):\r\n        os.makedirs(folder)\r\n\r\n\r\ndef normalize_class_name(name):\r\n    if name is None:\r\n        return \"\"\r\n    return str(name).strip().lower()\r\n\r\n\r\ndef classify_structural_class(class_name):\r\n    n = normalize_class_name(class_name)\r\n\r\n    if not n:\r\n        return None\r\n\r\n    # tdoor 优先\r\n    for kw in [\"tdoor\", \"double door\", \"double-door\", \"double_door\", \"双开门\", \"双扇门\", \"双门\"]:\r\n        if kw in n:\r\n            return \"tdoor\"\r\n\r\n    for kw in [\"window\", \"windows\", \"窗\", \"窗户\", \"飘窗\"]:\r\n        if kw in n:\r\n            return \"window\"\r\n\r\n    for kw in [\"door\", \"single door\", \"single-door\", \"single_door\", \"门\", \"单开门\", \"单扇门\"]:\r\n        if kw in n:\r\n            return \"door\"\r\n\r\n    for kw in [\"wall\", \"basic wall\", \"bearing wall\", \"shear wall\", \"墙\", \"墙体\", \"基本墙\", \"承重墙\", \"剪力墙\"]:\r\n        if kw in n:\r\n            return \"wall\"\r\n\r\n    return None\r\n\r\n\r\ndef get_model(model_input):\r\n    if model_input is None:\r\n        raise Exception(\"IN[0] 为空，请传入 YOLO 模型对象或模型路径。\")\r\n\r\n    if not isinstance(model_input, str):\r\n        if hasattr(model_input, \"predict\") or hasattr(model_input, \"__call__\"):\r\n            logs.append(\"检测到 IN[0] 是已加载模型对象，直接使用。\")\r\n            return model_input\r\n\r\n    model_path = str(model_input).strip()\r\n\r\n    if not model_path:\r\n        raise Exception(\"模型路径为空。\")\r\n\r\n    if not os.path.exists(model_path):\r\n        raise Exception(\"YOLO 模型路径不存在: {}\".format(model_path))\r\n\r\n    if YOLO is None:\r\n        raise Exception(\"无法导入 ultralytics.YOLO，请检查环境。\")\r\n\r\n    logs.append(\"开始加载 YOLO 模型: {}\".format(model_path))\r\n    model = YOLO(model_path)\r\n    logs.append(\"YOLO 模型加载完成。\")\r\n    return model\r\n\r\n\r\ndef safe_get_class_name(names, cls_id):\r\n    try:\r\n        if isinstance(names, dict):\r\n            return names.get(int(cls_id), str(cls_id))\r\n        return names[int(cls_id)]\r\n    except:\r\n        return str(cls_id)\r\n\r\n\r\ndef empty_class_masks(h, w):\r\n    return {\r\n        \"wall\": np.zeros((h, w), dtype=np.uint8),\r\n        \"door\": np.zeros((h, w), dtype=np.uint8),\r\n        \"window\": np.zeros((h, w), dtype=np.uint8),\r\n        \"tdoor\": np.zeros((h, w), dtype=np.uint8)\r\n    }\r\n\r\n\r\ndef fill_polygon_to_mask(mask, contour_pts, width, height):\r\n    pts = np.array(contour_pts, dtype=np.int32)\r\n\r\n    if pts is None or len(pts) < 3:\r\n        return False\r\n\r\n    pts[:, 0] = np.clip(pts[:, 0], 0, width - 1)\r\n    pts[:, 1] = np.clip(pts[:, 1], 0, height - 1)\r\n\r\n    cv2.fillPoly(mask, [pts], 255)\r\n    return True\r\n\r\n\r\ndef build_raw_structural_masks(result, width, height):\r\n    class_masks = empty_class_masks(height, width)\r\n\r\n    if result is None or result.masks is None:\r\n        return class_masks\r\n\r\n    masks_xy = result.masks.xy\r\n\r\n    if result.boxes is not None and result.boxes.cls is not None:\r\n        cls_ids = result.boxes.cls.cpu().numpy().astype(int)\r\n    else:\r\n        cls_ids = np.zeros(len(masks_xy), dtype=np.int32)\r\n\r\n    names = result.names\r\n\r\n    logs.append(\"YOLO 类别映射: {}\".format(str(names)))\r\n    logs.append(\"YOLO 实例 mask 数量: {}\".format(len(masks_xy)))\r\n\r\n    count_dict = {\"wall\": 0, \"door\": 0, \"window\": 0, \"tdoor\": 0, \"ignored\": 0}\r\n\r\n    for i, contour_pts in enumerate(masks_xy):\r\n        try:\r\n            if i >= len(cls_ids):\r\n                count_dict[\"ignored\"] += 1\r\n                continue\r\n\r\n            cls_id = int(cls_ids[i])\r\n            class_name = safe_get_class_name(names, cls_id)\r\n            structural_key = classify_structural_class(class_name)\r\n\r\n            if structural_key is None:\r\n                count_dict[\"ignored\"] += 1\r\n                continue\r\n\r\n            ok = fill_polygon_to_mask(class_masks[structural_key], contour_pts, width, height)\r\n\r\n            if ok:\r\n                count_dict[structural_key] += 1\r\n                logs.append(\"结构性类别写入: idx={}, name={}, mapped={}\".format(i, class_name, structural_key))\r\n            else:\r\n                count_dict[\"ignored\"] += 1\r\n\r\n        except Exception as e:\r\n            count_dict[\"ignored\"] += 1\r\n            logs.append(\"处理实例失败 idx={}: {}\".format(i, str(e)))\r\n\r\n    logs.append(\"结构性类别统计: {}\".format(str(count_dict)))\r\n    return class_masks\r\n\r\n\r\ndef generate_random_colors():\r\n    random.seed(1234)\r\n    return {\r\n        \"wall\":   (random.randint(40,255), random.randint(40,255), random.randint(40,255)),\r\n        \"door\":   (random.randint(40,255), random.randint(40,255), random.randint(40,255)),\r\n        \"window\": (random.randint(40,255), random.randint(40,255), random.randint(40,255)),\r\n        \"tdoor\":  (random.randint(40,255), random.randint(40,255), random.randint(40,255))\r\n    }\r\n\r\n\r\ndef colorize_class_masks(class_masks, colors):\r\n    h, w = class_masks[\"wall\"].shape[:2]\r\n    color_img = np.zeros((h, w, 3), dtype=np.uint8)\r\n\r\n    for key in [\"wall\", \"door\", \"window\", \"tdoor\"]:\r\n        color_img[class_masks[key] > 0] = colors[key]\r\n\r\n    return color_img\r\n\r\n\r\ndef dilate_opening_masks(raw_class_masks):\r\n    out = {}\r\n    for key in raw_class_masks:\r\n        out[key] = raw_class_masks[key].copy()\r\n\r\n    kernel = cv2.getStructuringElement(cv2.MORPH_RECT, (OPENING_DILATE_KERNEL, OPENING_DILATE_KERNEL))\r\n\r\n    for key in [\"door\", \"window\", \"tdoor\"]:\r\n        out[key] = cv2.dilate(out[key], kernel, iterations=OPENING_DILATE_ITER)\r\n\r\n    logs.append(\"门窗局部膨胀 kernel: {} x {}, iterations={}\".format(\r\n        OPENING_DILATE_KERNEL, OPENING_DILATE_KERNEL, OPENING_DILATE_ITER\r\n    ))\r\n    return out\r\n\r\n\r\ndef union_masks(class_masks):\r\n    h, w = class_masks[\"wall\"].shape[:2]\r\n    merged = np.zeros((h, w), dtype=np.uint8)\r\n\r\n    for key in [\"wall\", \"door\", \"window\", \"tdoor\"]:\r\n        merged[class_masks[key] > 0] = 255\r\n\r\n    return merged\r\n\r\n\r\ndef filter_small_components(mask, min_area):\r\n    num_labels, labels, stats, _ = cv2.connectedComponentsWithStats(mask, connectivity=8)\r\n    cleaned = np.zeros_like(mask, dtype=np.uint8)\r\n\r\n    kept = 0\r\n    removed = 0\r\n\r\n    for label_id in range(1, num_labels):\r\n        area = stats[label_id, cv2.CC_STAT_AREA]\r\n        if area >= min_area:\r\n            cleaned[labels == label_id] = 255\r\n            kept += 1\r\n        else:\r\n            removed += 1\r\n\r\n    logs.append(\"连通域过滤: kept={}, removed={}, min_area={}\".format(kept, removed, min_area))\r\n    return cleaned\r\n\r\n\r\ndef clean_structure_mask_with_gap_suppression(structure_mask):\r\n    mask = structure_mask.copy().astype(np.uint8)\r\n    mask[mask > 0] = 255\r\n\r\n    bridge_kernel = cv2.getStructuringElement(cv2.MORPH_RECT, (BRIDGE_KERNEL, BRIDGE_KERNEL))\r\n    mask = cv2.dilate(mask, bridge_kernel, iterations=BRIDGE_ITER)\r\n    logs.append(\"局部桥接 dilate kernel: {} x {}, iterations={}\".format(BRIDGE_KERNEL, BRIDGE_KERNEL, BRIDGE_ITER))\r\n\r\n    close_kernel = cv2.getStructuringElement(cv2.MORPH_RECT, (CLOSE_KERNEL, CLOSE_KERNEL))\r\n    mask = cv2.morphologyEx(mask, cv2.MORPH_CLOSE, close_kernel, iterations=CLOSE_ITER)\r\n    logs.append(\"闭运算 kernel: {} x {}, iterations={}\".format(CLOSE_KERNEL, CLOSE_KERNEL, CLOSE_ITER))\r\n\r\n    open_kernel = cv2.getStructuringElement(cv2.MORPH_RECT, (OPEN_KERNEL, OPEN_KERNEL))\r\n    mask = cv2.morphologyEx(mask, cv2.MORPH_OPEN, open_kernel, iterations=OPEN_ITER)\r\n    logs.append(\"弱开运算 kernel: {} x {}, iterations={}\".format(OPEN_KERNEL, OPEN_KERNEL, OPEN_ITER))\r\n\r\n    mask = filter_small_components(mask, MIN_COMPONENT_AREA)\r\n\r\n    if ERODE_BACK_KERNEL > 1 and ERODE_BACK_ITER > 0:\r\n        erode_kernel = cv2.getStructuringElement(cv2.MORPH_RECT, (ERODE_BACK_KERNEL, ERODE_BACK_KERNEL))\r\n        mask = cv2.erode(mask, erode_kernel, iterations=ERODE_BACK_ITER)\r\n        logs.append(\"轻微回缩 erode kernel: {} x {}, iterations={}\".format(\r\n            ERODE_BACK_KERNEL, ERODE_BACK_KERNEL, ERODE_BACK_ITER\r\n        ))\r\n\r\n    mask[mask > 0] = 255\r\n    return mask\r\n\r\n\r\ndef save_image(path, img):\r\n    folder = os.path.dirname(path)\r\n    ensure_dir(folder)\r\n\r\n    ok = cv2.imwrite(path, img)\r\n    if not ok:\r\n        raise Exception(\"cv2.imwrite 保存失败: {}\".format(path))\r\n\r\n    logs.append(\"已保存图像: {}\".format(path))\r\n\r\n\r\n# ============================================================\r\n# 主流程\r\n# ============================================================\r\n\r\ntry:\r\n    if not pixpath or not os.path.exists(pixpath):\r\n        raise Exception(\"输入图像路径无效或不存在: {}\".format(pixpath))\r\n\r\n    img = cv2.imread(pixpath, cv2.IMREAD_COLOR)\r\n    if img is None:\r\n        raise Exception(\"cv2.imread 读取图像失败: {}\".format(pixpath))\r\n\r\n    h, w = img.shape[:2]\r\n\r\n    logs.append(\"输入图像: {}\".format(pixpath))\r\n    logs.append(\"图像尺寸: width={}, height={}\".format(w, h))\r\n\r\n    # ======== 强制只按输入图片路径创建输出目录 ========\r\n    image_dir = os.path.dirname(os.path.abspath(pixpath))\r\n    output_dir = os.path.join(image_dir, output_folder_name)\r\n\r\n    logs.append(\"输入图片所在目录: {}\".format(image_dir))\r\n    logs.append(\"输出子文件夹名称: {}\".format(output_folder_name))\r\n    logs.append(\"最终输出文件夹: {}\".format(output_dir))\r\n\r\n    ensure_dir(output_dir)\r\n\r\n    model = get_model(dect_Model)\r\n\r\n    logs.append(\"开始 YOLO 实例分割推理...\")\r\n    logs.append(\"YOLO_IMGSZ={}, YOLO_CONF={}, YOLO_IOU={}\".format(YOLO_IMGSZ, YOLO_CONF, YOLO_IOU))\r\n\r\n    results = model(\r\n        pixpath,\r\n        imgsz=YOLO_IMGSZ,\r\n        conf=YOLO_CONF,\r\n        iou=YOLO_IOU,\r\n        verbose=False\r\n    )\r\n\r\n    if results is None or len(results) == 0:\r\n        raise Exception(\"YOLO 推理没有返回结果。\")\r\n\r\n    result = results[0]\r\n    logs.append(\"YOLO 推理完成。\")\r\n\r\n    raw_class_masks = build_raw_structural_masks(result, w, h)\r\n\r\n    colors = generate_random_colors() if USE_RANDOM_COLORS else CLASS_COLORS\r\n\r\n    raw_color_mask = colorize_class_masks(raw_class_masks, colors)\r\n    raw_path = os.path.join(output_dir, \"01_raw_structural_semantic_masks.png\")\r\n    save_image(raw_path, raw_color_mask)\r\n\r\n    dilated_class_masks = dilate_opening_masks(raw_class_masks)\r\n    dilated_color_mask = colorize_class_masks(dilated_class_masks, colors)\r\n    dilated_path = os.path.join(output_dir, \"02_dilated_opening_structural_masks.png\")\r\n    save_image(dilated_path, dilated_color_mask)\r\n\r\n    merged_mask = union_masks(dilated_class_masks)\r\n    cleaned_mask = clean_structure_mask_with_gap_suppression(merged_mask)\r\n    cleaned_path = os.path.join(output_dir, \"03_cleaned_structure_mask.png\")\r\n    save_image(cleaned_path, cleaned_mask)\r\n\r\n    OUT = {\r\n        \"success\": True,\r\n        \"output_dir\": output_dir,\r\n        \"raw_structural_semantic_mask\": raw_path,\r\n        \"dilated_opening_structural_mask\": dilated_path,\r\n        \"cleaned_structure_mask\": cleaned_path,\r\n        \"logs\": logs\r\n    }\r\n\r\nexcept Exception as e:\r\n    logs.append(\"执行失败: {}\".format(str(e)))\r\n    logs.append(traceback.format_exc())\r\n\r\n    OUT = {\r\n        \"success\": False,\r\n        \"error\": str(e),\r\n        \"logs\": logs\r\n    }\r\n",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "8c66335ef14142ba8834b780bc0cfee4",

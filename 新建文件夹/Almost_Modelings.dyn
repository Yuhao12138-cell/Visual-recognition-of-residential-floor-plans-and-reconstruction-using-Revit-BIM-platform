    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# -*- coding: utf-8 -*-\r\n\r\nimport os\r\nimport json\r\nimport math\r\nimport traceback\r\nimport cv2\r\nimport numpy as np\r\n\r\ntry:\r\n    from ultralytics import YOLO\r\nexcept:\r\n    YOLO = None\r\n\r\n# ---------------- Revit / Dynamo ----------------\r\ntry:\r\n    import clr\r\n    clr.AddReference(\"RevitServices\")\r\n    from RevitServices.Persistence import DocumentManager\r\n\r\n    clr.AddReference(\"RevitAPI\")\r\n    from Autodesk.Revit.DB import FilteredElementCollector, Wall, XYZ\r\n\r\n    doc = DocumentManager.Instance.CurrentDBDocument\r\nexcept Exception:\r\n    doc = None\r\n\r\nlogs = []\r\nlogs.append(\"=== 当前运行的是检测框中心点投影宿主墙可视化节点 V2 ===\")\r\n\r\n# ============================================================\r\n# 输入\r\n# ============================================================\r\ntry:\r\n    dect_Model = IN[0]\r\nexcept:\r\n    dect_Model = None\r\n\r\ntry:\r\n    pixpath = IN[1]\r\nexcept:\r\n    pixpath = \"\"\r\n\r\ntry:\r\n    wall_mask_img_path = str(IN[2]).strip()\r\nexcept:\r\n    wall_mask_img_path = \"\"\r\n\r\ntry:\r\n    seg_meta_json_path = str(IN[3]).strip()\r\nexcept:\r\n    seg_meta_json_path = \"\"\r\n\r\ntry:\r\n    fallback_scale = float(IN[4])\r\nexcept:\r\n    fallback_scale = 1.0\r\n\r\ntry:\r\n    YOLO_CONF = float(IN[5])\r\nexcept:\r\n    YOLO_CONF = 0.3\r\n\r\ntry:\r\n    YOLO_IOU = float(IN[6])\r\nexcept:\r\n    YOLO_IOU = 0.45\r\n\r\ntry:\r\n    YOLO_IMGSZ = int(IN[7])\r\nexcept:\r\n    YOLO_IMGSZ = 640\r\n\r\nOUTPUT_FOLDER_NAME = \"structure_mask_process\"\r\n\r\nTARGET_WINDOW_CLASS_NAME = \"window\"\r\nTARGET_DOOR_CLASS_NAME = \"twosidedoor\"\r\n\r\nMAX_HOST_WALL_SEARCH_DIST_FT = 6.0\r\n\r\nCENTER_POINT_RADIUS = 8\r\nPROJECT_POINT_RADIUS = 14\r\nPROJECT_POINT_RING_RADIUS = 20\r\nHOST_WALL_MARKER_RADIUS = 8\r\nHOST_WALL_MARKER_INTERVAL_PX = 34\r\nHOST_WALL_MARKER_ALPHA = 0.24\r\nCENTER_TO_PROJECT_LINE_THICKNESS = 3\r\nBBOX_LINE_THICKNESS = 2\r\n\r\nCOLOR_PALETTE = [\r\n    (0, 255, 0),\r\n    (255, 0, 255),\r\n    (0, 165, 255),\r\n    (255, 0, 0),\r\n    (128, 0, 255),\r\n    (0, 255, 255),\r\n    (255, 128, 0),\r\n    (80, 255, 120),\r\n    (180, 80, 255),\r\n    (255, 80, 80),\r\n]\r\n\r\n# ============================================================\r\n# seg_meta / 坐标参数\r\n# ============================================================\r\nbbox_min_x = None\r\nbbox_min_y = None\r\nbbox_width = None\r\nbbox_height = None\r\nscale_x_ft_per_px = None\r\nscale_y_ft_per_px = None\r\n\r\norigin = XYZ(0, 0, 0)\r\n\r\n# fallback\r\npixelWidth = 1600\r\npixelHeight = 1200\r\nwidthFt = fallback_scale\r\nscaleX = widthFt / pixelWidth if pixelWidth > 0 else 0.0\r\nscaleY = widthFt * (pixelHeight / float(pixelWidth)) / pixelHeight if pixelWidth > 0 and pixelHeight > 0 else 0.0\r\n\r\n# ============================================================\r\n# 工具函数\r\n# ============================================================\r\n\r\ndef ensure_dir(folder):\r\n    if folder and not os.path.exists(folder):\r\n        os.makedirs(folder)\r\n\r\ndef save_image(path, img):\r\n    ensure_dir(os.path.dirname(path))\r\n    ok = cv2.imwrite(path, img)\r\n    if not ok:\r\n        raise Exception(\"cv2.imwrite 保存失败: {}\".format(path))\r\n    logs.append(\"已保存图像: {}\".format(path))\r\n\r\ndef sanitize_name(name):\r\n    if not name:\r\n        return \"Unknown\"\r\n    return str(name).strip()\r\n\r\ndef load_json_multi_encoding(path):\r\n    if not path:\r\n        logs.append(\"seg_meta_json_path为空\")\r\n        return None\r\n\r\n    if not os.path.exists(path):\r\n        logs.append(\"seg_meta_json_path不存在: {}\".format(path))\r\n        return None\r\n\r\n    encodings = [\"utf-8\", \"utf-8-sig\", \"gbk\"]\r\n    last_err = None\r\n\r\n    for enc in encodings:\r\n        try:\r\n            with open(path, \"r\", encoding=enc) as f:\r\n                data = json.load(f)\r\n            logs.append(\"读取 seg_meta_json 成功: {} (encoding={})\".format(path, enc))\r\n            return data\r\n        except Exception as e:\r\n            last_err = e\r\n\r\n    logs.append(\"读取 seg_meta_json 失败: {}\".format(str(last_err)))\r\n    return None\r\n\r\ndef get_model(model_input):\r\n    if model_input is None:\r\n        raise Exception(\"IN[0] 为空，请传入 YOLO 模型对象或模型路径。\")\r\n\r\n    if not isinstance(model_input, str):\r\n        if hasattr(model_input, \"predict\") or hasattr(model_input, \"__call__\"):\r\n            logs.append(\"检测到 IN[0] 是已加载模型对象，直接使用。\")\r\n            return model_input\r\n\r\n    model_path = str(model_input).strip()\r\n\r\n    if not model_path:\r\n        raise Exception(\"模型路径为空。\")\r\n\r\n    if not os.path.exists(model_path):\r\n        raise Exception(\"YOLO 模型路径不存在: {}\".format(model_path))\r\n\r\n    if YOLO is None:\r\n        raise Exception(\"无法导入 ultralytics.YOLO，请检查环境。\")\r\n\r\n    logs.append(\"开始加载 YOLO 模型: {}\".format(model_path))\r\n    model = YOLO(model_path)\r\n    logs.append(\"YOLO 模型加载完成。\")\r\n    return model\r\n\r\ndef pix_to_revit(x, y):\r\n    global bbox_min_x, bbox_min_y, bbox_height\r\n    global scale_x_ft_per_px, scale_y_ft_per_px\r\n    global origin, scaleX, scaleY, pixelHeight\r\n\r\n    try:\r\n        if bbox_min_x is not None and bbox_min_y is not None and bbox_height is not None \\\r\n           and scale_x_ft_per_px is not None and scale_y_ft_per_px is not None:\r\n            local_x = x - bbox_min_x\r\n            local_y = y - bbox_min_y\r\n            revit_x = origin.X + local_x * scale_x_ft_per_px\r\n            revit_y = origin.Y + (bbox_height - local_y) * scale_y_ft_per_px\r\n            return XYZ(revit_x, revit_y, origin.Z)\r\n        else:\r\n            revit_x = origin.X + x * scaleX\r\n            revit_y = origin.Y + (pixelHeight - y) * scaleY\r\n            return XYZ(revit_x, revit_y, origin.Z)\r\n    except Exception:\r\n        revit_x = origin.X + x * scaleX\r\n        revit_y = origin.Y + (pixelHeight - y) * scaleY\r\n        return XYZ(revit_x, revit_y, origin.Z)\r\n\r\ndef revit_to_pix(pt):\r\n    global bbox_min_x, bbox_min_y, bbox_height\r\n    global scale_x_ft_per_px, scale_y_ft_per_px\r\n    global origin, scaleX, scaleY, pixelHeight\r\n\r\n    try:\r\n        if bbox_min_x is not None and bbox_min_y is not None and bbox_height is not None \\\r\n           and scale_x_ft_per_px is not None and scale_y_ft_per_px is not None:\r\n            local_x = (pt.X - origin.X) / scale_x_ft_per_px\r\n            local_y_from_bottom = (pt.Y - origin.Y) / scale_y_ft_per_px\r\n            local_y = bbox_height - local_y_from_bottom\r\n            x = bbox_min_x + local_x\r\n            y = bbox_min_y + local_y\r\n            return (float(x), float(y))\r\n        else:\r\n            x = (pt.X - origin.X) / scaleX if abs(scaleX) > 1e-12 else 0.0\r\n            y = pixelHeight - (pt.Y - origin.Y) / scaleY if abs(scaleY) > 1e-12 else 0.0\r\n            return (float(x), float(y))\r\n    except Exception:\r\n        x = (pt.X - origin.X) / scaleX if abs(scaleX) > 1e-12 else 0.0\r\n        y = pixelHeight - (pt.Y - origin.Y) / scaleY if abs(scaleY) > 1e-12 else 0.0\r\n        return (float(x), float(y))\r\n\r\ndef get_wall_curve(wall):\r\n    try:\r\n        loc = wall.Location\r\n        if loc and hasattr(loc, \"Curve\"):\r\n            return loc.Curve\r\n    except:\r\n        pass\r\n    return None\r\n\r\ndef point_to_curve_distance_2d(pt, curve):\r\n    try:\r\n        p0 = curve.GetEndPoint(0)\r\n        p1 = curve.GetEndPoint(1)\r\n\r\n        vx = p1.X - p0.X\r\n        vy = p1.Y - p0.Y\r\n        wx = pt.X - p0.X\r\n        wy = pt.Y - p0.Y\r\n\r\n        len2 = vx * vx + vy * vy\r\n        if len2 < 1e-12:\r\n            return None, None, None\r\n\r\n        t = (wx * vx + wy * vy) / len2\r\n\r\n        proj_x = p0.X + t * vx\r\n        proj_y = p0.Y + t * vy\r\n        proj_pt = XYZ(proj_x, proj_y, pt.Z)\r\n\r\n        dx = pt.X - proj_x\r\n        dy = pt.Y - proj_y\r\n        dist = math.sqrt(dx * dx + dy * dy)\r\n\r\n        return dist, proj_pt, t\r\n    except:\r\n        return None, None, None\r\n\r\ndef find_nearest_wall(doc, pt, max_dist_ft=6.0):\r\n    nearest_wall = None\r\n    nearest_curve = None\r\n    nearest_proj_pt = None\r\n    best_dist = 1e18\r\n    best_t = None\r\n\r\n    walls = FilteredElementCollector(doc).OfClass(Wall).ToElements()\r\n\r\n    checked = 0\r\n    valid = 0\r\n\r\n    for wall in walls:\r\n        try:\r\n            checked += 1\r\n            curve = get_wall_curve(wall)\r\n            if curve is None:\r\n                continue\r\n\r\n            p0 = curve.GetEndPoint(0)\r\n            p1 = curve.GetEndPoint(1)\r\n            wall_len = math.sqrt((p1.X - p0.X) ** 2 + (p1.Y - p0.Y) ** 2)\r\n            if wall_len < 1e-6:\r\n                continue\r\n\r\n            dist, proj_pt, t = point_to_curve_distance_2d(pt, curve)\r\n            if dist is None:\r\n                continue\r\n\r\n            # 只要求投影在线段上，放宽过滤，尽量贴近原放置代码\r\n            if t < 0.0 or t > 1.0:\r\n                continue\r\n\r\n            if dist <= max_dist_ft:\r\n                valid += 1\r\n                if dist < best_dist:\r\n                    best_dist = dist\r\n                    nearest_wall = wall\r\n                    nearest_curve = curve\r\n                    nearest_proj_pt = proj_pt\r\n                    best_t = t\r\n        except:\r\n            continue\r\n\r\n    logs.append(\"宿主墙搜索: checked={}, valid={}, best_dist={}\".format(\r\n        checked,\r\n        valid,\r\n        best_dist if best_dist < 1e18 else None\r\n    ))\r\n\r\n    return nearest_wall, nearest_curve, nearest_proj_pt, best_dist, best_t\r\n\r\ndef safe_get_class_name(names, cls_id):\r\n    try:\r\n        if isinstance(names, dict):\r\n            return names.get(int(cls_id), str(cls_id))\r\n        return names[int(cls_id)]\r\n    except:\r\n        return str(cls_id)\r\n\r\ndef classify_target(name):\r\n    n = sanitize_name(name).strip().lower()\r\n    if n == TARGET_WINDOW_CLASS_NAME:\r\n        return \"window\"\r\n    if n == TARGET_DOOR_CLASS_NAME:\r\n        return \"tdoor\"\r\n    return None\r\n\r\ndef clip_point(pt, w, h):\r\n    x, y = pt\r\n    x = int(round(x))\r\n    y = int(round(y))\r\n    x = max(0, min(w - 1, x))\r\n    y = max(0, min(h - 1, y))\r\n    return (x, y)\r\n\r\ndef draw_transparent_wall_markers(img, p1, p2, color):\r\n    h, w = img.shape[:2]\r\n    p1 = clip_point(p1, w, h)\r\n    p2 = clip_point(p2, w, h)\r\n\r\n    x1, y1 = p1\r\n    x2, y2 = p2\r\n    dx = x2 - x1\r\n    dy = y2 - y1\r\n    length = math.sqrt(dx * dx + dy * dy)\r\n    if length < 1:\r\n        return img\r\n\r\n    count = max(2, int(length / float(HOST_WALL_MARKER_INTERVAL_PX)))\r\n    overlay = img.copy()\r\n\r\n    for i in range(count + 1):\r\n        t = i / float(count)\r\n        x = int(round(x1 + dx * t))\r\n        y = int(round(y1 + dy * t))\r\n        cv2.circle(overlay, (x, y), HOST_WALL_MARKER_RADIUS, color, -1, cv2.LINE_AA)\r\n\r\n    out = cv2.addWeighted(overlay, HOST_WALL_MARKER_ALPHA, img, 1.0 - HOST_WALL_MARKER_ALPHA, 0)\r\n    return out\r\n\r\ndef draw_item(img, item, color):\r\n    h, w = img.shape[:2]\r\n\r\n    cx = clip_point(item[\"center_pix\"], w, h)\r\n    px = clip_point(item[\"projection_pix\"], w, h)\r\n\r\n    x1, y1, x2, y2 = item[\"bbox\"]\r\n    p1 = clip_point((x1, y1), w, h)\r\n    p2 = clip_point((x2, y2), w, h)\r\n\r\n    cv2.rectangle(img, p1, p2, color, BBOX_LINE_THICKNESS, cv2.LINE_AA)\r\n    cv2.line(img, cx, px, color, CENTER_TO_PROJECT_LINE_THICKNESS, cv2.LINE_AA)\r\n\r\n    cv2.circle(img, cx, CENTER_POINT_RADIUS + 3, (255, 255, 255), -1, cv2.LINE_AA)\r\n    cv2.circle(img, cx, CENTER_POINT_RADIUS, color, -1, cv2.LINE_AA)\r\n\r\n    cv2.circle(img, px, PROJECT_POINT_RING_RADIUS, color, 4, cv2.LINE_AA)\r\n    cv2.circle(img, px, PROJECT_POINT_RADIUS, color, -1, cv2.LINE_AA)\r\n    cv2.circle(img, px, 5, (255, 255, 255), -1, cv2.LINE_AA)\r\n\r\n    label = \"{}{}\".format(\"W\" if item[\"kind\"] == \"window\" else \"TD\", item[\"index\"])\r\n    tx = max(0, min(w - 80, px[0] + 12))\r\n    ty = max(20, min(h - 5, px[1] - 12))\r\n\r\n    cv2.putText(img, label, (tx, ty), cv2.FONT_HERSHEY_SIMPLEX, 0.65, (0, 0, 0), 4, cv2.LINE_AA)\r\n    cv2.putText(img, label, (tx, ty), cv2.FONT_HERSHEY_SIMPLEX, 0.65, color, 2, cv2.LINE_AA)\r\n\r\n    return img\r\n\r\n# ============================================================\r\n# 主流程\r\n# ============================================================\r\ntry:\r\n    if doc is None:\r\n        raise Exception(\"当前 Revit doc 为空，请在 Revit Dynamo 环境中运行。\")\r\n\r\n    if not pixpath or not os.path.exists(pixpath):\r\n        raise Exception(\"输入原始平面图路径无效或不存在: {}\".format(pixpath))\r\n\r\n    pix_img = cv2.imread(pixpath, cv2.IMREAD_COLOR)\r\n    if pix_img is None:\r\n        raise Exception(\"cv2.imread 读取原始平面图失败: {}\".format(pixpath))\r\n\r\n    pixel_h, pixel_w = pix_img.shape[:2]\r\n    pixelWidth = pixel_w\r\n    pixelHeight = pixel_h\r\n\r\n    logs.append(\"输入原始平面图: {}\".format(pixpath))\r\n    logs.append(\"原始图像尺寸: width={}, height={}\".format(pixel_w, pixel_h))\r\n\r\n    image_dir = os.path.dirname(os.path.abspath(pixpath))\r\n    output_dir = os.path.join(image_dir, OUTPUT_FOLDER_NAME)\r\n    ensure_dir(output_dir)\r\n    logs.append(\"输出文件夹: {}\".format(output_dir))\r\n\r\n    if (not wall_mask_img_path) or (not os.path.exists(wall_mask_img_path)):\r\n        auto_mask = os.path.join(output_dir, \"06_wall_thickness_semantic_bars.png\")\r\n        if os.path.exists(auto_mask):\r\n            wall_mask_img_path = auto_mask\r\n\r\n    if wall_mask_img_path and os.path.exists(wall_mask_img_path):\r\n        base_img = cv2.imread(wall_mask_img_path, cv2.IMREAD_COLOR)\r\n        if base_img is None:\r\n            base_img = pix_img.copy()\r\n            logs.append(\"读取墙体遮罩图失败，回退到原图。\")\r\n        else:\r\n            logs.append(\"读取墙体遮罩图成功: {}\".format(wall_mask_img_path))\r\n    else:\r\n        base_img = pix_img.copy()\r\n        logs.append(\"未提供有效墙体遮罩图，使用原始图像作为底图。\")\r\n\r\n    if base_img.shape[1] != pixel_w or base_img.shape[0] != pixel_h:\r\n        base_img = cv2.resize(base_img, (pixel_w, pixel_h), interpolation=cv2.INTER_LINEAR)\r\n        logs.append(\"底图已 resize 到原图尺寸。\")\r\n\r\n    # 读取 seg_meta\r\n    seg_meta = load_json_multi_encoding(seg_meta_json_path)\r\n    if seg_meta and seg_meta.get(\"ok\", False):\r\n        try:\r\n            bbox_info = seg_meta.get(\"wall_bbox_px\", None)\r\n            scale_info = seg_meta.get(\"scale\", {})\r\n\r\n            if bbox_info:\r\n                bbox_min_x = bbox_info.get(\"min_x\", None)\r\n                bbox_min_y = bbox_info.get(\"min_y\", None)\r\n                bbox_width = bbox_info.get(\"width\", None)\r\n                bbox_height = bbox_info.get(\"height\", None)\r\n\r\n            scale_x_ft_per_px = scale_info.get(\"scale_x_ft_per_px\", None)\r\n            scale_y_ft_per_px = scale_info.get(\"scale_y_ft_per_px\", None)\r\n\r\n            dbg = seg_meta.get(\"debug\", {})\r\n            if \"pixelWidth\" in dbg:\r\n                pixelWidth = dbg.get(\"pixelWidth\", pixelWidth)\r\n            if \"pixelHeight\" in dbg:\r\n                pixelHeight = dbg.get(\"pixelHeight\", pixelHeight)\r\n\r\n            logs.append(\"坐标映射 use_bbox_mapping=True\")\r\n        except Exception as e:\r\n            logs.append(\"解析 seg_meta 失败: {}\".format(str(e)))\r\n    else:\r\n        logs.append(\"seg_meta 无效，使用 fallback 整图 scale\")\r\n\r\n    logs.append(\"bbox_min_x={}, bbox_min_y={}, bbox_width={}, bbox_height={}\".format(\r\n        bbox_min_x, bbox_min_y, bbox_width, bbox_height\r\n    ))\r\n    logs.append(\"scale_x_ft_per_px={}, scale_y_ft_per_px={}\".format(\r\n        scale_x_ft_per_px, scale_y_ft_per_px\r\n    ))\r\n\r\n    model = get_model(dect_Model)\r\n\r\n    logs.append(\"开始 YOLO 检测推理...\")\r\n    logs.append(\"YOLO_IMGSZ={}, YOLO_CONF={}, YOLO_IOU={}\".format(\r\n        YOLO_IMGSZ, YOLO_CONF, YOLO_IOU\r\n    ))\r\n\r\n    result_list = model(\r\n        source=pixpath,\r\n        save=False,\r\n        conf=YOLO_CONF,\r\n        iou=YOLO_IOU,\r\n        imgsz=YOLO_IMGSZ,\r\n        verbose=False\r\n    )\r\n\r\n    if result_list is None or len(result_list) == 0:\r\n        raise Exception(\"YOLO 检测没有返回结果。\")\r\n\r\n    result = result_list[0]\r\n    boxes = result.boxes\r\n    xyxy = boxes.xyxy.cpu().numpy() if boxes is not None and boxes.xyxy is not None else np.empty((0, 4))\r\n    cls_ids = boxes.cls.cpu().numpy().astype(int) if boxes is not None and boxes.cls is not None else np.array([], dtype=int)\r\n    confs = boxes.conf.cpu().numpy() if boxes is not None and boxes.conf is not None else np.ones((len(xyxy),), dtype=np.float32)\r\n    names = result.names\r\n\r\n    logs.append(\"检测框数量: {}\".format(len(xyxy)))\r\n    logs.append(\"类别映射: {}\".format(str(names)))\r\n\r\n    detections = []\r\n    for i, bbox in enumerate(xyxy):\r\n        try:\r\n            class_id = cls_ids[i]\r\n            class_name = sanitize_name(safe_get_class_name(names, class_id))\r\n            kind = classify_target(class_name)\r\n            if kind is None:\r\n                continue\r\n\r\n            x1, y1, x2, y2 = bbox\r\n            cx = 0.5 * (x1 + x2)\r\n            cy = 0.5 * (y1 + y2)\r\n\r\n            detections.append({\r\n                \"raw_index\": i,\r\n                \"kind\": kind,\r\n                \"class_name\": class_name,\r\n                \"conf\": float(confs[i]),\r\n                \"bbox\": [float(x1), float(y1), float(x2), float(y2)],\r\n                \"center_pix\": (float(cx), float(cy))\r\n            })\r\n        except Exception as e:\r\n            logs.append(\"解析检测框失败 idx={}: {}\".format(i, str(e)))\r\n\r\n    logs.append(\"严格筛选后窗/双开门数量: {}\".format(len(detections)))\r\n\r\n    processed_items = []\r\n\r\n    for idx, det in enumerate(detections):\r\n        try:\r\n            cx, cy = det[\"center_pix\"]\r\n            revit_center_pt = pix_to_revit(cx, cy)\r\n\r\n            nearest_wall, nearest_curve, nearest_proj_pt, best_dist, best_t = find_nearest_wall(\r\n                doc,\r\n                revit_center_pt,\r\n                max_dist_ft=MAX_HOST_WALL_SEARCH_DIST_FT\r\n            )\r\n\r\n            if nearest_wall is None or nearest_proj_pt is None:\r\n                logs.append(\"检测项 {} 未找到有效宿主墙，跳过绘制。class={}, conf={}\".format(\r\n                    idx, det[\"class_name\"], det[\"conf\"]\r\n                ))\r\n                continue\r\n\r\n            proj_pix = revit_to_pix(nearest_proj_pt)\r\n\r\n            wall_p0 = nearest_curve.GetEndPoint(0)\r\n            wall_p1 = nearest_curve.GetEndPoint(1)\r\n            wall_p0_pix = revit_to_pix(wall_p0)\r\n            wall_p1_pix = revit_to_pix(wall_p1)\r\n\r\n            item = {\r\n                \"index\": idx + 1,\r\n                \"kind\": det[\"kind\"],\r\n                \"class_name\": det[\"class_name\"],\r\n                \"conf\": det[\"conf\"],\r\n                \"bbox\": det[\"bbox\"],\r\n                \"center_pix\": det[\"center_pix\"],\r\n                \"projection_pix\": proj_pix,\r\n                \"wall_p0_pix\": wall_p0_pix,\r\n                \"wall_p1_pix\": wall_p1_pix,\r\n                \"host_wall_id\": nearest_wall.Id.IntegerValue,\r\n                \"host_distance_ft\": best_dist,\r\n                \"host_t\": best_t\r\n            }\r\n            processed_items.append(item)\r\n\r\n            logs.append(\"检测项 {}: class={}, conf={:.3f}, center_pix=({:.1f},{:.1f}), proj_pix=({:.1f},{:.1f}), host_wall_id={}, dist_ft={:.4f}\".format(\r\n                idx,\r\n                det[\"class_name\"],\r\n                det[\"conf\"],\r\n                cx, cy,\r\n                proj_pix[0], proj_pix[1],\r\n                item[\"host_wall_id\"],\r\n                best_dist if best_dist is not None else -1.0\r\n            ))\r\n        except Exception as e:\r\n            logs.append(\"检测项 {} 投影处理失败: {}\".format(idx, str(e)))\r\n\r\n    logs.append(\"成功完成投影的窗/双开门数量: {}\".format(len(processed_items)))\r\n\r\n    draw_img = base_img.copy()\r\n\r\n    for i, item in enumerate(processed_items):\r\n        color = COLOR_PALETTE[i % len(COLOR_PALETTE)]\r\n        draw_img = draw_transparent_wall_markers(\r\n            draw_img,\r\n            item[\"wall_p0_pix\"],\r\n            item[\"wall_p1_pix\"],\r\n            color\r\n        )\r\n\r\n    for i, item in enumerate(processed_items):\r\n        color = COLOR_PALETTE[i % len(COLOR_PALETTE)]\r\n        draw_img = draw_item(draw_img, item, color)\r\n\r\n    out_path = os.path.join(output_dir, \"07_detection_projection_host_wall.png\")\r\n    save_image(out_path, draw_img)\r\n\r\n    info_path = os.path.join(output_dir, \"07_detection_projection_host_wall_info.json\")\r\n    with open(info_path, \"w\") as f:\r\n        json.dump({\r\n            \"source_image\": pixpath,\r\n            \"count\": len(processed_items),\r\n            \"items\": processed_items\r\n        }, f, ensure_ascii=False, indent=2)\r\n\r\n    legend = np.zeros((130, 900, 3), dtype=np.uint8)\r\n    cv2.circle(legend, (60, 42), PROJECT_POINT_RADIUS, COLOR_PALETTE[0], -1, cv2.LINE_AA)\r\n    cv2.circle(legend, (60, 42), PROJECT_POINT_RING_RADIUS, COLOR_PALETTE[0], 4, cv2.LINE_AA)\r\n    cv2.putText(legend, \"Projected point on host wall\", (100, 50), cv2.FONT_HERSHEY_SIMPLEX, 0.75, (255,255,255), 2, cv2.LINE_AA)\r\n    cv2.circle(legend, (60, 95), CENTER_POINT_RADIUS, COLOR_PALETTE[1], -1, cv2.LINE_AA)\r\n    cv2.putText(legend, \"Original bbox center; faint dots indicate corresponding host wall\", (100, 103), cv2.FONT_HERSHEY_SIMPLEX, 0.75, (255,255,255), 2, cv2.LINE_AA)\r\n\r\n    legend_path = os.path.join(output_dir, \"07_detection_projection_host_wall_legend.png\")\r\n    save_image(legend_path, legend)\r\n\r\n    OUT = {\r\n        \"success\": True,\r\n        \"output_dir\": output_dir,\r\n        \"projection_visualization\": out_path,\r\n        \"legend\": legend_path,\r\n        \"projection_info_json\": info_path,\r\n        \"processed_count\": int(len(processed_items)),\r\n        \"logs\": logs\r\n    }\r\n\r\nexcept Exception as e:\r\n    logs.append(\"执行失败: {}\".format(str(e)))\r\n    logs.append(traceback.format_exc())\r\n    OUT = {\r\n        \"success\": False,\r\n        \"error\": str(e),\r\n        \"logs\": logs\r\n    }\r\n",
      "Engine": "CPython3",

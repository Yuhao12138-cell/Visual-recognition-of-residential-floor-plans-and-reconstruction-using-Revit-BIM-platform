    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# 加载PythonStandard 和 DesignScript 库\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\nimport Autodesk.DesignScript.Geometry as DS\r\nimport Revit\r\nfrom Revit.Elements import *\r\nimport System\r\nsys.path.append(\"C:/Users/Lenovo/anaconda3/envs/revitenv/Lib/site-packages\")\r\nclr.AddReference('RevitAPI')\r\nclr.AddReference('RevitAPIUI')\r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.UI import *\r\n\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\nclr.AddReference('RevitNodes')\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\n\r\nimport re\r\nimport json\r\nimport os\r\nimport numpy as np\r\nimport torch\r\nimport cv2\r\nfrom ultralytics import YOLO\r\n\r\ndataEnteringNode = IN \r\n\r\n# =========================\r\n# 输入\r\n# =========================\r\ndect_Model = IN[0]\r\npixpath = IN[1]\r\nscale = IN[2]              # 保留作fallback\r\nseg_meta_json_path = IN[3] # 新增：读取分割得到的缩放与bbox信息\r\n\r\n# =========================\r\n# 参数\r\n# =========================\r\norigin = XYZ(0, 0, 0)   \r\nwidthFt = scale\r\npixelWidth = 1600   \r\npixelHeight = 1200\r\n\r\nnewpath = \"E:/yanjiu/revitss/tests/jjianzhu_dect.jpg\"\r\n\r\n# fallback 比例（只有在seg_meta读取失败时才使用）\r\nscaleX = widthFt / pixelWidth if pixelWidth > 0 else 0.0\r\nscaleY = widthFt * (pixelHeight / pixelWidth) / pixelHeight if pixelWidth > 0 and pixelHeight > 0 else 0.0\r\n\r\n# seg_meta读取到的参数\r\nbbox_info = None\r\nbbox_min_x = None\r\nbbox_min_y = None\r\nbbox_width = None\r\nbbox_height = None\r\nscale_x_ft_per_px = None\r\nscale_y_ft_per_px = None\r\n\r\nlogs = []\r\n\r\n# =========================\r\n# 工具函数\r\n# =========================\r\ndef sanitize_name(name):\r\n    if not name:\r\n        return \"Unknown\"\r\n    cleaned = re.sub(r'[\\x00-\\x1f\\x7f]', '', str(name))\r\n    if not cleaned.strip():\r\n        return \"Unnamed\"\r\n    return cleaned\r\n\r\ndef load_seg_meta(seg_meta_json_path, logs):\r\n    if seg_meta_json_path is None:\r\n        logs.append(\"seg_meta_json_path为空\")\r\n        return None\r\n\r\n    try:\r\n        with open(seg_meta_json_path, \"r\", encoding=\"utf-8\") as f:\r\n            data = json.load(f)\r\n        logs.append(\"读取seg_meta_json成功: {}\".format(seg_meta_json_path))\r\n        return data\r\n    except Exception as e:\r\n        logs.append(\"读取seg_meta_json失败: {}\".format(str(e)))\r\n        return None\r\n\r\ndef pix_to_revit(x, y):\r\n    \"\"\"\r\n    优先使用seg_meta中的 bbox + scale\r\n    与墙体分割/建墙使用同一坐标映射方式\r\n    \"\"\"\r\n    global bbox_min_x, bbox_min_y, bbox_width, bbox_height\r\n    global scale_x_ft_per_px, scale_y_ft_per_px\r\n    global origin, scaleX, scaleY, pixelHeight\r\n\r\n    try:\r\n        if bbox_min_x is not None and bbox_min_y is not None and bbox_height is not None \\\r\n           and scale_x_ft_per_px is not None and scale_y_ft_per_px is not None:\r\n\r\n            local_x = x - bbox_min_x\r\n            local_y = y - bbox_min_y\r\n\r\n            revit_x = origin.X + local_x * scale_x_ft_per_px\r\n            revit_y = origin.Y + (bbox_height - local_y) * scale_y_ft_per_px\r\n            return XYZ(revit_x, revit_y, origin.Z)\r\n    except:\r\n        pass\r\n\r\n    # fallback：原整图映射\r\n    revit_x = origin.X + x * scaleX\r\n    revit_y = origin.Y + (pixelHeight - y) * scaleY\r\n    return XYZ(revit_x, revit_y, origin.Z)\r\n\r\n# =========================\r\n# 读取seg_meta\r\n# =========================\r\nseg_meta = load_seg_meta(seg_meta_json_path, logs)\r\n\r\nif seg_meta and seg_meta.get(\"ok\", False):\r\n    try:\r\n        bbox_info = seg_meta.get(\"wall_bbox_px\", None)\r\n        scale_info = seg_meta.get(\"scale\", {})\r\n\r\n        if bbox_info:\r\n            bbox_min_x = bbox_info.get(\"min_x\", None)\r\n            bbox_min_y = bbox_info.get(\"min_y\", None)\r\n            bbox_width = bbox_info.get(\"width\", None)\r\n            bbox_height = bbox_info.get(\"height\", None)\r\n\r\n        scale_x_ft_per_px = scale_info.get(\"scale_x_ft_per_px\", None)\r\n        scale_y_ft_per_px = scale_info.get(\"scale_y_ft_per_px\", None)\r\n\r\n        dbg = seg_meta.get(\"debug\", {})\r\n        if \"pixelWidth\" in dbg and \"pixelHeight\" in dbg:\r\n            pixelWidth = dbg.get(\"pixelWidth\", pixelWidth)\r\n            pixelHeight = dbg.get(\"pixelHeight\", pixelHeight)\r\n\r\n        logs.append(\"bbox_info={}\".format(str(bbox_info)))\r\n        logs.append(\"scale_x_ft_per_px={}\".format(str(scale_x_ft_per_px)))\r\n        logs.append(\"scale_y_ft_per_px={}\".format(str(scale_y_ft_per_px)))\r\n        logs.append(\"pixelWidth={}, pixelHeight={}\".format(pixelWidth, pixelHeight))\r\n    except Exception as e:\r\n        logs.append(\"解析seg_meta失败: {}\".format(str(e)))\r\nelse:\r\n    logs.append(\"seg_meta无效，使用fallback整图scale\")\r\n\r\n# =========================\r\n# 运行YOLO检测\r\n# =========================\r\nyolo_dect = YOLO(dect_Model, task=\"detect\")\r\ndect_result = yolo_dect(source=pixpath, save=False, conf=0.3, iou=0.45, imgsz=640)\r\ncv2.imwrite(newpath, dect_result[0].plot())\r\n\r\nresult = dect_result[0]\r\nboxes = result.boxes\r\nxyxy = boxes.xyxy.cpu().numpy() if boxes is not None else np.empty((0, 4))\r\ncls_ids = boxes.cls.cpu().numpy().astype(int) if boxes is not None else np.array([], dtype=int)\r\nnames = result.names\r\n\r\nlogs.append(\"检测框数量: {}\".format(len(xyxy)))\r\nlogs.append(\"类别映射: {}\".format(str(names)))\r\n\r\n# =========================\r\n# Revit文档对象\r\n# =========================\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\napp = doc.Application\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\ncreated_lines = []\r\ndyn_lines = []\r\ndyn_faces = [] \r\ncreated_shapes = []\r\n\r\nplane = Plane.CreateByNormalAndOrigin(XYZ.BasisZ, origin)\r\nsketch_plane = SketchPlane.Create(doc, plane)\r\n\r\n# =========================\r\n# 创建检测框\r\n# =========================\r\nfor i, bbox in enumerate(xyxy):\r\n    try:\r\n        x1, y1, x2, y2 = bbox\r\n\r\n        pt1 = pix_to_revit(x1, y1)  # 左上\r\n        pt2 = pix_to_revit(x2, y1)  # 右上\r\n        pt3 = pix_to_revit(x2, y2)  # 右下\r\n        pt4 = pix_to_revit(x1, y2)  # 左下\r\n\r\n        dyn_pt1 = pt1.ToPoint()\r\n        dyn_pt2 = pt2.ToPoint()\r\n        dyn_pt3 = pt3.ToPoint()\r\n        dyn_pt4 = pt4.ToPoint()\r\n\r\n        lines = [\r\n            Line.CreateBound(pt1, pt2),\r\n            Line.CreateBound(pt2, pt3),\r\n            Line.CreateBound(pt3, pt4),\r\n            Line.CreateBound(pt4, pt1)\r\n        ]\r\n\r\n        for line in lines:\r\n            model_curve = doc.Create.NewModelCurve(line, sketch_plane)\r\n            created_lines.append(model_curve)\r\n\r\n            start_dyn = line.GetEndPoint(0).ToPoint()\r\n            end_dyn = line.GetEndPoint(1).ToPoint()\r\n            dyn_line = DS.Line.ByStartPointEndPoint(start_dyn, end_dyn)\r\n            dyn_lines.append(dyn_line)\r\n\r\n        points = [dyn_pt1, dyn_pt2, dyn_pt3, dyn_pt4]\r\n        poly = DS.PolyCurve.ByPoints(points, connectLastToFirst=True)\r\n        if poly.IsClosed:\r\n            surface = DS.Surface.ByPatch(poly)\r\n            dyn_faces.append(surface)\r\n\r\n        curve_loop = CurveLoop()\r\n        curve_loop.Append(Line.CreateBound(pt1, pt2))\r\n        curve_loop.Append(Line.CreateBound(pt2, pt3))\r\n        curve_loop.Append(Line.CreateBound(pt3, pt4))\r\n        curve_loop.Append(Line.CreateBound(pt4, pt1))\r\n\r\n        thickness = 0.001\r\n        solid = GeometryCreationUtilities.CreateExtrusionGeometry(\r\n            [curve_loop], XYZ.BasisZ, thickness)\r\n\r\n        direct_shape = DirectShape.CreateElement(doc, ElementId(BuiltInCategory.OST_GenericModel))\r\n        direct_shape.SetShape([solid])\r\n\r\n        class_id = cls_ids[i]\r\n        class_name = names[class_id]\r\n        safe_name = sanitize_name(class_name)\r\n        direct_shape.Name = \"YOLO_\" + safe_name\r\n        created_shapes.append(direct_shape)\r\n\r\n        logs.append(\"检测框{}创建成功: class={}, bbox=({}, {}, {}, {})\".format(\r\n            i, safe_name, x1, y1, x2, y2\r\n        ))\r\n\r\n    except Exception as e:\r\n        logs.append(\"检测框{}创建失败: {}\".format(i, str(e)))\r\n        continue\r\n\r\n# =========================\r\n# 提交事务\r\n# =========================\r\nTransactionManager.Instance.TransactionTaskDone()\r\ndoc.Regenerate()\r\n\r\n# =========================\r\n# 输出\r\n# =========================\r\nOUT = newpath, created_shapes, logs\r\n",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "dad25e71cf1c42718e4f6a9491ef0db5",

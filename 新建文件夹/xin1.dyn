      "FunctionSignature": "DSCore.IO.Image.ReadFromFile@var",
      "Replication": "Auto",
      "Description": "作为位图加载文件。\n\nImage.ReadFromFile (file: var): var"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# 加载 Python Standard 和 DesignScript 库\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\nimport Autodesk.DesignScript.Geometry as DS\r\nimport Revit\r\nfrom Revit.Elements import *\r\nimport System\r\nsys.path.append(\"C:/Users/Lenovo/anaconda3/envs/revitenv/Lib/site-packages\")\r\nclr.AddReference('RevitAPI')\r\nclr.AddReference('RevitAPIUI')\r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.UI import *\r\n\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\nclr.AddReference('RevitNodes')\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\n#\r\nimport numpy as np\r\nimport torch\r\nimport cv2\r\nfrom ultralytics import YOLO\r\n\r\ndataEnteringNode = IN \r\ndect_Model = IN[0]\r\npixpath = IN[1]\r\n#params\r\norigin = XYZ(0, 0, 0)   \r\nwidthFt = 10.0\r\npixelWidth = 1600   \r\npixelHeight = 1200                          \r\n#                         \r\nyolo_dect = YOLO(dect_Model,task = \"detect\")\r\nnewpath = \"E:/yanjiu/revitss/tests/jjianzhu_dect.jpg\"\r\n\r\ndect_result = yolo_dect(source = pixpath,save = False,conf = 0.3,iou = 0.45,imgsz = 640)\r\ncv2.imwrite(newpath,dect_result[0].plot())\r\n#tempouts = []\r\n#tempouts.append(newpath)\r\n#tempouts.extend(dect_result)\r\nscaleX = widthFt / pixelWidth\r\nscaleY = widthFt * (pixelHeight / pixelWidth) / pixelHeight  \r\n\r\nresult = dect_result[0]        \r\nboxes = result.boxes\r\nxyxy = boxes.xyxy.cpu().numpy() \r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\napp = doc.Application\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\ncreated_lines = []\r\ndyn_lines = [] \r\ndyn_faces = [] \r\n\r\ndef pix_to_revit(x, y):\r\n    revit_x = origin.X + x * scaleX\r\n    revit_y = origin.Y + (pixelHeight - y) * scaleY  # 翻转 Y 轴\r\n    return XYZ(revit_x, revit_y, origin.Z)\r\nplane = Plane.CreateByNormalAndOrigin(XYZ.BasisZ, origin)\r\nsketch_plane = SketchPlane.Create(doc, plane)\r\n\r\nfor bbox in xyxy:\r\n    x1, y1, x2, y2 = bbox  # 左上角 (x1,y1), 右下角 (x2,y2)\r\n    \r\n    # 计算四个角点的 Revit 坐标\r\n    pt1 = pix_to_revit(x1, y1)  # 左上\r\n    pt2 = pix_to_revit(x2, y1)  # 右上\r\n    pt3 = pix_to_revit(x2, y2)  # 右下\r\n    pt4 = pix_to_revit(x1, y2)  # 左下\r\n    \r\n    # 创建四条线\r\n    lines = [\r\n        Line.CreateBound(pt1, pt2),\r\n        Line.CreateBound(pt2, pt3),\r\n        Line.CreateBound(pt3, pt4),\r\n        Line.CreateBound(pt4, pt1)\r\n    ]\r\n    \r\n    # 创建模型线并添加到列表\r\n    for line in lines:\r\n        model_curve = doc.Create.NewModelCurve(line, sketch_plane)\r\n        created_lines.append(model_curve)\r\n        start_dyn = line.GetEndPoint(0).ToPoint()\r\n        end_dyn = line.GetEndPoint(1).ToPoint()\r\n        dyn_line = DS.Line.ByStartPointEndPoint(start_dyn, end_dyn)\r\n        dyn_lines.append(dyn_line)\r\n    poly = DS.PolyCurve.ByJoinedCurves(dyn_lines, 0.001)\r\n    if poly.IsClosed:\r\n        surface = DS.Surface.ByPatch(poly)\r\n        dyn_faces.append(surface)\r\n    \r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\ndoc.Regenerate()\r\n# Outss\r\n#OUT = [created_lines, dyn_lines]\r\nOUT = dyn_faces",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "f60af7ea64e4407eafe628e1b967fa9f",

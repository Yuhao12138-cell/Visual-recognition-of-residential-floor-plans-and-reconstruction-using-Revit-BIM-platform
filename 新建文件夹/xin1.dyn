    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "#加载PythonStandard和DesignScript库\r\nimport sys\r\nimport clr\r\nclr.AddReference( 'ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n#加载RevitAPI\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n#加载RevitNodes\r\nclr.AddReference('RevitNodes')\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\n#加载Revitservices\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n#该节点的输入内容将存储为IN变量中的一个列表。\r\nfamtype=UnwrapElement(IN[0])\r\n#将代码放在该行下面\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\nif not famtype.IsActive:\r\n    famtype.Activate()\r\nfaminstances = []\r\n\r\nfor x in range(0,16000,1600):\r\n    \r\n    x = UnitUtils.ConvertToInternalUnits(x, UnitTypeId.Millimeters)\r\n    f = doc.Create.NewFamilyInstance(XYZ(0,x,0), famtype, Structure.StructuralType.NonStructural)\r\n    faminstances.append(f.ToDSType(True))\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\n#将输出内容指定给OUT变量。\r\nOUT = faminstances",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "1386f867729f4a9c9f841f73d487b9db",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "4a5a1d47c760460892e006d829f7986c",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [

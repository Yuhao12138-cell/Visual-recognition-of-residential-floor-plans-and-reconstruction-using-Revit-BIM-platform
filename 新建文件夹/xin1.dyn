    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# 加载 Python Standard 和 DesignScript 库\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n#-----------------------\r\nimport json\r\nimport re\r\nimport os\r\n\r\nocr_json_path = IN[0]\r\nresult_json_path = IN[1]\r\n\r\ndef ensure_dir_of_file(file_path):\r\n    folder = os.path.dirname(file_path)\r\n    if folder and not os.path.exists(folder):\r\n        os.makedirs(folder)\r\n\r\ndef get_poly(item):\r\n    return item.get(\"poly\", None)\r\n\r\ndef get_center(item):\r\n    poly = get_poly(item)\r\n    if poly:\r\n        xs = [p[0] for p in poly]\r\n        ys = [p[1] for p in poly]\r\n        return sum(xs) / float(len(xs)), sum(ys) / float(len(ys))\r\n    return None, None\r\n\r\ndef get_width_height(item):\r\n    poly = get_poly(item)\r\n    if not poly:\r\n        return None, None\r\n    xs = [p[0] for p in poly]\r\n    ys = [p[1] for p in poly]\r\n    return max(xs) - min(xs), max(ys) - min(ys)\r\n\r\ndef infer_axis(item):\r\n    w, h = get_width_height(item)\r\n    if w is None or h is None:\r\n        return \"unknown\"\r\n    if w >= h * 1.5:\r\n        return \"horizontal\"\r\n    elif h >= w * 1.5:\r\n        return \"vertical\"\r\n    else:\r\n        return \"unknown\"\r\n\r\ndef extract_numbers_from_text(text):\r\n    nums = re.findall(r'\\d+(?:\\.\\d+)?', text or \"\")\r\n    result = []\r\n    for n in nums:\r\n        try:\r\n            v = float(n)\r\n            if 100 <= v <= 50000:\r\n                # 尽量转 int，便于后续使用\r\n                if abs(v - int(v)) < 1e-6:\r\n                    result.append(int(v))\r\n                else:\r\n                    result.append(v)\r\n        except:\r\n            pass\r\n    return result\r\n\r\ndef classify_text(text):\r\n    nums = extract_numbers_from_text(text)\r\n    if len(nums) >= 2:\r\n        return \"dimension_chain\"\r\n    elif len(nums) == 1:\r\n        return \"number\"\r\n    return \"other\"\r\n\r\ndef is_valid_dimension_item(item):\r\n    text = str(item.get(\"text\", \"\")).strip()\r\n    score = float(item.get(\"score\", 0))\r\n    kind = classify_text(text)\r\n    nums = extract_numbers_from_text(text)\r\n\r\n    if len(nums) == 0:\r\n        return False\r\n\r\n    if kind in [\"number\", \"dimension_chain\"] and score >= 0.75:\r\n        return True\r\n\r\n    return False\r\n\r\ndef build_processed_items(items):\r\n    result = []\r\n    for item in items:\r\n        text = str(item.get(\"text\", \"\")).strip()\r\n        nums = extract_numbers_from_text(text)\r\n        kind = classify_text(text)\r\n        center = get_center(item)\r\n\r\n        result.append({\r\n            \"text\": text,\r\n            \"score\": float(item.get(\"score\", 0)),\r\n            \"poly\": item.get(\"poly\", None),\r\n            \"center\": center,\r\n            \"kind\": kind,\r\n            \"dimension_numbers\": nums,\r\n            \"valid\": is_valid_dimension_item(item)\r\n        })\r\n    return result\r\n\r\ndef group_items(items, axis, tol=60):\r\n    groups = []\r\n\r\n    for item in items:\r\n        x, y = item.get(\"center\", (None, None))\r\n        if x is None:\r\n            continue\r\n\r\n        coord = y if axis == \"horizontal\" else x\r\n\r\n        found = None\r\n        for g in groups:\r\n            if abs(g[\"coord\"] - coord) <= tol:\r\n                found = g\r\n                break\r\n\r\n        if found is None:\r\n            found = {\"axis\": axis, \"coord\": coord, \"items\": []}\r\n            groups.append(found)\r\n\r\n        found[\"items\"].append(item)\r\n\r\n    # 更新组坐标\r\n    for g in groups:\r\n        vals = []\r\n        for it in g[\"items\"]:\r\n            x, y = it.get(\"center\", (None, None))\r\n            vals.append(y if axis == \"horizontal\" else x)\r\n        if vals:\r\n            g[\"coord\"] = sum(vals) / float(len(vals))\r\n\r\n    return groups\r\n\r\ndef dedup_group_numbers(group, axis):\r\n    entries = []\r\n\r\n    for item in group[\"items\"]:\r\n        nums = item.get(\"dimension_numbers\", [])\r\n        x, y = item.get(\"center\", (None, None))\r\n        pos = x if axis == \"horizontal\" else y\r\n\r\n        for n in nums:\r\n            entries.append({\r\n                \"value\": n,\r\n                \"pos\": pos,\r\n                \"text\": item.get(\"text\", \"\")\r\n            })\r\n\r\n    entries = sorted(entries, key=lambda e: e[\"pos\"] if e[\"pos\"] is not None else 0)\r\n\r\n    deduped = []\r\n    for e in entries:\r\n        duplicated = False\r\n        for d in deduped:\r\n            same_value = (d[\"value\"] == e[\"value\"])\r\n            close_pos = False\r\n            if d[\"pos\"] is not None and e[\"pos\"] is not None:\r\n                close_pos = abs(d[\"pos\"] - e[\"pos\"]) <= 20\r\n            if same_value and close_pos:\r\n                duplicated = True\r\n                break\r\n        if not duplicated:\r\n            deduped.append(e)\r\n\r\n    return deduped\r\n\r\ndef summarize_group(group, axis):\r\n    deduped = dedup_group_numbers(group, axis)\r\n    values = [e[\"value\"] for e in deduped]\r\n\r\n    texts = []\r\n    seen = set()\r\n    for item in group[\"items\"]:\r\n        t = item.get(\"text\", \"\")\r\n        if t not in seen:\r\n            texts.append(t)\r\n            seen.add(t)\r\n\r\n    return {\r\n        \"axis\": axis,\r\n        \"coord\": group[\"coord\"],\r\n        \"count\": len(group[\"items\"]),\r\n        \"values\": values,\r\n        \"sum\": sum(values) if values else None,\r\n        \"texts\": texts\r\n    }\r\n\r\ntry:\r\n    with open(ocr_json_path, \"r\", encoding=\"utf-8\") as f:\r\n        data = json.load(f)\r\n\r\n    if not data.get(\"ok\", False):\r\n        result_data = {\r\n            \"ok\": False,\r\n            \"error\": \"ocr json not ok\",\r\n            \"source_json\": ocr_json_path\r\n        }\r\n    else:\r\n        raw_items = data.get(\"items\", [])\r\n        items = build_processed_items(raw_items)\r\n\r\n        dim_items = [it for it in items if it[\"valid\"]]\r\n\r\n        horizontal_items = [it for it in dim_items if infer_axis(it) == \"horizontal\"]\r\n        vertical_items = [it for it in dim_items if infer_axis(it) == \"vertical\"]\r\n\r\n        horizontal_groups = [summarize_group(g, \"horizontal\") for g in group_items(horizontal_items, \"horizontal\", 60)]\r\n        vertical_groups = [summarize_group(g, \"vertical\") for g in group_items(vertical_items, \"vertical\", 60)]\r\n\r\n        horizontal_groups = [g for g in horizontal_groups if g[\"sum\"] is not None]\r\n        vertical_groups = [g for g in vertical_groups if g[\"sum\"] is not None]\r\n\r\n        horizontal_groups = sorted(horizontal_groups, key=lambda g: g[\"sum\"], reverse=True)\r\n        vertical_groups = sorted(vertical_groups, key=lambda g: g[\"sum\"], reverse=True)\r\n\r\n        horizontal_main = horizontal_groups[0] if horizontal_groups else None\r\n        vertical_main = vertical_groups[0] if vertical_groups else None\r\n\r\n        result_data = {\r\n            \"ok\": True,\r\n            \"source_json\": ocr_json_path,\r\n            \"result\": {\r\n                \"horizontal_length\": horizontal_main[\"sum\"] if horizontal_main else None,\r\n                \"vertical_length\": vertical_main[\"sum\"] if vertical_main else None,\r\n                \"horizontal_candidates\": [g[\"sum\"] for g in horizontal_groups],\r\n                \"vertical_candidates\": [g[\"sum\"] for g in vertical_groups],\r\n                \"horizontal_segments\": horizontal_main[\"values\"] if horizontal_main else [],\r\n                \"vertical_segments\": vertical_main[\"values\"] if vertical_main else [],\r\n                \"horizontal_coord\": horizontal_main[\"coord\"] if horizontal_main else None,\r\n                \"vertical_coord\": vertical_main[\"coord\"] if vertical_main else None\r\n            },\r\n            \"debug\": {\r\n                \"horizontal_groups\": horizontal_groups,\r\n                \"vertical_groups\": vertical_groups\r\n            }\r\n        }\r\n\r\n    ensure_dir_of_file(result_json_path)\r\n    with open(result_json_path, \"w\", encoding=\"utf-8\") as f:\r\n        json.dump(result_data, f, ensure_ascii=False, indent=2)\r\n\r\n    # Dynamo 输出尽量简单\r\n    OUT = result_json_path\r\n\r\nexcept Exception as e:\r\n    err = {\r\n        \"ok\": False,\r\n        \"error\": str(e),\r\n        \"source_json\": ocr_json_path,\r\n        \"result_json_path\": result_json_path\r\n    }\r\n\r\n    try:\r\n        ensure_dir_of_file(result_json_path)\r\n        with open(result_json_path, \"w\", encoding=\"utf-8\") as f:\r\n            json.dump(err, f, ensure_ascii=False, indent=2)\r\n    except:\r\n        pass\r\n\r\n    OUT = result_json_path\r\n\r\n",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "f430ebd3ddb84187a9fb0285410f3a3a",
      "NodeType": "PythonScriptNode",
      "Inputs": [

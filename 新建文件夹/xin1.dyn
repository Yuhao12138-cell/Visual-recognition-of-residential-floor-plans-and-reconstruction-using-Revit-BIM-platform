    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# 加载 Python Standard 和 DesignScript 库\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\nimport os\r\nimport json\r\nimport subprocess\r\nimport shutil\r\nimport re\r\n\r\n# IN[0] = 原始图片长路径（不能动）\r\n# IN[1] = revitenv python.exe 路径\r\n# IN[2] = ocr_runner.py 路径\r\n# IN[3] = 临时工作目录，例如 E:\\temp_ocr\r\n# IN[4] = json 输出路径，例如 E:\\temp_ocr\\ocr_result.json\r\n\r\nsrc_image_path = IN[0]\r\npython_exe = IN[1]\r\nscript_path = IN[2]\r\nwork_dir = IN[3]\r\noutput_json = IN[4]\r\n\r\ndef ensure_dir(path):\r\n    if not os.path.exists(path):\r\n        os.makedirs(path)\r\n\r\ndef classify_text(text):\r\n    t = (text or \"\").strip()\r\n\r\n    room_keywords = [\"客厅\", \"卧室\", \"厨房\", \"卫生间\", \"阳台\", \"餐厅\", \"书房\", \"主卧\", \"次卧\"]\r\n    if any(k in t for k in room_keywords):\r\n        return \"room_name\"\r\n\r\n    if re.match(r'^\\d+(\\.\\d+)?\\s*(m²|m2|㎡)$', t, re.I):\r\n        return \"area\"\r\n\r\n    if re.match(r'^\\d+(\\.\\d+)?$', t):\r\n        return \"number\"\r\n\r\n    # 含尺寸链常见符号/字母/数字\r\n    if re.search(r'[\\dKk→—\\-米]+', t):\r\n        nums = extract_dimension_numbers(t)\r\n        if len(nums) >= 2:\r\n            return \"dimension_chain\"\r\n        elif len(nums) == 1:\r\n            return \"dimension_like\"\r\n\r\n    return \"other\"\r\n\r\ndef normalize_area_text(text):\r\n    t = (text or \"\").strip()\r\n    t = t.replace(\"㎡\", \"m²\")\r\n    t = re.sub(r'(?i)m2', 'm²', t)\r\n    return t\r\n\r\ndef extract_dimension_numbers(text):\r\n    \"\"\"\r\n    从类似 'K1280→1325→1905—→K3390—715' 中提取数字序列\r\n    返回 [1280,1325,1905,3390,715]\r\n    \"\"\"\r\n    if not text:\r\n        return []\r\n    nums = re.findall(r'\\d+(?:\\.\\d+)?', text)\r\n    result = []\r\n    for n in nums:\r\n        try:\r\n            if \".\" in n:\r\n                result.append(float(n))\r\n            else:\r\n                result.append(int(n))\r\n        except:\r\n            pass\r\n    return result\r\n\r\ndef is_valid_item(item):\r\n    text = (item.get(\"text\") or \"\").strip()\r\n    score = float(item.get(\"score\", 0))\r\n    kind = item.get(\"kind\", \"other\")\r\n\r\n    if not text:\r\n        return False\r\n\r\n    # 不同类型不同阈值\r\n    if kind == \"room_name\":\r\n        return score >= 0.75\r\n    elif kind == \"area\":\r\n        return score >= 0.75\r\n    elif kind == \"number\":\r\n        return score >= 0.85\r\n    elif kind == \"dimension_chain\":\r\n        # 尺寸链可以稍微放宽，因为经常混入符号\r\n        return score >= 0.70 or len(item.get(\"dimension_numbers\", [])) >= 2\r\n    elif kind == \"dimension_like\":\r\n        return score >= 0.75\r\n    else:\r\n        return score >= 0.75\r\n\r\ndef poly_center(poly):\r\n    try:\r\n        xs = [p[0] for p in poly]\r\n        ys = [p[1] for p in poly]\r\n        return [sum(xs) / float(len(xs)), sum(ys) / float(len(ys))]\r\n    except:\r\n        return None\r\n\r\ntry:\r\n    ensure_dir(work_dir)\r\n\r\n    # 固定复制输出图像\r\n    test_image_path = os.path.join(work_dir, \"Test1.jpg\")\r\n\r\n    # 直接复制文件，最稳\r\n    shutil.copyfile(src_image_path, test_image_path)\r\n\r\n    # 调外部 python\r\n    cmd = [python_exe, script_path, test_image_path, output_json]\r\n\r\n    p = subprocess.Popen(\r\n        cmd,\r\n        stdout=subprocess.PIPE,\r\n        stderr=subprocess.PIPE,\r\n        shell=False\r\n    )\r\n    stdout, stderr = p.communicate()\r\n\r\n    stdout_text = stdout.decode(\"utf-8\", errors=\"ignore\")\r\n    stderr_text = stderr.decode(\"utf-8\", errors=\"ignore\")\r\n\r\n    if not os.path.exists(output_json):\r\n        OUT = {\r\n            \"ok\": False,\r\n            \"error\": \"output_json not found\",\r\n            \"src_image_path\": src_image_path,\r\n            \"test_image_path\": test_image_path,\r\n            \"cmd\": cmd,\r\n            \"stdout\": stdout_text,\r\n            \"stderr\": stderr_text\r\n        }\r\n    else:\r\n        with open(output_json, \"r\", encoding=\"utf-8\") as f:\r\n            data = json.load(f)\r\n\r\n        if not data.get(\"ok\", False):\r\n            OUT = {\r\n                \"ok\": False,\r\n                \"src_image_path\": src_image_path,\r\n                \"test_image_path\": test_image_path,\r\n                \"cmd\": cmd,\r\n                \"stdout\": stdout_text,\r\n                \"stderr\": stderr_text,\r\n                \"json\": data\r\n            }\r\n        else:\r\n            items = data.get(\"items\", [])\r\n            processed_items = []\r\n\r\n            for item in items:\r\n                text = (item.get(\"text\") or \"\").strip()\r\n                score = float(item.get(\"score\", 0))\r\n                poly = item.get(\"poly\", None)\r\n\r\n                clean_text = normalize_area_text(text)\r\n                kind = classify_text(clean_text)\r\n                dim_nums = extract_dimension_numbers(clean_text)\r\n                center = poly_center(poly) if isinstance(poly, list) else None\r\n\r\n                item2 = {\r\n                    \"text\": text,\r\n                    \"clean_text\": clean_text,\r\n                    \"score\": score,\r\n                    \"poly\": poly,\r\n                    \"center\": center,\r\n                    \"kind\": kind,\r\n                    \"dimension_numbers\": dim_nums\r\n                }\r\n\r\n                item2[\"valid\"] = is_valid_item(item2)\r\n                processed_items.append(item2)\r\n\r\n            valid_items = [x for x in processed_items if x[\"valid\"]]\r\n            invalid_items = [x for x in processed_items if not x[\"valid\"]]\r\n\r\n            room_items = [x for x in valid_items if x[\"kind\"] == \"room_name\"]\r\n            area_items = [x for x in valid_items if x[\"kind\"] == \"area\"]\r\n            number_items = [x for x in valid_items if x[\"kind\"] == \"number\"]\r\n            dimension_chain_items = [x for x in valid_items if x[\"kind\"] == \"dimension_chain\"]\r\n            dimension_like_items = [x for x in valid_items if x[\"kind\"] == \"dimension_like\"]\r\n            other_items = [x for x in valid_items if x[\"kind\"] == \"other\"]\r\n\r\n            OUT = {\r\n                \"ok\": True,\r\n                \"src_image_path\": src_image_path,\r\n                \"test_image_path\": test_image_path,\r\n                \"output_json\": output_json,\r\n                \"cmd\": cmd,\r\n                \"stdout\": stdout_text,\r\n                \"stderr\": stderr_text,\r\n                \"all_items\": processed_items,\r\n                \"valid_items\": valid_items,\r\n                \"invalid_items\": invalid_items,\r\n                \"room_items\": room_items,\r\n                \"area_items\": area_items,\r\n                \"number_items\": number_items,\r\n                \"dimension_chain_items\": dimension_chain_items,\r\n                \"dimension_like_items\": dimension_like_items,\r\n                \"other_items\": other_items\r\n            }\r\n            OUT = output_json\r\n\r\nexcept Exception as e:\r\n    OUT = {\r\n        \"ok\": False,\r\n        \"error\": str(e),\r\n        \"src_image_path\": src_image_path\r\n    }\r\n",
      "Engine": "CPython3",
      "VariableInputPorts": true,

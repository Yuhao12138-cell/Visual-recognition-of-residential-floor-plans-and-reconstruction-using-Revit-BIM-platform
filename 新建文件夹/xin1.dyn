    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# 加载 PythonStandard 和 DesignScript 库\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\nimport Autodesk.DesignScript.Geometry as DS\r\nimport Revit\r\nfrom Revit.Elements import *\r\nimport System\r\nsys.path.append(\"C:/Users/Lenovo/anaconda3/envs/revitenv/Lib/site-packages\")\r\nclr.AddReference('RevitAPI')\r\nclr.AddReference('RevitAPIUI')\r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.UI import *\r\n\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\nclr.AddReference('RevitNodes')\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\n\r\nimport math\r\nimport re\r\nimport json\r\nimport os\r\nimport numpy as np\r\nimport torch\r\nimport cv2\r\nfrom ultralytics import YOLO\r\n\r\ndataEnteringNode = IN \r\n\r\n# =========================\r\n# 输入\r\n# =========================\r\npose_Model = IN[0]\r\npixpath = IN[1]\r\nscale = IN[2]   # 保留作fallback\r\ntarget_family_name = IN[3] if len(IN) > 3 else \"Bed\"\r\ntarget_type_name = IN[4] if len(IN) > 4 else \"Only_Bed\"\r\nseg_meta_json_path = IN[5] if len(IN) > 5 else None\r\n\r\n# =========================\r\n# 参数\r\n# =========================\r\norigin = XYZ(0, 0, 0)   \r\nwidthFt = scale\r\npixelWidth = 1600   \r\npixelHeight = 1200\r\n\r\n# 读取seg_meta后填充\r\nbbox_info = None\r\nbbox_min_x = None\r\nbbox_min_y = None\r\nbbox_width = None\r\nbbox_height = None\r\nscale_x_ft_per_px = None\r\nscale_y_ft_per_px = None\r\n\r\nlogs = []\r\n\r\n# =========================\r\n# 配置\r\n# =========================\r\nCLASS_CONFIG = {\r\n    \"Bed\": {\r\n        \"family_name\": \"Bed\",\r\n        \"type_name\": \"Bed\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": True,\r\n        \"family_default_axis\": \"Y\"\r\n    },\r\n    \"CookingCounter\": {\r\n        \"family_name\": \"CookingCounter\",\r\n        \"type_name\": \"CookingCounter\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\"\r\n    },\r\n    \"Cabinet\": {\r\n        \"family_name\": \"Cabinet\",\r\n        \"type_name\": \"Cabinet\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\"\r\n    },\r\n    \"DiningTable\": {\r\n        \"family_name\": \"DiningTable\",\r\n        \"type_name\": \"DiningTable\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\"\r\n    },\r\n    \"DiningTables\": {\r\n        \"family_name\": \"DiningTables\",\r\n        \"type_name\": \"DiningTables\",\r\n        \"rotate\": False,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\"\r\n    },\r\n    \"Sofa\": {\r\n        \"family_name\": \"Sofa\",\r\n        \"type_name\": \"Sofa\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\"\r\n    },\r\n    \"TVStand\": {\r\n        \"family_name\": \"TVStand\",\r\n        \"type_name\": \"TVStand\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\"\r\n    },\r\n    \"Toilet\": {\r\n        \"family_name\": \"Toilet\",\r\n        \"type_name\": \"Toilet\",\r\n        \"rotate\": True,\r\n        \"kp_start_idx\": 0,\r\n        \"kp_end_idx\": 1,\r\n        \"area_filter\": False,\r\n        \"family_default_axis\": \"Y\"\r\n    }\r\n}\r\n\r\n# =========================\r\n# 工具函数\r\n# =========================\r\ndef norm_str(s):\r\n    if s is None:\r\n        return \"\"\r\n    return str(s).strip().lower()\r\n\r\ndef sanitize_name(name):\r\n    if not name:\r\n        return \"Unknown\"\r\n    cleaned = re.sub(r'[\\x00-\\x1f\\x7f]', '', str(name))\r\n    if not cleaned.strip():\r\n        return \"Unnamed\"\r\n    return cleaned\r\n\r\ndef load_seg_meta(seg_meta_json_path, logs):\r\n    if not seg_meta_json_path:\r\n        logs.append(\"seg_meta_json_path为空，将使用fallback scale\")\r\n        return None\r\n    try:\r\n        with open(seg_meta_json_path, \"r\", encoding=\"utf-8\") as f:\r\n            data = json.load(f)\r\n        logs.append(\"读取seg_meta_json成功: {}\".format(seg_meta_json_path))\r\n        return data\r\n    except Exception as e:\r\n        logs.append(\"读取seg_meta_json失败: {}\".format(str(e)))\r\n        return None\r\n\r\ndef pix_to_revit(x, y):\r\n    \"\"\"\r\n    优先使用seg_meta中的 bbox + scale\r\n    与墙体和检测节点保持一致\r\n    \"\"\"\r\n    global bbox_min_x, bbox_min_y, bbox_width, bbox_height\r\n    global scale_x_ft_per_px, scale_y_ft_per_px\r\n    global origin, widthFt, pixelWidth, pixelHeight\r\n\r\n    try:\r\n        if bbox_min_x is not None and bbox_min_y is not None and bbox_height is not None \\\r\n           and scale_x_ft_per_px is not None and scale_y_ft_per_px is not None:\r\n\r\n            local_x = x - bbox_min_x\r\n            local_y = y - bbox_min_y\r\n\r\n            revit_x = origin.X + local_x * scale_x_ft_per_px\r\n            revit_y = origin.Y + (bbox_height - local_y) * scale_y_ft_per_px\r\n            return XYZ(revit_x, revit_y, origin.Z)\r\n    except:\r\n        pass\r\n\r\n    # fallback\r\n    scaleX = widthFt / pixelWidth if pixelWidth > 0 else 0.0\r\n    scaleY = widthFt * (float(pixelHeight) / float(pixelWidth)) / pixelHeight if pixelWidth > 0 and pixelHeight > 0 else 0.0\r\n    revit_x = origin.X + x * scaleX\r\n    revit_y = origin.Y + (pixelHeight - y) * scaleY\r\n    return XYZ(revit_x, revit_y, origin.Z)\r\n\r\ndef get_level(doc):\r\n    av = doc.ActiveView\r\n    try:\r\n        if hasattr(av, \"GenLevel\") and av.GenLevel:\r\n            return av.GenLevel\r\n    except:\r\n        pass\r\n    levels = FilteredElementCollector(doc).OfClass(Level).ToElements()\r\n    if levels and len(levels) > 0:\r\n        return levels[0]\r\n    return None\r\n\r\ndef find_family_symbol(doc, family_name=None, type_name=None):\r\n    collector = FilteredElementCollector(doc).OfClass(FamilySymbol)\r\n    for fs in collector:\r\n        try:\r\n            fam_name = fs.Family.Name if fs.Family else None\r\n            p = fs.get_Parameter(BuiltInParameter.SYMBOL_NAME_PARAM)\r\n            typ_name = p.AsString() if p else fs.Name\r\n\r\n            family_ok = True if family_name is None else (fam_name == family_name)\r\n            type_ok = True if type_name is None else (typ_name == type_name)\r\n\r\n            if family_ok and type_ok:\r\n                return fs\r\n        except:\r\n            pass\r\n    return None\r\n\r\ndef angle_from_vector(vec, family_default_axis=\"X\"):\r\n    vx = vec.X\r\n    vy = vec.Y\r\n    angle = math.atan2(vy, vx)\r\n\r\n    if family_default_axis == \"Y\":\r\n        angle -= math.pi / 2.0\r\n\r\n    return angle\r\n\r\ndef build_symbol_lookup(doc):\r\n    lookup = {}\r\n    collector = FilteredElementCollector(doc).OfClass(FamilySymbol)\r\n    for fs in collector:\r\n        try:\r\n            fam_name = fs.Family.Name if fs.Family else \"\"\r\n            p = fs.get_Parameter(BuiltInParameter.SYMBOL_NAME_PARAM)\r\n            typ_name = p.AsString() if p else fs.Name\r\n            key = (norm_str(fam_name), norm_str(typ_name))\r\n            lookup[key] = fs\r\n        except:\r\n            pass\r\n    return lookup\r\n\r\ndef get_symbol_from_lookup(symbol_lookup, family_name, type_name):\r\n    key = (norm_str(family_name), norm_str(type_name))\r\n    if key in symbol_lookup:\r\n        return symbol_lookup[key]\r\n    return None\r\n\r\ndef compute_class_area_threshold(boxes, cls_ids, names, class_name, scale_ratio=0.33):\r\n    areas = []\r\n    for i, bbox in enumerate(boxes):\r\n        cls_name = names[int(cls_ids[i])] if len(cls_ids) > i else \"\"\r\n        if cls_name != class_name:\r\n            continue\r\n\r\n        x1, y1, x2, y2 = bbox\r\n        area = max(0, (x2 - x1)) * max(0, (y2 - y1))\r\n        areas.append(area)\r\n\r\n    if len(areas) == 0:\r\n        return 0.0, 0.0\r\n\r\n    median_area = float(np.median(areas))\r\n    min_area = median_area * scale_ratio\r\n    return median_area, min_area\r\n\r\ndef ensure_symbol_active(doc, symbol):\r\n    if symbol and not symbol.IsActive:\r\n        symbol.Activate()\r\n        doc.Regenerate()\r\n\r\ndef create_family_instance(doc, center_pt, symbol, level):\r\n    try:\r\n        instance = doc.Create.NewFamilyInstance(\r\n            center_pt,\r\n            symbol,\r\n            level,\r\n            StructuralType.NonStructural\r\n        )\r\n    except:\r\n        instance = doc.Create.NewFamilyInstance(\r\n            center_pt,\r\n            symbol,\r\n            doc.ActiveView\r\n        )\r\n    return instance\r\n\r\ndef get_angle_from_keypoints(start_pt, end_pt, family_default_axis=\"Y\"):\r\n    vec = XYZ(\r\n        start_pt.X - end_pt.X,\r\n        start_pt.Y - end_pt.Y,\r\n        0\r\n    )\r\n\r\n    if vec.GetLength() < 1e-6:\r\n        return None\r\n\r\n    angle = math.atan2(vec.Y, vec.X)\r\n\r\n    if family_default_axis == \"Y\":\r\n        angle -= math.pi / 2.0\r\n\r\n    return angle\r\n\r\ndef rotate_instance(doc, instance, center_pt, angle):\r\n    axis_end = XYZ(center_pt.X, center_pt.Y, center_pt.Z + 1.0)\r\n    axis = Line.CreateBound(center_pt, axis_end)\r\n    ElementTransformUtils.RotateElement(doc, instance.Id, axis, angle)\r\n\r\n# =========================\r\n# 读取seg_meta\r\n# =========================\r\nseg_meta = load_seg_meta(seg_meta_json_path, logs)\r\n\r\nif seg_meta and seg_meta.get(\"ok\", False):\r\n    try:\r\n        bbox_info = seg_meta.get(\"wall_bbox_px\", None)\r\n        scale_info = seg_meta.get(\"scale\", {})\r\n        dbg = seg_meta.get(\"debug\", {})\r\n\r\n        if bbox_info:\r\n            bbox_min_x = bbox_info.get(\"min_x\", None)\r\n            bbox_min_y = bbox_info.get(\"min_y\", None)\r\n            bbox_width = bbox_info.get(\"width\", None)\r\n            bbox_height = bbox_info.get(\"height\", None)\r\n\r\n        scale_x_ft_per_px = scale_info.get(\"scale_x_ft_per_px\", None)\r\n        scale_y_ft_per_px = scale_info.get(\"scale_y_ft_per_px\", None)\r\n\r\n        if \"pixelWidth\" in dbg and \"pixelHeight\" in dbg:\r\n            pixelWidth = dbg.get(\"pixelWidth\", pixelWidth)\r\n            pixelHeight = dbg.get(\"pixelHeight\", pixelHeight)\r\n\r\n        logs.append(\"bbox_info={}\".format(str(bbox_info)))\r\n        logs.append(\"scale_x_ft_per_px={}\".format(str(scale_x_ft_per_px)))\r\n        logs.append(\"scale_y_ft_per_px={}\".format(str(scale_y_ft_per_px)))\r\n        logs.append(\"pixelWidth={}, pixelHeight={}\".format(pixelWidth, pixelHeight))\r\n    except Exception as e:\r\n        logs.append(\"解析seg_meta失败: {}\".format(str(e)))\r\nelse:\r\n    logs.append(\"seg_meta无效，使用fallback整图scale\")\r\n\r\n# =========================\r\n# 运行姿态估计\r\n# =========================\r\nyolo_pose = YOLO(pose_Model, task=\"pose\")\r\nnewpath = \"E:/yanjiu/revitss/tests/jjianzhu_pose.jpg\"\r\n\r\npose_results = yolo_pose(\r\n    source=pixpath,\r\n    save=False,\r\n    conf=0.3,\r\n    iou=0.45,\r\n    imgsz=640\r\n)\r\ncv2.imwrite(newpath, pose_results[0].plot())\r\n\r\nresult = pose_results[0]\r\nboxes = result.boxes.xyxy.cpu().numpy() if result.boxes is not None else []\r\ncls_ids = result.boxes.cls.cpu().numpy().astype(int) if result.boxes is not None else []\r\nconfs = result.boxes.conf.cpu().numpy() if result.boxes is not None else []\r\nnames = result.names\r\nkps_xy = None\r\nif result.keypoints is not None and result.keypoints.xy is not None:\r\n    kps_xy = result.keypoints.xy.cpu().numpy()\r\n\r\n# =========================\r\n# Revit对象\r\n# =========================\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\napp = doc.Application\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\nlevel = get_level(doc)\r\nsymbol_lookup = build_symbol_lookup(doc)\r\n\r\nbed_median_area, bed_min_area = compute_class_area_threshold(\r\n    boxes, cls_ids, names, \"Bed\", 0.33\r\n)\r\n\r\n# process areas\r\nbed_indices = []\r\nbed_areas = []\r\nfor i, bbox in enumerate(boxes):\r\n    cls_name = names[int(cls_ids[i])] if len(cls_ids) > i else \"\"\r\n    if cls_name != \"Bed\":\r\n        continue\r\n\r\n    x1, y1, x2, y2 = bbox\r\n    area = max(0, (x2 - x1)) * max(0, (y2 - y1))\r\n    bed_indices.append(i)\r\n    bed_areas.append(area)\r\n\r\nif len(bed_areas) > 0:\r\n    median_bed_area = float(np.median(bed_areas))\r\n    min_area_threshold = median_bed_area * 0.33\r\nelse:\r\n    median_bed_area = 0.0\r\n    min_area_threshold = 0.0\r\n\r\ncreated_lines = []\r\ndyn_lines = []\r\ndyn_faces = [] \r\ncreated_shapes = []\r\ncreated_instances = []\r\ndebug_info = []\r\nmissing_family_types = []\r\nskipped_unconfigured_classes = []\r\n\r\nplane = Plane.CreateByNormalAndOrigin(XYZ.BasisZ, origin)\r\nsketch_plane = SketchPlane.Create(doc, plane)\r\n\r\nfor cls_name, cfg in CLASS_CONFIG.items():\r\n    symbol = get_symbol_from_lookup(\r\n        symbol_lookup,\r\n        cfg.get(\"family_name\"),\r\n        cfg.get(\"type_name\")\r\n    )\r\n    if symbol:\r\n        ensure_symbol_active(doc, symbol)\r\n\r\n# =========================\r\n# 放置实例\r\n# =========================\r\nfor i, bbox in enumerate(boxes):\r\n    cls_name = names[int(cls_ids[i])] if len(cls_ids) > i else \"\"\r\n    conf = confs[i] if len(confs) > i else 0.0\r\n\r\n    # 1. 配置中未定义的类，跳过\r\n    if cls_name not in CLASS_CONFIG:\r\n        skipped_unconfigured_classes.append({\r\n            \"index\": i,\r\n            \"class\": cls_name,\r\n            \"reason\": \"class_not_configured\"\r\n        })\r\n        continue\r\n\r\n    cfg = CLASS_CONFIG[cls_name]\r\n    family_name = cfg.get(\"family_name\")\r\n    type_name = cfg.get(\"type_name\")\r\n    need_rotate = cfg.get(\"rotate\", False)\r\n    family_default_axis = cfg.get(\"family_default_axis\", \"Y\")\r\n\r\n    # 2. 查找对应族类型\r\n    symbol = get_symbol_from_lookup(symbol_lookup, family_name, type_name)\r\n    if symbol is None:\r\n        missing_family_types.append({\r\n            \"index\": i,\r\n            \"class\": cls_name,\r\n            \"family_name\": family_name,\r\n            \"type_name\": type_name,\r\n            \"reason\": \"family_symbol_not_found\"\r\n        })\r\n        continue\r\n\r\n    # 3. 中心点\r\n    x1, y1, x2, y2 = bbox\r\n    cx = (x1 + x2) / 2.0\r\n    cy = (y1 + y2) / 2.0\r\n    center_pt = pix_to_revit(cx, cy)\r\n\r\n    # 4. 面积过滤\r\n    area = max(0, (x2 - x1)) * max(0, (y2 - y1))\r\n    if cfg.get(\"area_filter\", False):\r\n        if cls_name == \"Bed\" and bed_min_area > 0 and area < bed_min_area:\r\n            debug_info.append({\r\n                \"index\": i,\r\n                \"class\": cls_name,\r\n                \"reason\": \"filtered_small_area\",\r\n                \"area\": area,\r\n                \"threshold\": bed_min_area\r\n            })\r\n            continue\r\n\r\n    # 5. 创建实例\r\n    try:\r\n        instance = create_family_instance(doc, center_pt, symbol, level)\r\n    except Exception as e:\r\n        debug_info.append({\r\n            \"index\": i,\r\n            \"class\": cls_name,\r\n            \"reason\": \"create_instance_failed\",\r\n            \"error\": str(e)\r\n        })\r\n        continue\r\n\r\n    rotated = False\r\n    angle = None\r\n    start_pt = None\r\n    end_pt = None\r\n\r\n    # 6. 如果该类需要旋转，尝试读取关键点\r\n    if need_rotate:\r\n        kp_start_idx = cfg.get(\"kp_start_idx\", None)\r\n        kp_end_idx = cfg.get(\"kp_end_idx\", None)\r\n\r\n        if kps_xy is not None and i < len(kps_xy) and kp_start_idx is not None and kp_end_idx is not None:\r\n            kp = kps_xy[i]\r\n\r\n            if len(kp) > max(kp_start_idx, kp_end_idx):\r\n                sx, sy = kp[kp_start_idx]\r\n                ex, ey = kp[kp_end_idx]\r\n\r\n                start_pt = pix_to_revit(sx, sy)\r\n                end_pt = pix_to_revit(ex, ey)\r\n\r\n                angle = get_angle_from_keypoints(\r\n                    start_pt,\r\n                    end_pt,\r\n                    family_default_axis\r\n                )\r\n\r\n                if angle is not None:\r\n                    try:\r\n                        rotate_instance(doc, instance, center_pt, angle)\r\n                        rotated = True\r\n                    except Exception as e:\r\n                        debug_info.append({\r\n                            \"index\": i,\r\n                            \"class\": cls_name,\r\n                            \"reason\": \"rotate_failed\",\r\n                            \"error\": str(e)\r\n                        })\r\n                else:\r\n                    debug_info.append({\r\n                        \"index\": i,\r\n                        \"class\": cls_name,\r\n                        \"reason\": \"zero_direction_vector\"\r\n                    })\r\n            else:\r\n                debug_info.append({\r\n                    \"index\": i,\r\n                    \"class\": cls_name,\r\n                    \"reason\": \"insufficient_keypoints\"\r\n                })\r\n        else:\r\n            debug_info.append({\r\n                \"index\": i,\r\n                \"class\": cls_name,\r\n                \"reason\": \"no_keypoints_for_rotation\"\r\n            })\r\n\r\n    created_instances.append(instance.ToDSType(False))\r\n    debug_info.append({\r\n        \"index\": i,\r\n        \"class\": cls_name,\r\n        \"family_name\": family_name,\r\n        \"type_name\": type_name,\r\n        \"center_xyz\": [center_pt.X, center_pt.Y, center_pt.Z],\r\n        \"bbox_px\": [float(x1), float(y1), float(x2), float(y2)],\r\n        \"area\": area,\r\n        \"rotated\": rotated,\r\n        \"angle_rad\": angle,\r\n        \"angle_deg\": angle * 180.0 / math.pi if angle is not None else None,\r\n        \"conf\": float(conf),\r\n        \"kp_start_xyz\": [start_pt.X, start_pt.Y, start_pt.Z] if start_pt else None,\r\n        \"kp_end_xyz\": [end_pt.X, end_pt.Y, end_pt.Z] if end_pt else None\r\n    })\r\n\r\n# =========================\r\n# 提交事务\r\n# =========================\r\nTransactionManager.Instance.TransactionTaskDone()\r\ndoc.Regenerate()\r\n\r\nOUT = {\r\n    \"preview_image\": newpath,\r\n    \"created_instances\": created_instances,\r\n    \"debug_info\": debug_info,\r\n    \"missing_family_types\": missing_family_types,\r\n    \"skipped_unconfigured_classes\": skipped_unconfigured_classes,\r\n    \"bed_area_threshold\": {\r\n        \"median_area\": bed_median_area,\r\n        \"min_area\": bed_min_area\r\n    },\r\n    \"seg_meta_json_path\": seg_meta_json_path,\r\n    \"logs\": logs\r\n}\r\n",

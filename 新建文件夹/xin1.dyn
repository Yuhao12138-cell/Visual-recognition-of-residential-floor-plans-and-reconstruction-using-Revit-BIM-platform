    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# 加载 Python Standard 和 DesignScript 库\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\nsys.path.append(\"C:/Users/Lenovo/anaconda3/envs/revitenv/Lib/site-packages\")\r\nimport numpy as np\r\nimport torch\r\nimport cv2\r\nfrom ultralytics import YOLO\r\n\r\n# 该节点的输入内容将存储为 IN 变量中的一个列表。\r\ndataEnteringNode = IN                            \r\n# 将代码放在该行下面                          \r\nyolo_seg = YOLO(\"E:/yanjiu/hou_pracs_on/Testings/Saves/yolov8l-seg.pt\",task = \"seg\")\r\n\r\nfilepath = \"E:/yanjiu/revitss/tests/jiedao.jpg\"\r\nnewpath = \"E:/yanjiu/revitss/tests/jiedao_seg.jpg\"\r\n\r\nseg_result = yolo_seg(source = filepath,save = False,conf = 0.3,iou = 0.45,imgsz = 640)\r\ncv2.imwrite(newpath,seg_result[0].plot())\r\n\r\n\r\n\r\n# 将输出内容指定给 OUT 变量。\r\nOUT = torch.__version__",
